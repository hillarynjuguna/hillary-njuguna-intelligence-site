# Oscillatory Fields - Environment Variables

# Resend API Key for dispatching CIR Assessment results and diagnostic emails
RESEND_API_KEY=re_123456789

# Vercel Postgres URL for storing CIR assessments and telemetry
POSTGRES_URL=postgres://default:password@ep-hidden-brook-1234.us-east-1.postgres.vercel-storage.com:5432/verceldb
POSTGRES_PRISMA_URL=postgres://default:password@ep-hidden-brook-1234.us-east-1.postgres.vercel-storage.com:5432/verceldb?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://default:password@ep-hidden-brook-1234.us-east-1.postgres.vercel-storage.com:5432/verceldb
POSTGRES_USER=default
POSTGRES_HOST=ep-hidden-brook-1234.us-east-1.postgres.vercel-storage.com
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=verceldb
