# Hillary Njuguna — Intelligence Architecture Site
# Copy this to .env for local development
# In Vercel: Settings → Environment Variables → Add each key below

# ── REQUIRED ──

# OpenRouter API key — get from openrouter.ai (OpenAI-compatible, supports 200+ models)
# NEVER commit the real value. This file is safe to commit.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── OPTIONAL ──

# Formspree endpoint (already hardcoded in HTML but document here for reference)
# FORMSPREE_ENDPOINT=https://formspree.io/f/maqdrora

# If you add Plausible analytics later:
# PLAUSIBLE_DOMAIN=hillary-site.vercel.app

# If you add Sentry error tracking later:
# SENTRY_DSN=your_sentry_dsn_here
