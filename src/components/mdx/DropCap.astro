---
interface Props {
  letter: string;
  accent?: 'ember' | 'sage' | 'gold';
}

const { letter, accent = 'ember' } = Astro.props;
---

<span class={`drop-cap drop-cap--${accent}`}>{letter}</span>

<style>
  .drop-cap {
    float: left;
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    line-height: 0.85;
    padding-top: 4px;
    padding-right: var(--space-2);
    padding-left: 2px;
    font-weight: 700;
    color: var(--accent-color, var(--ember));
    user-select: none;
  }

  .drop-cap--ember {
    --accent-color: var(--ember);
  }

  .drop-cap--sage {
    --accent-color: var(--sage);
  }

  .drop-cap--gold {
    --accent-color: var(--gold);
  }
</style>
