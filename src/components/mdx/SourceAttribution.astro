---
import claimsData from '../../data/claims.json';

interface Props {
  claimId: string;
}

const { claimId } = Astro.props;

// Find the claim in database
const claim = claimsData.claims.find((c) => c.id === claimId);

if (!claim) {
  throw new Error(`[SourceAttribution] Claim ID "${claimId}" not found in claims.json`);
}

// Find corresponding source if present
const source = claim.sourceId ? claimsData.sources.find((s) => s.id === claim.sourceId) : null;

// Determine badge label and color
let tierLabel = "Extrapolated from Principles";
let tierClass = "tier-3";
let tierColor = "#5C554D";

if (claim.tier === 1) {
  tierLabel = "Verified Source";
  tierClass = "tier-1";
  tierColor = "var(--color-verified)";
} else if (claim.tier === 2) {
  tierLabel = "Reported — Unverified";
  tierClass = "tier-2";
  tierColor = "var(--color-sovereign)";
}
---

<span class="attribution-container" data-claim-id={claimId}>
  <span class="claim-body"><slot /></span><sup class="superscript-marker" style={`color: ${tierColor};`}>[{claim.id}]</sup>
  
  <!-- Tooltip overlay -->
  <span class="attribution-tooltip">
    <span class="tooltip-header">
      <span class={`tier-badge ${tierClass}`}>{tierLabel}</span>
      <span class="claim-id-badge">{claim.id}</span>
    </span>
    
    {source ? (
      <span class="source-details">
        <span class="source-title">"{source.title}"</span>
        <span class="source-meta">
          <span class="source-authors">{source.authors}</span>
          <span class="source-venue">{source.venue}</span>
        </span>
        <a href={source.url} target="_blank" rel="noopener" class="source-link">
          Source Document &rarr;
        </a>
      </span>
    ) : (
      <span class="source-details">
        <span class="source-note">{claim.note}</span>
      </span>
    )}
  </span>
</span>

<style>
  .attribution-container {
    position: relative;
    display: inline;
    cursor: help;
  }
  .superscript-marker {
    font-family: var(--font-mono);
    font-size: 0.7em;
    font-weight: bold;
    margin-left: 1px;
    user-select: none;
    transition: filter var(--duration-fast) var(--ease-out);
  }
  .attribution-container:hover .superscript-marker {
    filter: brightness(1.2);
  }
  .attribution-tooltip {
    position: absolute;
    bottom: 120%;
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    width: 280px;
    padding: var(--space-4);
    background: var(--surface-1);
    border: 1px solid var(--border-bright);
    border-radius: var(--radius-md);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    opacity: 0;
    pointer-events: none;
    z-index: var(--z-raised);
    transition: opacity var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  
  /* Show tooltip on hover or active container touch */
  .attribution-container:hover .attribution-tooltip {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  
  .tooltip-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-dim);
    padding-bottom: var(--space-2);
  }
  .tier-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: bold;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }
  .tier-badge.tier-1 {
    background: rgba(13, 148, 136, 0.08);
    color: var(--color-verified);
    border: 1px solid rgba(13, 148, 136, 0.2);
  }
  .tier-badge.tier-2 {
    background: rgba(217, 119, 6, 0.08);
    color: var(--color-sovereign);
    border: 1px solid rgba(217, 119, 6, 0.2);
  }
  .tier-badge.tier-3 {
    background: rgba(92, 85, 77, 0.08);
    color: #5C554D;
    border: 1px solid rgba(92, 85, 77, 0.2);
  }
  .claim-id-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }
  
  .source-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .source-title {
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--text-primary);
  }
  .source-meta {
    display: flex;
    flex-direction: column;
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: var(--leading-tight);
  }
  .source-authors {
    font-style: italic;
  }
  .source-venue {
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    margin-top: 1px;
  }
  .source-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ember);
    text-decoration: none;
    font-weight: bold;
    margin-top: var(--space-1);
    transition: color var(--duration-fast) var(--ease-out);
  }
  .source-link:hover {
    color: var(--ember-bright);
    text-decoration: underline;
  }
  .source-note {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
  }

  /* Adaptive tooltip position at edges */
  @media (max-width: 480px) {
    .attribution-tooltip {
      width: 220px;
    }
  }
</style>
