---
// ValidationStack.astro - Stacked horizontal bar chart for token prefix allocation
---

<div class="validation-stack-container">
  <div class="stack-title">Context Token Allocation</div>
  
  <div class="horizontal-stack-bar">
    <div class="stack-segment segment-schemas" style="width: 99.3%;">
      <span class="segment-label">Static Tool Schemas (75,000 tokens)</span>
    </div>
    <div class="stack-segment segment-prompt" style="width: 0.7%;">
      <span class="segment-label">Prompt</span>
    </div>
  </div>

  <div class="stack-legend">
    <div class="legend-item">
      <span class="legend-color color-grey"></span>
      <span class="legend-text">Tool Definition Overhead: 99.33%</span>
    </div>
    <div class="legend-item">
      <span class="legend-color color-teal"></span>
      <span class="legend-text">Actual Query Payload: 0.67%</span>
    </div>
  </div>
</div>

<style>
  .validation-stack-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin: var(--space-8) 0;
    padding: var(--space-6);
    background: var(--surface-1);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
  }
  .stack-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-secondary);
  }
  .horizontal-stack-bar {
    display: flex;
    width: 100%;
    height: 36px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-mid);
    overflow: hidden;
    background: var(--surface-3);
  }
  .stack-segment {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-mid) var(--ease-out);
  }
  .segment-schemas {
    background: var(--color-infrastructure);
    color: rgba(255, 255, 255, 0.7);
    border-right: 1px solid var(--border-bright);
  }
  .segment-prompt {
    background: var(--color-verified);
    color: var(--observable);
  }
  .segment-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 var(--space-2);
  }
  .segment-prompt .segment-label {
    position: absolute;
    bottom: -22px;
    right: 0;
    color: var(--color-verified);
    font-weight: bold;
  }
  .stack-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    border-top: 1px solid var(--border-dim);
    padding-top: var(--space-3);
    margin-top: var(--space-2);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .legend-color {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .color-grey {
    background: var(--color-infrastructure);
  }
  .color-teal {
    background: var(--color-verified);
  }
  .legend-text {
    font-size: var(--text-xs);
    color: var(--text-secondary);
  }
</style>
