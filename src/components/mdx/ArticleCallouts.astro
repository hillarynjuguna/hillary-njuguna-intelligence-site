---
// Semantic callout components for Intelligence Digest articles
// These create reading cadence and epistemic framing
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  type?: 'trap' | 'advice' | 'pullquote' | 'hook' | 'divider';
  number?: string | number;
  title?: string;
  attribution?: string;
}
const { type, ...props } = Astro.props;
---

<!-- TRAP: Failure mode or hidden risk in the system -->
{type === 'trap' && (
  <div class="callout callout--trap" {...props}>
    {(props.number || props.title) && (
      <div class="callout__header callout__header--trap">
        <span class="callout__label">Trap</span>
        {props.number && <h3 class="callout__number">#{props.number}</h3>}
        {props.title && <p class="callout__title">{props.title}</p>}
      </div>
    )}
    <div class="callout__body callout__body--trap">
      <slot />
    </div>
  </div>
)}

<!-- ADVICE: Actionable guidance to prevent or recover from failure -->
{type === 'advice' && (
  <div class="callout callout--advice" {...props}>
    {props.title && (
      <div class="callout__header callout__header--advice">
        <span class="callout__label">What to do instead</span>
        <h3 class="callout__title">{props.title}</h3>
      </div>
    )}
    <div class="callout__body callout__body--advice">
      <slot />
    </div>
  </div>
)}

<!-- PULLQUOTE: Emphasis or reflection point in prose -->
{type === 'pullquote' && (
  <blockquote class="callout callout--pullquote" {...props}>
    <div class="callout__body callout__body--pullquote">
      <slot />
    </div>
    {props.attribution && (
      <span class="callout__attribution">— {props.attribution}</span>
    )}
  </blockquote>
)}

<!-- HOOK: Opening frame that sets the emotional/narrative context -->
{type === 'hook' && (
  <div class="callout callout--hook" {...props}>
    <div class="callout__body callout__body--hook">
      <slot />
    </div>
  </div>
)}

<!-- DIVIDER: Semantic break between major sections -->
{type === 'divider' && (
  <div class="callout callout--divider" {...props}>
    <span aria-hidden="true">·  ·  ·</span>
  </div>
)}

<style>
  /* ── CALLOUT SYSTEM ────────────────────────────────────────────────── */

  .callout {
    margin: 2.4rem 0;
  }

  /* TRAP — Failure Mode Container */
  .callout--trap {
    border: none;
    background: transparent;
  }

  .callout__header--trap {
    background: var(--ember, #c0392b);
    color: #fff;
    border-radius: 6px 6px 0 0;
    padding: 1rem 1.4rem 0.85rem;
    margin-bottom: 0;
  }

  .callout__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
    display: block;
    margin-bottom: 0.3rem;
  }

  .callout__number {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .callout__title {
    margin: 0.3rem 0 0;
    font-size: 1.32rem;
    font-weight: 700;
    line-height: 1.3;
    color: #fff;
  }

  .callout__body--trap {
    border: 2px solid var(--ember, #c0392b);
    border-top: none;
    border-radius: 0 0 6px 6px;
    padding: 1.4rem 1.5rem;
    background: #fff;
  }

  .callout__body--trap :first-child {
    margin-top: 0;
  }

  .callout__body--trap :last-child {
    margin-bottom: 0;
  }

  /* ADVICE — Actionable Guidance */
  .callout--advice {
    background: var(--sage, #0f4c3a);
    color: var(--text-light, #e8f5f1);
    border-radius: 6px;
    padding: 0;
    overflow: hidden;
  }

  .callout__header--advice {
    padding: 1.2rem 1.5rem 0.5rem;
    background: transparent;
    border-bottom: 1px solid rgba(168, 223, 201, 0.2);
  }

  .callout__header--advice .callout__label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    opacity: 0.75;
    margin-bottom: 0.4rem;
  }

  .callout__header--advice .callout__title {
    font-size: 1rem;
    font-weight: 700;
    color: #a8dfc9;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .callout__body--advice {
    padding: 1.2rem 1.5rem 1rem;
    color: var(--text-light, #e8f5f1);
  }

  .callout__body--advice :first-child {
    margin-top: 0;
  }

  .callout__body--advice :last-child {
    margin-bottom: 0;
  }

  .callout__body--advice ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .callout__body--advice li {
    padding: 0.45rem 0 0.45rem 2rem;
    position: relative;
    font-size: 0.97rem;
    border-bottom: 1px solid rgba(168, 223, 201, 0.15);
    line-height: 1.6;
  }

  .callout__body--advice li:last-child {
    border-bottom: none;
  }

  .callout__body--advice li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #a8dfc9;
    font-weight: 700;
    font-size: 1em;
  }

  /* PULLQUOTE — Emphasis and Reflection */
  .callout--pullquote {
    margin: 1.6rem 0;
    padding: 1.1rem 1.6rem;
    background: var(--surface-2, #f9f4ef);
    border-left: 5px solid var(--ember, #c0392b);
    font-style: italic;
    font-size: 1.12em;
    color: var(--text-primary, #3a2a2a);
    line-height: 1.65;
    display: block;
  }

  .callout--pullquote :first-child {
    margin-top: 0;
  }

  .callout--pullquote :last-child {
    margin-bottom: 0;
  }

  .callout__attribution {
    display: block;
    margin-top: 0.8rem;
    font-style: normal;
    font-size: 0.95em;
    opacity: 0.75;
  }

  /* HOOK — Narrative Opening */
  .callout--hook {
    border-left: 4px solid var(--ember, #c0392b);
    padding: 1.2rem 1.5rem;
    background: var(--surface-1, #fff8f6);
    font-style: italic;
    font-size: 1.18em;
    color: var(--text-primary, #2c2c2c);
    line-height: 1.7;
  }

  .callout--hook :first-child {
    margin-top: 0;
  }

  .callout--hook :last-child {
    margin-bottom: 0;
  }

  /* DIVIDER — Section Break */
  .callout--divider {
    text-align: center;
    color: var(--text-tertiary, #bbb);
    letter-spacing: 0.4em;
    margin: 2.2rem 0;
    font-size: 0.9em;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .callout {
      margin: 1.8rem 0;
    }

    .callout__title {
      font-size: 1.15rem;
    }

    .callout--hook {
      font-size: 1.05rem;
    }
  }
</style>
