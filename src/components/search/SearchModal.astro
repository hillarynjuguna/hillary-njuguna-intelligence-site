---
/**
 * SearchModal.astro
 * A premium, command-palette style search interface using Fuse.js.
 * Features: ⌘K / Ctrl+K trigger, fuzzy search, keyboard navigation, and collection filtering.
 */
---

<div id="search-modal" class="search-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="search-modal-container">
    <header class="search-header">
      <div class="search-input-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input 
          type="search" 
          id="search-input"
          placeholder="Search the corpus..."
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the corpus"
        />
        <kbd class="close-kbd">ESC</kbd>
      </div>

      <nav class="search-filters" aria-label="Search filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="research">Research</button>
        <button class="filter-btn" data-filter="digest">Digest</button>
        <button class="filter-btn" data-filter="products">Products</button>
        <button class="filter-btn" data-filter="clauses">Clauses</button>
      </nav>
    </header>

    <div id="search-results" class="search-results" aria-live="polite">
      <div class="search-empty">
        <p>Type to begin searching the intelligence architecture...</p>
      </div>
    </div>

    <footer class="search-footer">
      <div class="search-command">
        <kbd>↑↓</kbd> <span>Navigate</span>
      </div>
      <div class="search-command">
        <kbd>↵</kbd> <span>Open</span>
      </div>
      <div class="search-command">
        <kbd>ESC</kbd> <span>Close</span>
      </div>
    </footer>
  </div>
</div>

<style>
  .search-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background: rgba(5, 4, 3, 0.85);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-mid) var(--ease-out);
    padding: var(--space-4);
  }

  .search-modal-overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .search-modal-container {
    width: 100%;
    max-width: 640px;
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    transform: translateY(20px);
    transition: transform var(--duration-mid) var(--ease-out);
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .search-modal-overlay[aria-hidden="false"] .search-modal-container {
    transform: translateY(0);
  }

  /* Header & Input */
  .search-header {
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-dim);
    background: var(--surface-1);
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    position: relative;
  }

  .search-icon {
    color: var(--text-tertiary);
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding: var(--space-2) 0;
    outline: none;
  }

  .close-kbd {
    font-size: 10px;
    padding: 2px 6px;
    background: var(--surface-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text-tertiary);
  }

  /* Filters */
  .search-filters {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .filter-btn {
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 4px 10px;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .filter-btn:hover {
    background: var(--surface-4);
    border-color: var(--border-mid);
    color: var(--text-primary);
  }

  .filter-btn.active {
    background: var(--accent-research-alpha);
    border-color: var(--accent-research);
    color: var(--accent-research);
  }

  /* Results */
  .search-results {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-2);
    min-height: 300px;
  }

  .search-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    text-align: center;
    padding: var(--space-8);
  }

  .search-result-item {
    display: flex;
    flex-direction: column;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
    border-left: 3px solid transparent;
    margin-bottom: 2px;
  }

  .search-result-item:hover,
  .search-result-item.selected {
    background: var(--surface-3);
    outline: none;
  }

  /* Pillar Accents */
  .search-result-item[data-type="research"] { border-left-color: var(--accent-research); }
  .search-result-item[data-type="digest"] { border-left-color: var(--accent-digest); }
  .search-result-item[data-type="products"] { border-left-color: var(--accent-products); }
  .search-result-item[data-type="clauses"] { border-left-color: var(--accent-clauses); }

  .result-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-1);
  }

  .result-pillar {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Scoped colors via data-type */
  .search-result-item[data-type="research"] .result-pillar { color: var(--accent-research); }
  .search-result-item[data-type="digest"] .result-pillar { color: var(--accent-digest); }
  .search-result-item[data-type="products"] .result-pillar { color: var(--accent-products); }
  .search-result-item[data-type="clauses"] .result-pillar { color: var(--accent-clauses); }

  .result-title {
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--text-primary);
    margin: 0;
  }

  .result-summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: var(--space-2);
  }

  /* Footer */
  .search-footer {
    padding: var(--space-3) var(--space-4);
    background: var(--surface-1);
    border-top: 1px solid var(--border-dim);
    display: flex;
    gap: var(--space-6);
  }

  .search-command {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-tertiary);
    font-size: 11px;
    font-weight: 500;
  }

  .search-command kbd {
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: 3px;
    padding: 1px 5px;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .search-modal-container {
      max-height: 100vh;
      height: 100%;
      border-radius: 0;
    }
    .search-footer {
      display: none;
    }
  }
</style>

<script>
  import Fuse from 'fuse.js';

  class SearchController {
    constructor() {
      this.modal = document.getElementById('search-modal');
      this.input = document.getElementById('search-input');
      this.resultsContainer = document.getElementById('search-results');
      this.filterBtns = document.querySelectorAll('.filter-btn');
      
      this.index = [];
      this.fuse = null;
      this.currentFilter = 'all';
      this.selectedIndex = -1;
      this.isOpen = false;

      this.init();
    }

    async init() {
      // Setup triggers
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          this.toggleModal();
        }
        if (e.key === 'Escape' && this.isOpen) {
          this.close();
        }
        if (this.isOpen) {
          this.handleKeyboard(e);
        }
      });

      this.modal.addEventListener('click', (e) => {
        if (e.target === this.modal) this.close();
      });

      this.input.addEventListener('input', () => this.performSearch());

      this.filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          this.filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          this.currentFilter = btn.dataset.filter;
          this.performSearch();
        });
      });

      // Load data
      try {
        const res = await fetch('/search.json');
        const data = await res.json();
        this.index = data.index;
        
        this.fuse = new Fuse(this.index, {
          keys: [
            { name: 'title', weight: 1.0 },
            { name: 'summary', weight: 0.6 },
            { name: 'tags', weight: 0.4 }
          ],
          threshold: 0.3,
          includeMatches: true
        });
      } catch (err) {
        console.error('Failed to load search index:', err);
      }

      // External trigger support (Nav icon)
      window.addEventListener('open-search', () => this.open());
    }

    toggleModal() {
      this.isOpen ? this.close() : this.open();
    }

    open() {
      this.isOpen = true;
      this.modal.setAttribute('aria-hidden', 'false');
      setTimeout(() => this.input.focus(), 50);
      document.body.style.overflow = 'hidden';
    }

    close() {
      this.isOpen = false;
      this.modal.setAttribute('aria-hidden', 'true');
      this.input.value = '';
      this.resultsContainer.innerHTML = '<div class="search-empty"><p>Type to begin searching the intelligence architecture...</p></div>';
      this.selectedIndex = -1;
      document.body.style.overflow = '';
    }

    performSearch() {
      const query = this.input.value.trim();
      if (!query) {
        this.resultsContainer.innerHTML = '<div class="search-empty"><p>Type to begin searching the intelligence architecture...</p></div>';
        return;
      }

      let results = this.fuse.search(query).map(r => r.item);
      
      if (this.currentFilter !== 'all') {
        results = results.filter(r => r.type === this.currentFilter);
      }

      this.renderResults(results);
    }

    renderResults(results) {
      if (results.length === 0) {
        this.resultsContainer.innerHTML = '<div class="search-empty"><p>No results found for your query.</p></div>';
        return;
      }

      this.resultsContainer.innerHTML = results
        .map((res, i) => `
          <a href="${res.url}" class="search-result-item" data-type="${res.type}" data-index="${i}">
            <div class="result-header">
              <span class="result-pillar">${res.type}</span>
            </div>
            <h4 class="result-title">${res.title}</h4>
            <p class="result-summary">${res.excerpt || res.summary}</p>
          </a>
        `)
        .join('');

      this.selectedIndex = -1;
    }

    handleKeyboard(e) {
      const items = this.resultsContainer.querySelectorAll('.search-result-item');
      if (items.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        this.selectedIndex = (this.selectedIndex + 1) % items.length;
        this.updateSelection(items);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        this.selectedIndex = (this.selectedIndex - 1 + items.length) % items.length;
        this.updateSelection(items);
      } else if (e.key === 'Enter' && this.selectedIndex >= 0) {
        e.preventDefault();
        items[this.selectedIndex].click();
      }
    }

    updateSelection(items) {
      items.forEach(item => item.classList.remove('selected'));
      const selected = items[this.selectedIndex];
      if (selected) {
        selected.classList.add('selected');
        selected.scrollIntoView({ block: 'nearest' });
      }
    }
  }

  // Initialize
  new SearchController();
</script>
