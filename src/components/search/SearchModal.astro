---
/**
 * SearchModal.astro
 * Command-palette style search with field context.
 */
---

<div id="search-modal" class="search-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="search-modal-container">
    <header class="search-header">
      <div class="search-input-wrapper">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input
          type="search"
          id="search-input"
          placeholder="Search the corpus by node, term, or problem..."
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the corpus"
        />
        <kbd class="close-kbd">ESC</kbd>
      </div>

      <nav class="search-filters" aria-label="Search filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="research">Research</button>
        <button class="filter-btn" data-filter="digest">Digest</button>
        <button class="filter-btn" data-filter="products">Products</button>
        <button class="filter-btn" data-filter="clauses">Clauses</button>
        <button class="filter-btn" data-filter="field">Field</button>
      </nav>
    </header>

    <div id="search-results" class="search-results" aria-live="polite">
      <div class="search-empty">
        <p>Type to search the corpus and surface nearby nodes.</p>
      </div>
    </div>

    <footer class="search-footer">
      <div class="search-command">
        <kbd>Up/Down</kbd> <span>Navigate</span>
      </div>
      <div class="search-command">
        <kbd>Enter</kbd> <span>Open node</span>
      </div>
      <div class="search-command">
        <kbd>ESC</kbd> <span>Close</span>
      </div>
    </footer>
  </div>
</div>

<style>
  .search-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background: rgba(5, 4, 3, 0.85);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-mid) var(--ease-out);
    padding: var(--space-4);
  }

  .search-modal-overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .search-modal-container {
    width: 100%;
    max-width: 760px;
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    transform: translateY(20px);
    transition: transform var(--duration-mid) var(--ease-out);
    display: flex;
    flex-direction: column;
    max-height: 80vh;
  }

  .search-modal-overlay[aria-hidden="false"] .search-modal-container {
    transform: translateY(0);
  }

  .search-header {
    padding: var(--space-4);
    border-bottom: 1px solid var(--border-dim);
    background: var(--surface-1);
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    position: relative;
  }

  .search-icon {
    color: var(--text-tertiary);
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding: var(--space-2) 0;
    outline: none;
  }

  .close-kbd {
    font-size: 10px;
    padding: 2px 6px;
    background: var(--surface-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text-tertiary);
  }

  .search-filters {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  .filter-btn {
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    color: var(--text-secondary);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 4px 10px;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .filter-btn:hover {
    background: var(--surface-4);
    border-color: var(--border-mid);
    color: var(--text-primary);
  }

  .filter-btn.active {
    background: var(--accent-research-alpha);
    border-color: var(--accent-research);
    color: var(--accent-research);
  }

  .search-results {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-3);
    min-height: 320px;
    display: grid;
    gap: var(--space-3);
  }

  .search-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    text-align: center;
    padding: var(--space-8);
  }

  .search-result {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    cursor: pointer;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
    border: 1px solid var(--border-dim);
    background: var(--surface-1);
  }

  .search-result:hover,
  .search-result.selected {
    background: var(--surface-3);
    border-color: var(--border-mid);
    outline: none;
  }

  .search-result[data-type="research"] { box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.08); }
  .search-result[data-type="digest"] { box-shadow: inset 0 0 0 1px rgba(168, 85, 247, 0.08); }
  .search-result[data-type="products"] { box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.08); }
  .search-result[data-type="clauses"] { box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.08); }
  .search-result[data-type="field"] { box-shadow: inset 0 0 0 1px rgba(168, 85, 247, 0.08); }

  .search-result__type {
    color: var(--ember);
  }

  .search-result__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
  }

  .search-result__neighbors {
    color: var(--text-tertiary);
    font-size: var(--text-xs);
  }

  .search-result__transition {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-2);
  }

  .search-result__path {
    color: var(--ember);
  }

  .search-footer {
    padding: var(--space-3) var(--space-4);
    background: var(--surface-1);
    border-top: 1px solid var(--border-dim);
    display: flex;
    gap: var(--space-6);
  }

  .search-command {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-tertiary);
    font-size: 11px;
    font-weight: 500;
  }

  .search-command kbd {
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: 3px;
    padding: 1px 5px;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .search-modal-container {
      max-height: 100vh;
      height: 100%;
      border-radius: 0;
    }

    .search-footer {
      display: none;
    }
  }
</style>

<script>
  import Fuse from 'fuse.js';

  class SearchController {
    constructor() {
      this.modal = document.getElementById('search-modal');
      this.input = document.getElementById('search-input');
      this.resultsContainer = document.getElementById('search-results');
      this.filterBtns = document.querySelectorAll('.filter-btn');

      this.index = [];
      this.fuse = null;
      this.currentFilter = 'all';
      this.selectedIndex = -1;
      this.isOpen = false;

      this.init();
    }

    escapeHtml(value = '') {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    init() {
      const footerKeys = this.modal.querySelectorAll('.search-command kbd');
      const footerLabels = this.modal.querySelectorAll('.search-command span');
      if (footerKeys.length >= 2 && footerLabels.length >= 2) {
        footerKeys[0].textContent = 'Up/Down';
        footerKeys[1].textContent = 'Enter';
        footerLabels[1].textContent = 'Open node';
      }

      window.addEventListener('keydown', (event) => {
        if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
          event.preventDefault();
          this.toggleModal();
        }
        if (event.key === 'Escape' && this.isOpen) {
          this.close();
        }
        if (this.isOpen) {
          this.handleKeyboard(event);
        }
      });

      this.modal.addEventListener('click', (event) => {
        if (event.target === this.modal) this.close();
      });

      this.input.addEventListener('input', () => this.performSearch());

      this.filterBtns.forEach((button) => {
        button.addEventListener('click', () => {
          this.filterBtns.forEach((item) => item.classList.remove('active'));
          button.classList.add('active');
          this.currentFilter = button.dataset.filter;
          this.performSearch();
        });
      });

      this.loadIndex();
      window.addEventListener('open-search', () => this.open());
    }

    async loadIndex() {
      try {
        const response = await fetch('/search.json');
        const data = await response.json();
        this.index = data.index;

        this.fuse = new Fuse(this.index, {
          keys: [
            { name: 'title', weight: 1.0 },
            { name: 'summary', weight: 0.7 },
            { name: 'tags', weight: 0.45 },
            { name: 'domains', weight: 0.4 },
            { name: 'lineage', weight: 0.25 },
          ],
          threshold: 0.32,
          includeMatches: true,
        });
      } catch (error) {
        console.error('Failed to load search index:', error);
      }
    }

    toggleModal() {
      this.isOpen ? this.close() : this.open();
    }

    open() {
      this.isOpen = true;
      this.modal.setAttribute('aria-hidden', 'false');
      setTimeout(() => this.input.focus(), 50);
      document.body.style.overflow = 'hidden';
    }

    close() {
      this.isOpen = false;
      this.modal.setAttribute('aria-hidden', 'true');
      this.input.value = '';
      this.resultsContainer.innerHTML = '<div class="search-empty"><p>Type to search the corpus and surface nearby nodes.</p></div>';
      this.selectedIndex = -1;
      document.body.style.overflow = '';
    }

    performSearch() {
      const query = this.input.value.trim();
      if (!query || !this.fuse) {
        this.resultsContainer.innerHTML = '<div class="search-empty"><p>Type to search the corpus and surface nearby nodes.</p></div>';
        return;
      }

      let results = this.fuse.search(query).map((result) => result.item);

      if (this.currentFilter !== 'all') {
        results = results.filter((result) => result.type === this.currentFilter);
      }

      this.renderResults(results);
    }

    renderResults(results) {
      if (results.length === 0) {
        this.resultsContainer.innerHTML = '<div class="search-empty"><p>No nodes found for that query.</p></div>';
        return;
      }

      this.resultsContainer.innerHTML = results.map((result, index) => {
        const chips = [...(result.domains || []), ...(result.tags || [])]
          .slice(0, 4)
          .map((item) => `<span class="field-chip field-chip--muted">${this.escapeHtml(item)}</span>`)
          .join('');

        const meta = [
          result.category,
          result.status,
          result.productType,
          result.publishedAt ? new Date(result.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : null,
        ].filter(Boolean).map((item) => `<span class="search-result__meta-item">${this.escapeHtml(String(item))}</span>`).join('');

        return `
          <a href="${result.url}" class="search-result" data-type="${result.type}" data-index="${index}">
            <div class="search-result__header">
              <span class="search-result__type label">${this.escapeHtml(result.typeLabel || result.type)}</span>
              <span class="search-result__neighbors">${this.escapeHtml(result.neighborLabel || 'Entry point')}</span>
            </div>
            <h4 class="search-result__title">${this.escapeHtml(result.title)}</h4>
            <p class="search-result__summary">${this.escapeHtml(result.excerpt || result.summary || '')}</p>
            <div class="search-result__footer">
              <div class="search-result__meta">${meta}</div>
              <div class="search-result__transition">
                ${chips ? `<div class="search-result__chips">${chips}</div>` : ''}
                <span class="search-result__path label">${this.escapeHtml(result.pathHint || 'Open node')}</span>
              </div>
            </div>
          </a>
        `;
      }).join('');

      this.selectedIndex = -1;
    }

    handleKeyboard(event) {
      const items = this.resultsContainer.querySelectorAll('.search-result');
      if (items.length === 0) return;

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        this.selectedIndex = (this.selectedIndex + 1) % items.length;
        this.updateSelection(items);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        this.selectedIndex = (this.selectedIndex - 1 + items.length) % items.length;
        this.updateSelection(items);
      } else if (event.key === 'Enter' && this.selectedIndex >= 0) {
        event.preventDefault();
        items[this.selectedIndex].click();
      }
    }

    updateSelection(items) {
      items.forEach((item) => item.classList.remove('selected'));
      const selected = items[this.selectedIndex];
      if (selected) {
        selected.classList.add('selected');
        selected.scrollIntoView({ block: 'nearest' });
      }
    }
  }

  new SearchController();
</script>
