---
import { NAV_LINKS } from '@data/navigation';
import { SITE } from '@data/site';
import Logo from '@components/ui/Logo.astro';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="nav" id="site-nav">
  <div class="nav__inner container">
    <a href="/" class="nav__logo" aria-label={SITE.name}>
      <Logo size={44} className="nav__logo-img" />
      <span class="nav__logo-text">Oscillatory Fields</span>
    </a>

    <nav class="nav__links" aria-label="Primary navigation">
      {NAV_LINKS.map(({ label, href }) => (
        <a
          href={href}
          class:list={['nav__link', { 'nav__link--active': isActive(href) }]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <button id="search-trigger" class="nav__link nav__link--icon" aria-label="Search" title="Search Corpus (⌘K)">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
    </nav>

    <button class="nav__burger" id="nav-burger" aria-label="Toggle navigation" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <nav class="nav__mobile-links">
      {NAV_LINKS.map(({ label, href }) => (
        <a href={href} class="nav__mobile-link">{label}</a>
      ))}
      <button id="search-trigger-mobile" class="nav__mobile-link nav__mobile-link--icon">Search Corpus</button>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    background: rgba(5, 4, 3, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-mid) var(--ease-out),
      background var(--duration-mid) var(--ease-out);
  }

  .nav.scrolled {
    border-bottom-color: var(--border-dim);
    background: rgba(5, 4, 3, 0.95);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    height: 60px;
  }

  .nav__logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__logo-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.06em;
    color: var(--text-primary);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav__logo:hover .nav__logo-text {
    color: var(--ember);
  }

  .nav__logo-signal {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sage-bright);
    animation: pulse-slow 2.5s ease-in-out infinite;
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-left: auto;
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
    padding: var(--space-1) 0;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--text-primary);
  }

  .nav__link--active {
    border-bottom: 1px solid var(--ember);
  }

  .nav__link--icon {
    margin-left: var(--space-2);
    color: var(--text-tertiary);
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav__link--icon:hover {
    color: var(--ember);
    transform: scale(1.1);
  }

  /* Burger */
  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    margin-left: auto;
  }

  .nav__burger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--text-secondary);
    transition: all var(--duration-fast) var(--ease-out);
  }

  /* Mobile menu */
  .nav__mobile {
    display: none;
    background: var(--surface-1);
    border-top: 1px solid var(--border-dim);
    padding: var(--space-4) 0;
  }

  .nav__mobile.open {
    display: block;
  }

  .nav__mobile-links {
    display: flex;
    flex-direction: column;
    padding: 0 var(--space-6);
  }

  .nav__mobile-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-dim);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav__mobile-link:last-child {
    border-bottom: none;
  }

  .nav__mobile-link:hover {
    color: var(--text-primary);
  }

  .nav__mobile-link--icon {
    color: var(--ember);
    margin-top: var(--space-2);
  }

  @media (max-width: 768px) {
    .nav__links {
      display: none;
    }

    .nav__burger {
      display: flex;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const burger = document.getElementById('nav-burger');
  const mobile = document.getElementById('nav-mobile');

  // Scroll state
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  // Mobile toggle
  burger?.addEventListener('click', () => {
    const isOpen = mobile?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(isOpen));
    mobile?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Search trigger
  const searchTriggers = document.querySelectorAll('#search-trigger, #search-trigger-mobile');
  searchTriggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-search'));
      // Close mobile menu if open
      if (mobile?.classList.contains('open')) {
        mobile.classList.remove('open');
        burger?.setAttribute('aria-expanded', 'false');
        mobile.setAttribute('aria-hidden', 'true');
      }
    });
  });
</script>
