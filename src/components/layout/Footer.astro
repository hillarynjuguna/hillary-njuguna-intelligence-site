---
import { SITE } from '@data/site';
import { FOOTER_LINKS } from '@data/navigation';
import Logo from '@components/ui/Logo.astro';

const year = new Date().getFullYear();

const essentialReading = [
  { label: 'The Bainbridge Warning', href: '/research/bainbridge-warning' },
  { label: 'Project Aurora', href: '/research/aurora' },
  { label: 'DCFB Theory', href: '/research/dcfb' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={SITE.name}>
          <Logo size={64} className="footer__logo-img" variant="accent" />
          <span class="footer__logo-text">Oscillatory Fields</span>
        </a>
        <p class="footer__tagline">
          Intelligence architecture for institutions navigating AI deployment. 
          Ship AI systems with constitutional guarantees.
        </p>
        <div class="footer__cta-group">
          <a href="/contact" class="btn btn--primary footer__cta">Partner with our Research</a>
        </div>
      </div>

      <div class="footer__newsletter">
        <p class="footer__nav-label label">Intelligence Digest</p>
        <p class="footer__newsletter-desc">Research dispatches written during the synthesis process.</p>
        <form action="https://formspree.io/f/maqdrora" method="POST" class="footer__subscribe">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            class="footer__input"
            aria-label="Email address"
          />
          <button type="submit" class="btn btn--ember footer__submit">Subscribe</button>
        </form>
      </div>
    </div>

    <div class="footer__grid">
      <div class="footer__nav-group">
        <p class="footer__nav-label label">Essential Reading</p>
        <nav>
          {essentialReading.map(({ label, href }) => (
            <a href={href} class="footer__link">{label}</a>
          ))}
        </nav>
      </div>

      <div class="footer__nav-group">
        <p class="footer__nav-label label">Research</p>
        <nav>
          {FOOTER_LINKS.research.map(({ label, href }) => (
            <a href={href} class="footer__link">{label}</a>
          ))}
        </nav>
      </div>

      <div class="footer__nav-group">
        <p class="footer__nav-label label">Tools</p>
        <nav>
          {FOOTER_LINKS.tools.map(({ label, href }) => (
            <a href={href} class="footer__link">{label}</a>
          ))}
        </nav>
      </div>

      <div class="footer__nav-group">
        <p class="footer__nav-label label">Products</p>
        <nav>
          {FOOTER_LINKS.products.map(({ label, href }) => (
            <a href={href} class="footer__link">{label}</a>
          ))}
        </nav>
      </div>

      <div class="footer__nav-group">
        <p class="footer__nav-label label">Connect</p>
        <nav>
          {FOOTER_LINKS.external.map(({ label, href }) => (
            <a href={href} class="footer__link" target="_blank" rel="noopener noreferrer me">
              {label} ↗
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy label">
        © {year} {SITE.author.name} · Oscillatory Fields
      </p>
      <div class="footer__meta">
        <a href="/about" class="footer__meta-link label">About</a>
        <a href="/rss.xml" class="footer__meta-link label">RSS</a>
        <a href="/sitemap-index.xml" class="footer__meta-link label">Sitemap</a>
        <a href="/clauses" class="footer__meta-link label">Governance</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-dim);
    background: var(--surface-1);
    padding: var(--space-20) 0 var(--space-8);
    margin-top: var(--space-24);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-16);
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--border-dim);
  }

  .footer__brand {
    max-width: 48ch;
  }

  .footer__logo {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-6);
  }

  .footer__tagline {
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .footer__cta-group {
    display: flex;
    gap: var(--space-4);
  }

  .footer__newsletter-desc {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .footer__subscribe {
    display: flex;
    gap: var(--space-3);
  }

  .footer__input {
    flex: 1;
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-4);
    min-width: 0;
  }

  .footer__submit {
    flex-shrink: 0;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-10);
    margin-bottom: var(--space-16);
  }

  .footer__nav-label {
    margin-bottom: var(--space-6);
    color: var(--ember);
    display: block;
  }

  .footer__nav-group nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
    line-height: 1.4;
  }

  .footer__link:hover {
    color: var(--text-secondary);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-dim);
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__copy {
    color: var(--text-tertiary);
  }

  .footer__meta {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer__meta-link {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer__meta-link:hover {
    color: var(--ember);
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
    .footer__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__subscribe {
      flex-direction: column;
    }
  }
</style>
