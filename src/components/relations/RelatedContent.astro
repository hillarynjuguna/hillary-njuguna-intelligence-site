---
/**
 * Topology-aware related content component.
 * Accepts RelatedItem[] from the graph engine.
 */
import type { RelatedItem } from '@lib/graph/types';
import { getFieldTypeMeta, getNodeHref, truncateFieldText } from '@lib/field';
import RelationExplanation from './RelationExplanation.astro';

interface Props {
  items: RelatedItem[];
  heading?: string;
}

const { items, heading = 'Related' } = Astro.props;
if (!items?.length) return;
---

<aside class="related">
  <h2 class="related__heading label">{heading}</h2>
  <div class="related__list">
    {items.map((item) => (
      <a href={getNodeHref(item.node)} class="related__item">
        <div class="related__item-top">
          <span class="label related__type">
            {getFieldTypeMeta(item.node.contentType).label}
          </span>
          <RelationExplanation item={item} collapsed />
        </div>
        <span class="related__title">{item.node.title}</span>
        {item.node.description && (
          <span class="related__desc">
            {truncateFieldText(item.node.description, 110)}
          </span>
        )}
      </a>
    ))}
  </div>
</aside>

<style>
  .related {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .related__heading {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .related__list {
    display: grid;
    gap: var(--space-4);
  }

  .related__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--duration-mid) var(--ease-out);
    background: var(--surface-1);
  }

  .related__item:hover {
    border-color: var(--border-bright);
    background: var(--surface-2);
    transform: translateY(-2px);
  }

  .related__item-top {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    justify-content: space-between;
  }

  .related__type {
    color: var(--ember);
  }

  .related__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .related__desc {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-normal);
  }
</style>
