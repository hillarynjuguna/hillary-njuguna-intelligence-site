---
interface Props {
  data: any;
}

const { data } = Astro.props;
---

<div class="corpus-container">
  <div id="corpus-graph" data-graph={JSON.stringify(data)}></div>
  <div id="corpus-tooltip" class="tooltip"></div>
  
  <div class="graph-legend">
    <div class="legend-item"><span class="dot research"></span> Research</div>
    <div class="legend-item"><span class="dot digest"></span> Digest</div>
    <div class="legend-item"><span class="dot product"></span> Product</div>
    <div class="legend-item"><span class="dot clause"></span> Clause</div>
  </div>
</div>

<script>
  import * as d3 from 'd3';

  function initGraph() {
    const container = document.getElementById('corpus-graph');
    if (!container) return;

    const rawData = JSON.parse(container.dataset.graph || '{}');
    const tooltip = d3.select('#corpus-tooltip');
    
    // Process data for D3
    const nodes = rawData.nodes.map(n => ({ ...n }));
    const links = rawData.edges.map(e => ({
      source: e.source,
      target: e.target,
      type: e.type,
      value: e.confidence === 'high' ? 3 : e.confidence === 'medium' ? 2 : 1
    })).filter(l => 
      nodes.some(n => n.id === l.source) && 
      nodes.some(n => n.id === l.target)
    );

    const width = container.clientWidth;
    const height = container.clientHeight || 800;

    const svg = d3.select('#corpus-graph')
      .append('svg')
      .attr('width', '100%')
      .attr('height', height)
      .attr('viewBox', [0, 0, width, height])
      .attr('style', 'max-width: 100%; height: auto;');

    // Zoom behavior
    const g = svg.append('g');
    svg.call(d3.zoom().on('zoom', (event) => {
      g.attr('transform', event.transform);
    }));

    const simulation = d3.forceSimulation(nodes)
      .force('link', d3.forceLink(links).id(d => d.id).distance(100))
      .force('charge', d3.forceManyBody().strength(-300))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force('collision', d3.forceCollide().radius(50));

    // Colors by content type (Synced with tokens.css)
    const colorMap = {
      research: '#3b82f6', // Blue
      digest: '#a855f7',   // Purple
      product: '#10b981',  // Green
      clause: '#f59e0b',   // Amber
      'field-notes': '#a855f7' // Map back to digest
    };

    // Draw links
    const link = g.append('g')
      .attr('stroke', '#4B5563')
      .attr('stroke-opacity', 0.4)
      .selectAll('line')
      .data(links)
      .join('line')
      .attr('stroke-width', d => Math.sqrt(d.value) * 1.5);

    // Draw nodes
    const node = g.append('g')
      .selectAll('g')
      .data(nodes)
      .join('g')
      .attr('class', 'node-group')
      .call(d3.drag()
        .on('start', dragstarted)
        .on('drag', dragged)
        .on('end', dragended));

    node.append('circle')
      .attr('r', d => (d.links?.length || 5) + 8)
      .attr('fill', d => colorMap[d.contentType] || '#9CA3AF')
      .attr('stroke', '#1F2937')
      .attr('stroke-width', 2);

    node.append('text')
      .text(d => d.title.split(' ').slice(0, 3).join(' ') + (d.title.split(' ').length > 3 ? '...' : ''))
      .attr('x', 14)
      .attr('y', 4)
      .attr('fill', '#e8d4b0') // var(--text-primary)
      .attr('font-size', '10px')
      .attr('font-weight', '600')
      .attr('font-family', 'Inter, system-ui, sans-serif')
      .attr('pointer-events', 'none')
      .style('text-shadow', '0 1px 4px rgba(0,0,0,0.9)');

    // Interactivity
    node.on('mouseover', (event, d) => {
      tooltip.style('opacity', 1)
        .html(`
          <div class="tooltip-inner" style="border-left: 3px solid ${colorMap[d.contentType] || '#9CA3AF'}">
            <div class="tooltip-type" style="color: ${colorMap[d.contentType] || '#9CA3AF'}">${d.contentType}</div>
            <div class="tooltip-title">${d.title}</div>
            <p class="tooltip-desc">${d.description || ''}</p>
          </div>
        `)
        .style('left', (event.pageX + 15) + 'px')
        .style('top', (event.pageY - 10) + 'px');
      
      d3.select(event.currentTarget).select('circle')
        .transition().duration(200)
        .attr('r', (d.links?.length || 5) + 12)
        .attr('stroke', '#fff');
    })
    .on('mousemove', (event) => {
      tooltip.style('left', (event.pageX + 10) + 'px')
        .style('top', (event.pageY - 10) + 'px');
    })
    .on('mouseout', (event, d) => {
      tooltip.style('opacity', 0);
      d3.select(event.currentTarget).select('circle')
        .transition().duration(200)
        .attr('r', (d.links?.length || 5) + 8)
        .attr('stroke', '#1F2937');
    })
    .on('click', (event, d) => {
      window.location.href = `/${d.sourceCollection}/${d.slug}`;
    });

    simulation.on('tick', () => {
      link
        .attr('x1', d => d.source.x)
        .attr('y1', d => d.source.y)
        .attr('x2', d => d.target.x)
        .attr('y2', d => d.target.y);

      node.attr('transform', d => `translate(${d.x},${d.y})`);
    });

    function dragstarted(event) {
      if (!event.active) simulation.alphaTarget(0.3).restart();
      event.subject.fx = event.subject.x;
      event.subject.fy = event.subject.y;
    }

    function dragged(event) {
      event.subject.fx = event.x;
      event.subject.fy = event.y;
    }

    function dragended(event) {
      if (!event.active) simulation.alphaTarget(0);
      event.subject.fx = null;
      event.subject.fy = null;
    }
  }

  // Initial load
  initGraph();
  
  // Re-init on view transition
  document.addEventListener('astro:page-load', initGraph);
</script>

<style>
  .corpus-container {
    position: relative;
    width: 100%;
    height: 800px;
    background: radial-gradient(circle at center, #111827 0%, #030712 100%);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-dim);
    overflow: hidden;
    cursor: grab;
  }

  .corpus-container:active {
    cursor: grabbing;
  }

  #corpus-graph {
    width: 100%;
    height: 100%;
  }

  .tooltip {
    position: absolute;
    pointer-events: none;
    background: rgba(12, 10, 8, 0.9); /* var(--surface-1) alpha */
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-sm);
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 100;
    backdrop-filter: blur(12px);
    overflow: hidden;
  }

  .tooltip-inner {
    padding: var(--space-4);
  }

  .tooltip-type {
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-2);
  }

  .tooltip-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-3);
  }

  .tooltip-desc {
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin: 0;
  }

  .graph-legend {
    position: absolute;
    bottom: 24px;
    right: 24px;
    background: rgba(17, 24, 39, 0.7);
    backdrop-filter: blur(8px);
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid var(--border-dim);
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 10;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-dim);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot.research { background: #3b82f6; }
  .dot.digest { background: #a855f7; }
  .dot.product { background: #10b981; }
  .dot.clause { background: #f59e0b; }

  .node-group {
    cursor: pointer;
  }
</style>
