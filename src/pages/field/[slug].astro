---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import { buildFieldPrompt } from '@lib/field';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/content';

export async function getStaticPaths() {
  const signals = await getCollection('field-signals', ({ data }) => !data.draft);
  return signals.map((signal) => ({
    params: { slug: signal.slug },
    props: { signal },
  }));
}

const { signal } = Astro.props;
const { Content } = await signal.render();
const prompt = buildFieldPrompt('orient', {
  title: signal.data.title,
  nodeHref: `/field/${signal.slug}`,
});

const provenanceFacts = [
  { label: 'Source', value: 'Notion Insight Log' },
  ...(signal.data.bridgeVersion ? [{ label: 'Bridge', value: `v${signal.data.bridgeVersion}` }] : []),
  ...(signal.data.crystallizedBy ? [{ label: 'Crystallized by', value: signal.data.crystallizedBy }] : []),
  { label: 'Governance relevance', value: signal.data.governanceRelevance },
];
---

<BaseLayout
  title={`Signal #${signal.data.entryNumber}: ${signal.data.title}`}
  description={signal.data.summary}
>
  <main id="main-content" class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow={`Signal #${signal.data.entryNumber}`}
        title={signal.data.title}
        summary={signal.data.summary}
        breadcrumbs={[
          { name: 'Field signals', href: '/field' },
          { name: signal.data.title, href: `/field/${signal.slug}` },
        ]}
        meta={[
          { label: 'Type', value: signal.data.signalType },
          { label: 'Published', value: formatDate(signal.data.publishedAt) },
          { label: 'Crystallization', value: signal.data.crystallization },
        ]}
        chips={signal.data.newTerms.slice(0, 4).map((term: string) => ({ label: term, tone: 'accent' }))}
        width="wide"
        actions={[
          { label: 'Open field index', href: '/field', tone: 'ghost' },
          { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <article class="field-main prose">
          <Content />
        </article>

              </div>
    </div>
  </main>
</BaseLayout>

<style>
  .signal-refs {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-2);
  }

  .signal-refs li {
    padding-left: var(--space-4);
    border-left: 1px solid var(--border-dim);
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
</style>
