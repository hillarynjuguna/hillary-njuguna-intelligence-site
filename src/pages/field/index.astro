---
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldCard from '@components/field/FieldCard.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/content';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, findGraphNode, getNeighborLabel } from '@lib/field';

const allSignals = await getCollection('field-signals', ({ data }) => !data.draft);
const signals = allSignals.sort((a, b) => b.data.entryNumber - a.data.entryNumber);
const graph = await loadContentGraph();

const totalSignals = signals.length;
const domains = [...new Set(signals.flatMap((signal) => signal.data.domains || []))];
const allTerms = [...new Set(signals.flatMap((signal) => signal.data.newTerms || []))];
const signalTypes = signals.reduce((acc, signal) => {
  const type = signal.data.signalType || 'synthesis';
  acc[type] = (acc[type] || 0) + 1;
  return acc;
}, {} as Record<string, number>);
const prompt = buildFieldPrompt('orient', {
  title: 'Field signals',
  nodeHref: '/field',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Field Signals"
  description="The Insight Log rendered as a living semantic field. Observations that arrived through the build process itself."
  eyebrow="Substrate bridge"
  summary="Signals are the moments where the operational build crystallizes into a public node. They remain authored content, but they carry stronger provenance traces from the bridge layer."
  meta={[
    { label: 'Signals', value: String(totalSignals) },
    { label: 'Terms', value: String(allTerms.length) },
    { label: 'Domains', value: String(domains.length) },
  ]}
  chips={Object.entries(signalTypes)
    .sort(([, left], [, right]) => right - left)
    .map(([type, count]) => ({ label: `${type} ${count}` }))}
  actions={[
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
    { label: 'Browse taxonomy', href: '/tags', tone: 'ghost' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Mode', value: 'Orient into bridge-derived nodes' },
    { label: 'Source', value: 'Insight Log crystallization' },
    { label: 'Graph status', value: 'Graph-backed and searchable' },
  ]}
  containerClass="container--wide"
>
  <main id="main-content">
    <div class="card-grid">
      {signals.map((signal) => {
        const node = findGraphNode(graph, {
          id: signal.data.id,
          slug: signal.slug,
          sourceCollection: 'field-signals',
        });
        const neighborCount = countNodeNeighbors(graph, node?.id);

        return (
          <FieldCard
            href={`/field/${signal.slug}`}
            accent="field"
            eyebrow={`Signal #${signal.data.entryNumber}`}
            title={signal.data.title}
            summary={signal.data.summary}
            meta={[
              signal.data.signalType,
              formatDate(signal.data.publishedAt),
            ]}
            chips={[
              ...signal.data.newTerms.slice(0, 2).map((term) => ({ label: term })),
              ...(signal.data.domains || []).slice(0, 2).map((domain: string) => ({ label: domain })),
            ]}
            neighborhoodLabel={getNeighborLabel(neighborCount, 'Field signal')}
            linkLabel="Open signal"
          />
        );
      })}
    </div>
  </main>
</FieldShellLayout>
