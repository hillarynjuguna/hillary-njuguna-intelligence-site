---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/content';

// Get all published field signals (draft: false only)
const allSignals = await getCollection('field-signals', ({ data }) => !data.draft);
const signals = allSignals.sort((a, b) => b.data.entryNumber - a.data.entryNumber);

// Aggregate statistics
const totalSignals = signals.length;
const domains = [...new Set(signals.flatMap(s => s.data.domains || []))];
const allTerms = [...new Set(signals.flatMap(s => s.data.newTerms || []))];
const allLexicon = [...new Set(signals.flatMap(s => s.data.lexiconCandidates || []))];
const signalTypes = signals.reduce((acc, s) => {
  const t = s.data.signalType || 'synthesis';
  acc[t] = (acc[t] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

// Group signals by month
const byMonth = signals.reduce((acc, s) => {
  const d = new Date(s.data.publishedAt);
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
  if (!acc[key]) acc[key] = [];
  acc[key].push(s);
  return acc;
}, {} as Record<string, typeof signals>);
---

<BaseLayout
  title="Field Signals — Emergent Discoveries During Build"
  description="The Insight Log rendered as a living semantic field. Observations that arrived not despite the construction process but through it."
>
  <main id="main-content" class="field-signals">
    <header class="field-header">
      <div class="field-header__badge">Substrate Bridge v2.0</div>
      <h1>Field Signals</h1>
      <p class="field-header__subtitle">
        Emergent discoveries during build. Observations that arrived not despite
        the construction process but <em>through</em> it.
      </p>
      <p class="field-header__origin">
        Each signal began as an Insight Log entry in the Notion workspace —
        the operational brain where the research corpus takes shape. What you see
        here is the crystallized form: the pattern that survived the crossing
        from working memory to public surface.
      </p>
    </header>

    <!-- Semantic Field Overview -->
    <section class="field-overview" aria-label="Field statistics">
      <div class="field-stat">
        <span class="field-stat__value">{totalSignals}</span>
        <span class="field-stat__label">Signals</span>
      </div>
      <div class="field-stat">
        <span class="field-stat__value">{allTerms.length}</span>
        <span class="field-stat__label">Terms Crystallized</span>
      </div>
      <div class="field-stat">
        <span class="field-stat__value">{domains.length}</span>
        <span class="field-stat__label">Active Domains</span>
      </div>
      <div class="field-stat">
        <span class="field-stat__value">{allLexicon.length}</span>
        <span class="field-stat__label">Lexicon Candidates</span>
      </div>
    </section>

    <!-- Signal Type Distribution -->
    <section class="signal-types" aria-label="Signal type distribution">
      {Object.entries(signalTypes).sort(([,a],[,b]) => b - a).map(([type, count]) => (
        <span class="signal-type-badge" data-type={type}>
          {type} <span class="signal-type-count">{count}</span>
        </span>
      ))}
    </section>

    <!-- Domain Tags -->
    <section class="domain-tags" aria-label="Active domains">
      {domains.sort().map(d => (
        <span class="domain-tag">{d}</span>
      ))}
    </section>

    <!-- Signal Timeline -->
    <section class="signal-timeline" aria-label="Field signals timeline">
      {Object.entries(byMonth).sort(([a],[b]) => b.localeCompare(a)).map(([month, monthSignals]) => {
        const [y, m] = month.split('-');
        const monthName = new Date(parseInt(y), parseInt(m) - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
        return (
          <div class="month-group">
            <h2 class="month-label">{monthName}</h2>
            <div class="signal-grid">
              {monthSignals.map(signal => (
                <article class="signal-card" data-type={signal.data.signalType}>
                  <div class="signal-card__meta">
                    <span class="signal-card__number">#{signal.data.entryNumber}</span>
                    <span class="signal-card__type">{signal.data.signalType}</span>
                    {signal.data.entryDate && (
                      <time class="signal-card__date">{signal.data.entryDate}</time>
                    )}
                  </div>
                  <h3 class="signal-card__title">
                    <a href={`/field/${signal.slug}`}>{signal.data.title}</a>
                  </h3>
                  <p class="signal-card__summary">{signal.data.summary}</p>
                  {signal.data.newTerms && signal.data.newTerms.length > 0 && (
                    <div class="signal-card__terms">
                      {signal.data.newTerms.slice(0, 3).map(term => (
                        <span class="term-badge">{term}</span>
                      ))}
                    </div>
                  )}
                  {signal.data.domains && (
                    <div class="signal-card__domains">
                      {(signal.data.domains as string[]).slice(0, 3).map((d: string) => (
                        <span class="domain-micro">{d}</span>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        );
      })}
    </section>

    <!-- Terms Crystallized -->
    {allTerms.length > 0 && (
      <section class="terms-index" aria-label="Terms crystallized across all signals">
        <h2>Terms Crystallized</h2>
        <p class="terms-index__note">
          These terms emerged from the Insight Log's recursive self-observation.
          Each was named because the build process made it visible.
        </p>
        <div class="terms-grid">
          {allTerms.sort().map(term => (
            <span class="term-entry">{term}</span>
          ))}
        </div>
      </section>
    )}

    <!-- Provenance -->
    <footer class="field-footer">
      <p>
        These signals are crystallized from the
        <strong>Insight Log</strong> — a living document in the Notion workspace
        where observations surface through the act of building. The Substrate
        Bridge v2.0 performs preliminary crystallization; the human sovereign
        (τ-node) validates each signal before it appears here.
      </p>
      <p class="field-footer__constitutional">
        Constitutional constraint: No signal publishes without τ-node validation.
        The λ-node proposes. The τ-node decides.
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  .field-signals {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .field-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.1));
  }

  .field-header__badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent, #64ffda);
    border: 1px solid var(--color-accent, #64ffda);
    padding: 0.25rem 0.75rem;
    border-radius: 2px;
    margin-bottom: 1rem;
    font-family: var(--font-mono, monospace);
  }

  .field-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .field-header__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary, rgba(255,255,255,0.7));
    max-width: 48rem;
    line-height: 1.6;
  }

  .field-header__origin {
    font-size: 0.9rem;
    color: var(--color-text-tertiary, rgba(255,255,255,0.5));
    max-width: 48rem;
    line-height: 1.6;
    margin-top: 1rem;
    font-style: italic;
  }

  .field-overview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .field-stat {
    padding: 1.25rem;
    background: var(--color-surface, rgba(255,255,255,0.03));
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    border-radius: 4px;
    text-align: center;
  }

  .field-stat__value {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent, #64ffda);
    font-family: var(--font-mono, monospace);
  }

  .field-stat__label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary, rgba(255,255,255,0.6));
    margin-top: 0.25rem;
  }

  .signal-types, .domain-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .signal-type-badge {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    font-family: var(--font-mono, monospace);
    background: rgba(100, 255, 218, 0.08);
    color: var(--color-accent, #64ffda);
    border: 1px solid rgba(100, 255, 218, 0.15);
  }

  .signal-type-count {
    opacity: 0.6;
    margin-left: 0.25rem;
  }

  .domain-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    background: rgba(255,255,255,0.05);
    color: var(--color-text-secondary, rgba(255,255,255,0.6));
    border: 1px solid rgba(255,255,255,0.08);
  }

  .month-group {
    margin-bottom: 2.5rem;
  }

  .month-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary, rgba(255,255,255,0.5));
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.06));
  }

  .signal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .signal-card {
    padding: 1.25rem;
    background: var(--color-surface, rgba(255,255,255,0.02));
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    border-radius: 4px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .signal-card:hover {
    border-color: var(--color-accent, #64ffda);
    transform: translateY(-1px);
  }

  .signal-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.75rem;
    font-family: var(--font-mono, monospace);
    color: var(--color-text-tertiary, rgba(255,255,255,0.4));
  }

  .signal-card__number {
    color: var(--color-accent, #64ffda);
    font-weight: 600;
  }

  .signal-card__type {
    padding: 0.1rem 0.4rem;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
  }

  .signal-card__title {
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
    line-height: 1.35;
  }

  .signal-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .signal-card__title a:hover {
    color: var(--color-accent, #64ffda);
  }

  .signal-card__summary {
    font-size: 0.85rem;
    color: var(--color-text-secondary, rgba(255,255,255,0.6));
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .signal-card__terms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  .term-badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.4rem;
    background: rgba(255, 200, 50, 0.1);
    color: #ffc832;
    border: 1px solid rgba(255, 200, 50, 0.2);
    border-radius: 2px;
    font-family: var(--font-mono, monospace);
  }

  .signal-card__domains {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.5rem;
  }

  .domain-micro {
    font-size: 0.6rem;
    padding: 0.1rem 0.3rem;
    background: rgba(255,255,255,0.04);
    border-radius: 2px;
    color: var(--color-text-tertiary, rgba(255,255,255,0.4));
  }

  .terms-index {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.08));
  }

  .terms-index h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .terms-index__note {
    font-size: 0.85rem;
    color: var(--color-text-secondary, rgba(255,255,255,0.6));
    margin-bottom: 1.25rem;
  }

  .terms-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .term-entry {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: rgba(255, 200, 50, 0.06);
    border: 1px solid rgba(255, 200, 50, 0.12);
    border-radius: 2px;
    font-family: var(--font-mono, monospace);
    color: rgba(255, 200, 50, 0.8);
  }

  .field-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.08));
    font-size: 0.85rem;
    color: var(--color-text-secondary, rgba(255,255,255,0.5));
    line-height: 1.6;
  }

  .field-footer__constitutional {
    font-style: italic;
    margin-top: 1rem;
    color: var(--color-text-tertiary, rgba(255,255,255,0.35));
  }
</style>
