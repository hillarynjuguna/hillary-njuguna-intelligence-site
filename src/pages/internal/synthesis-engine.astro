---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('ops', {
  title: 'Corpus Synthesis Engine',
  nodeHref: '/internal/synthesis-engine',
});
---

<BaseLayout
  title="Corpus Synthesis Engine"
  description="Internal tool for multi-corpus synthesis."
  seo={{ noindex: true }}
>
  <div class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Internal tool"
        title="Corpus Synthesis Engine"
        summary="This surface is operational rather than public, but it should still stay legible as a support layer around the corpus rather than a detached product."
        meta={[
          { label: 'Mode', value: 'Synthesize' },
          { label: 'Audience', value: 'Internal' },
        ]}
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Research archive', href: '/research', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <div class="synthesis-form field-surface">
            <form id="synthesis-form">
              <div class="form-group">
                <label for="brief" class="label form-label">Synthesis brief</label>
                <textarea
                  id="brief"
                  name="brief"
                  class="form-input form-textarea"
                  placeholder="Enter multi-corpus connections or questions here..."
                  required></textarea>
              </div>

              <div class="form-footer">
                <button type="submit" class="btn btn--primary form-submit" id="submit-btn">
                  Synthesize
                </button>
              </div>
            </form>
          </div>

          <div class="output-container field-surface" id="output-container" style="display: none;">
            <div class="output-header">
              <h2 class="output-title">Synthesis result</h2>
              <div class="status-indicator"></div>
            </div>
            <div id="loading-indicator" class="loading-indicator" style="display: none;">
              Processing with λ-node...
            </div>
            <div id="error-message" class="error-message" style="display: none;"></div>
            <div id="result-content" class="result-content markdown-body"></div>
          </div>
        </div>

              </div>
    </div>
  </div>
</BaseLayout>

<style>
  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-label {
    color: var(--text-tertiary);
  }

  .form-input {
    background: var(--surface-3);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: border-color var(--duration-fast) var(--ease-out);
    width: 100%;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--ember-dim);
  }

  .form-textarea {
    resize: vertical;
    min-height: 250px;
    line-height: var(--leading-relaxed);
  }

  .ops-note {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    font-size: var(--text-sm);
  }

  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-dim);
  }

  .output-title {
    font-size: var(--text-xl);
    color: var(--text-primary);
  }

  .loading-indicator {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    animation: pulse 2s infinite;
  }

  .error-message {
    color: var(--ember);
    padding: var(--space-4);
    background: var(--surface-2);
    border-left: 4px solid var(--ember);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
  }

  .result-content {
    color: var(--text-primary);
    line-height: var(--leading-loose);
    white-space: pre-wrap;
  }

  @keyframes pulse {
    0% { opacity: 0.6; }
    50% { opacity: 1; }
    100% { opacity: 0.6; }
  }
</style>

<script>
  import { marked } from 'marked';

  const form = document.getElementById('synthesis-form');
  const submitBtn = document.getElementById('submit-btn');
  const outputContainer = document.getElementById('output-container');
  const loadingIndicator = document.getElementById('loading-indicator');
  const errorMessage = document.getElementById('error-message');
  const resultContent = document.getElementById('result-content');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const brief = formData.get('brief');

    if (!brief.trim()) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Synthesizing...';

    outputContainer.style.display = 'block';
    loadingIndicator.style.display = 'block';
    errorMessage.style.display = 'none';
    resultContent.innerHTML = '';

    try {
      const response = await fetch('/api/synthesize', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ brief }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || 'Failed to synthesize');
      }

      try {
        resultContent.innerHTML = marked.parse(data.result);
      } catch (error) {
        resultContent.textContent = data.result;
      }
    } catch (error) {
      errorMessage.textContent = error.message || 'An error occurred during synthesis.';
      errorMessage.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Synthesize';
      loadingIndicator.style.display = 'none';
    }
  });
</script>
