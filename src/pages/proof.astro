---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MCRC Proof — Oscillatory Fields</title>
  <meta name="description" content="Cryptographic proof of the MCRC v1.0.0-alpha constitutional runtime. Live Ed25519 attestations, revocation telemetry, and sequencing gate reports." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0b0d10;
      --surface: #111418;
      --surface-2: #181c22;
      --border: #242830;
      --ember: #c4673a;
      --ember-dim: rgba(196,103,58,0.12);
      --green: #4caf7d;
      --green-dim: rgba(76,175,125,0.1);
      --text-primary: #e8e6e1;
      --text-secondary: #8a8880;
      --text-dim: #50504e;
      --mono: 'JetBrains Mono', monospace;
      --sans: 'Inter', system-ui, sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg); color: var(--text-primary); font-family: var(--sans); line-height: 1.6; }

    /* Nav */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      background: rgba(11,13,16,0.9);
      backdrop-filter: blur(12px);
      z-index: 100;
    }
    nav .wordmark { font-family: var(--mono); font-size: 0.8rem; color: var(--ember); letter-spacing: 0.05em; text-decoration: none; }
    nav a.back { font-size: 0.8rem; color: var(--text-secondary); text-decoration: none; }
    nav a.back:hover { color: var(--text-primary); }

    /* Hero */
    .hero {
      max-width: 800px;
      margin: 5rem auto 4rem;
      padding: 0 2rem;
      text-align: center;
    }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--ember);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }
    .hero-eyebrow::before,
    .hero-eyebrow::after {
      content: '';
      width: 40px;
      height: 1px;
      background: var(--ember);
      opacity: 0.4;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 600;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }
    .hero h1 em { font-style: normal; color: var(--ember); }
    .hero p {
      font-size: 1.05rem;
      color: var(--text-secondary);
      max-width: 560px;
      margin: 0 auto 2.5rem;
    }
    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* Buttons */
    .btn-primary {
      background: var(--ember);
      color: #fff;
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      font-weight: 600;
      font-size: 0.9rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
    .btn-ghost {
      background: transparent;
      color: var(--text-secondary);
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      font-size: 0.9rem;
      border: 1px solid var(--border);
      transition: border-color 0.2s, color 0.2s;
    }
    .btn-ghost:hover { border-color: var(--text-secondary); color: var(--text-primary); }

    /* Stats bar */
    .stats-bar {
      max-width: 900px;
      margin: 0 auto 4rem;
      padding: 0 2rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .stat {
      background: var(--surface);
      padding: 1.5rem;
      text-align: center;
    }
    .stat-val {
      font-family: var(--mono);
      font-size: 1.75rem;
      font-weight: 600;
      color: var(--ember);
      display: block;
      margin-bottom: 0.25rem;
    }
    .stat-val.green { color: var(--green); }
    .stat-label { font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; }

    /* Proof embed */
    .proof-embed-wrap {
      max-width: 1000px;
      margin: 0 auto 5rem;
      padding: 0 2rem;
    }
    .proof-embed-wrap h2 {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .proof-embed-wrap h2::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    iframe {
      width: 100%;
      height: 720px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #0d0f12;
    }

    /* Kit section */
    .kit-section {
      max-width: 900px;
      margin: 0 auto 5rem;
      padding: 0 2rem;
      scroll-margin-top: 5rem;
    }
    .kit-section h2 {
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }
    .kit-section > p { color: var(--text-secondary); margin-bottom: 2rem; }

    .kit-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .kit-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem;
    }
    .kit-card-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .kit-card h3 { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.4rem; }
    .kit-card p { font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5; }
    .kit-card code { font-family: var(--mono); font-size: 0.75rem; color: var(--ember); background: var(--ember-dim); padding: 0.1rem 0.4rem; border-radius: 3px; }

    .install-block {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }
    .install-header {
      background: var(--surface-2);
      padding: 0.6rem 1rem;
      font-family: var(--mono);
      font-size: 0.7rem;
      color: var(--text-dim);
      border-bottom: 1px solid var(--border);
    }
    .install-body {
      padding: 1rem 1.25rem;
      font-family: var(--mono);
      font-size: 0.82rem;
      line-height: 2;
      color: var(--text-primary);
    }
    .install-body .cmd-prompt { color: var(--ember); user-select: none; margin-right: 0.5rem; }
    .install-body .cmd-comment { color: var(--text-dim); }

    /* Footer */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem;
      text-align: center;
    }
    footer p { font-family: var(--mono); font-size: 0.7rem; color: var(--text-dim); }
    footer a { color: var(--ember); text-decoration: none; }
  </style>
</head>
<body>
  <nav>
    <a class="wordmark" href="/">Oscillatory Fields</a>
    <a class="back" href="/research">← Research</a>
  </nav>

  <section class="hero">
    <div class="hero-eyebrow">MCRC v1.0.0-alpha · Live Attestations</div>
    <h1>Constitutional <em>Proof,</em><br>Not Policy</h1>
    <p>
      Every governance claim this site makes is backed by cryptographic evidence.
      Below are the real Ed25519 signatures, real revocation latencies, and real sequencing gate reports from the MCRC simulation harness.
    </p>
    <div class="hero-actions">
      <a href="/demo/mcrc-proof/" class="btn-primary" target="_blank">
        Open Live Viewer ↗
      </a>
      <a href="#kit" class="btn-ghost">Download Verification Kit</a>
    </div>
  </section>

  <div class="stats-bar">
    <div class="stat">
      <span class="stat-val green">&lt;1.2ms</span>
      <span class="stat-label">Revocation Latency</span>
    </div>
    <div class="stat">
      <span class="stat-val">4/4</span>
      <span class="stat-label">Gates Passed</span>
    </div>
    <div class="stat">
      <span class="stat-val">3</span>
      <span class="stat-label">Signed CPEs</span>
    </div>
    <div class="stat">
      <span class="stat-val green">Ed25519</span>
      <span class="stat-label">Signature Scheme</span>
    </div>
    <div class="stat">
      <span class="stat-val">200ms</span>
      <span class="stat-label">SLA Threshold</span>
    </div>
  </div>

  <div class="proof-embed-wrap">
    <h2>Live Constitutional Provenance Viewer</h2>
    <iframe
      src="/demo/mcrc-proof/"
      title="MCRC Constitutional Provenance Viewer"
      loading="lazy"
    ></iframe>
  </div>

  <section class="kit-section" id="kit">
    <h2>Download the Verification Kit</h2>
    <p>
      Run the simulation yourself. Every signature is reproducible.
      The kit contains the harness, verifier, sequencing gates, and the public key.
    </p>

    <div class="kit-grid">
      <div class="kit-card">
        <div class="kit-card-icon">⚙️</div>
        <h3>constitutional_stress_test.py</h3>
        <p>The λ/μ concurrent harness. Injects <code>fracture</code> and <code>bifurcation</code> perturbations. Emits signed CPEs.</p>
      </div>
      <div class="kit-card">
        <div class="kit-card-icon">🔐</div>
        <h3>verify_zahavian_signal.py</h3>
        <p>Independent verifier. Loads <code>mu_public_key.pem</code>, checks Ed25519 signatures, monotonic nonces, and dynamic thresholds.</p>
      </div>
      <div class="kit-card">
        <div class="kit-card-icon">🚦</div>
        <h3>sequencing_gates.py</h3>
        <p>Four cryptographic preconditions gating commercial deployment. No soft passes. No manual overrides.</p>
      </div>
      <div class="kit-card">
        <div class="kit-card-icon">📋</div>
        <h3>zahavian_attestations.jsonl</h3>
        <p>Append-only signed CPE chain. Three trial records. Each tamper attempt breaks the Ed25519 signature.</p>
      </div>
    </div>

    <div class="install-block">
      <div class="install-header">bash — reproduce in 60 seconds</div>
      <div class="install-body">
        <div><span class="cmd-prompt">$</span>pip install cryptography</div>
        <div><span class="cmd-prompt">$</span>python simulations/constitutional_stress_test.py <span class="cmd-comment"># generates attestations</span></div>
        <div><span class="cmd-prompt">$</span>python simulations/verify_zahavian_signal.py      <span class="cmd-comment"># verifies Ed25519 sigs</span></div>
        <div><span class="cmd-prompt">$</span>python simulations/sequencing_gates.py             <span class="cmd-comment"># runs 4 deployment gates</span></div>
      </div>
    </div>

    <div style="display:flex; gap:1rem; flex-wrap:wrap;">
      <a href="https://github.com/hillarynjuguna/hillary-njuguna-intelligence-site/tree/main/simulations" class="btn-primary" target="_blank" rel="noopener">
        View on GitHub ↗
      </a>
      <a href="/demo/mcrc-proof/zahavian_attestations.jsonl" class="btn-ghost" download>
        Download Attestations (.jsonl)
      </a>
      <a href="/demo/mcrc-proof/gate_compliance_report.json" class="btn-ghost" download>
        Download Gate Report (.json)
      </a>
    </div>
  </section>

  <footer>
    <p>
      Oscillatory Fields · <a href="/research">Research</a> · <a href="/products">Products</a> · <a href="/privacy">Privacy</a>
      <br>Governance is structure, not policy.
    </p>
  </footer>
</body>
</html>
