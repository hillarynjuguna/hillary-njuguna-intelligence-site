---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import { loadTaxonomyIndex } from '@lib/generated/loaders';

const taxonomy = await loadTaxonomyIndex();

const categories = [
  { id: 'domains', label: 'Domains', description: 'Core operational spheres and research fields.' },
  { id: 'themes', label: 'Themes', description: 'Cross-cutting conceptual frameworks.' },
  { id: 'tags', label: 'Topics', description: 'Specific technical and theoretical anchors.' },
];

const title = "Taxonomy Hub";
const description = "Explore the intellectual architecture of Oscillatory Fields through domains, themes, and technical topics.";
---

<BaseLayout title={title} description={description} breadcrumbs={[{ name: 'Taxonomy', href: '/tags' }]}>
  <div class="taxonomy-hub">
    <header class="hub-header" data-reveal>
      <p class="label">Mapping the Corpus</p>
      <h1 class="hub-title">Taxonomy Hub</h1>
      <p class="hub-subtitle">
        The Oscillatory Fields research corpus is indexed across three primary axes of significance.
      </p>
    </header>

    <div class="hub-grid">
      {categories.map((cat) => (
        <section class="hub-section" data-reveal>
          <div class="hub-section__header">
            <h2 class="hub-section__title">{cat.label}</h2>
            <p class="hub-section__desc">{cat.description}</p>
          </div>

          <div class="tag-cloud">
            {Object.entries(taxonomy[cat.id as keyof typeof taxonomy]).sort((a,b) => b[1].count - a[1].count).map(([key, group]) => {
              const slug = key.toLowerCase().replace(/\s+/g, '-');
              return (
                <a href={`/tags/${slug}`} class="tag-link hover-lift">
                  <span class="tag-link__label">{group.label}</span>
                  <span class="tag-link__count">{group.count}</span>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .taxonomy-hub {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }

  .hub-header {
    margin-bottom: var(--space-20);
    max-width: 800px;
  }

  .hub-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    margin: var(--space-4) 0;
    letter-spacing: -0.03em;
    color: var(--text-bright);
  }

  .hub-subtitle {
    font-size: var(--text-xl);
    color: var(--text-dim);
    line-height: 1.5;
  }

  .hub-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-24);
  }

  .hub-section__header {
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border-dim);
    padding-bottom: var(--space-6);
  }

  .hub-section__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: var(--space-2);
  }

  .hub-section__desc {
    font-size: var(--text-base);
    color: var(--text-dim);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .tag-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.3s var(--ease-out);
  }

  .tag-link:hover {
    border-color: var(--accent-main);
    background: rgba(var(--accent-rgb), 0.05);
  }

  .tag-link__label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-main);
  }

  .tag-link__count {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent-main);
    background: rgba(var(--accent-rgb), 0.1);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    min-width: 24px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .hub-grid {
      gap: var(--space-16);
    }
  }
</style>
