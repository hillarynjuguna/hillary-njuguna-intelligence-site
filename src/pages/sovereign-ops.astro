    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Knowledge Spine</p>
        <h2 class="section__title">The 7-Vein Cartographic Survey</h2>
        <span class="ops-aligned label">✓ Aligned with Notion HQ</span>
      </div>

      <div class="veins-grid">
        {veins.map(vein => (
          <button class={`vein-card vein-card--${vein.status} open-local-btn`} data-path={vein.folder} aria-label={`Open ${vein.name} in Explorer`}>
