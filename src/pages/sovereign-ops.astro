---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import FieldRail from '@components/field/FieldRail.astro';
import { buildFieldPrompt } from '@lib/field';

const veins = [
  {
    id: 'V1',
    name: 'The Bainbridge Warning Manuscript',
    description: 'Constitutional primitives, ratification doctrine, and the core governance architecture.',
    status: 'seeded',
    count: '22 docs',
    notion: 'Vein 1',
    folder: '1_The_Bainbridge_Warning_Manuscript',
  },
  {
    id: 'V2',
    name: 'RSPS / RRI Starter Repository',
    description: 'HOT SDC engine, ContextPacket schema, ThreadIntelligence, and ANTIGRAVITY conversation layers.',
    status: 'active',
    count: 'HOT SDC live',
    notion: 'Vein 2',
    folder: '2_The_RSPS_RRI_Starter_Repository',
  },
  {
    id: 'V3',
    name: 'Cross-Model Conversation Archives',
    description: 'Claude, DeepSeek, Grok, and GPT dialogue exports plus synthesis artifacts and phone intelligence harvests.',
    status: 'active',
    count: 'Exports + ADB',
    notion: 'Vein 3',
    folder: '3_The_Archival_And_Synthesis_Layer',
  },
  {
    id: 'V4',
    name: 'Academic Papers',
    description: 'Peer-reviewed sources, whitepapers, and epistemic foundation documents.',
    status: 'seeded',
    count: 'Research corpus',
    notion: 'Vein 4',
    folder: '4_The_Curated_Academic_Corpus',
  },
  {
    id: 'V5',
    name: 'Phenomenological Corpus',
    description: 'Phone intelligence harvests, NotebookLM sessions, and personal synthesis documents.',
    status: 'active',
    count: '149 artifacts',
    notion: 'Vein 5',
    folder: '5_The_Phenomenological_Corpus',
  },
  {
    id: 'V6',
    name: 'Astrocartography Cognitive Operating System',
    description: 'Agent SEA, witness-android, CE-Ledger, this site, and business strategy surfaces.',
    status: 'live',
    count: '5+ repos',
    notion: 'Vein 6',
    folder: '6_The_Astrocartography_Cognitive_Operating_System',
  },
  {
    id: 'V7',
    name: 'Theological / AOD + GHC Corpus',
    description: 'AOD framework, Ghost-Headcount theory, and the theological substrate of the sovereign field.',
    status: 'seeded',
    count: 'Initialized',
    notion: 'Vein 7',
    folder: '7_Theological_AOD_And_GHC_Corpus',
  },
];

const activeProjects = [
  { name: 'HOT SDC Engine v4.2', path: '2_The_RSPS_RRI_Starter_Repository/HOT_SDC_Engine', status: 'live', link: '/orchestra-operation' },
  { name: 'Hillary Intelligence Site', path: 'Projects/hillary-njuguna-intelligence-site', status: 'live', link: '/' },
  { name: 'Agent SEA Platform', path: 'Projects/agent-sea-platform', status: 'live', link: 'https://github.com/kebabken8-lang/agent-sea-platform' },
  { name: 'witness-android', path: '6_The_Astrocartography_Cognitive_Operating_System/witness-android', status: 'dev', link: null },
  { name: 'CE-Ledger', path: 'Projects/CE-Ledger', status: 'dev', link: null },
  { name: 'funnel-landing (Tapau)', path: 'Projects/funnel-landing', status: 'dev', link: null },
];

const notionLinks = [
  { label: 'Witness Infrastructure HQ', url: 'https://notion.so/323eb86f-d1b0-8111-b421-d1120619e988' },
  { label: 'Content Calendar', url: 'https://www.notion.so' },
  { label: 'Corpus Map, 7-Vein Survey', url: 'https://www.notion.so' },
];

const engineMetrics = [
  { label: 'Ache Vector Dimensions', value: '5', sub: 'E / A / D / T / Φ' },
  { label: 'Context Packet Schema', value: 'v2.0', sub: 'Pydantic v2 validated' },
  { label: 'Vein Count', value: '7', sub: 'Aligned with Notion HQ' },
  { label: 'Phone Artifacts Harvested', value: '149', sub: 'From ADB pull' },
];

const prompt = buildFieldPrompt('ops', {
  title: 'Sovereign Ops',
  nodeHref: '/sovereign-ops',
  primaryCorpusHref: '/corpus',
});
---

<BaseLayout
  title="Sovereign Ops"
  description="Operational command surface for the local sovereign node and bridge systems."
  seo={{ noindex: true }}
>
  <main class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Operational field"
        title="Sovereign Ops"
        summary="This is the local command surface around the corpus. It can inspect, launch, and bridge systems, but it remains support infrastructure around the public field rather than a separate product."
        meta={[
          { label: 'Mode', value: 'Operate' },
          { label: 'Boundary', value: 'Local-first' },
          { label: 'Node', value: 'τ-node' },
        ]}
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Synthesis engine', href: '/internal/synthesis-engine', tone: 'secondary' },
          { label: 'Research archive', href: '/research', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <section class="ops-section field-surface">
            <div class="ops-section__head">
              <p class="label ops-section__label">Local metrics</p>
              <h2 class="ops-section__title">Current operating boundary</h2>
            </div>
            <div class="ops-metrics">
              {engineMetrics.map((metric) => (
                <article class="ops-metric-card">
                  <span class="ops-metric-card__value">{metric.value}</span>
                  <span class="ops-metric-card__label label">{metric.label}</span>
                  <span class="ops-metric-card__sub">{metric.sub}</span>
                </article>
              ))}
            </div>
          </section>

          <section class="ops-section field-surface">
            <div class="ops-section__head">
              <p class="label ops-section__label">Knowledge spine</p>
              <h2 class="ops-section__title">Seven veins, one local field</h2>
              <p class="ops-section__copy">Each vein is a local corpus stratum. Opening a vein uses the machine boundary directly, so these actions should stay legible as local operations rather than public navigation.</p>
            </div>

            <div class="ops-grid">
              {veins.map((vein) => (
                <button class:list={['ops-card', `ops-card--${vein.status}`, 'open-local-btn']} data-path={vein.folder} data-local-control="true" type="button" aria-label={`Open ${vein.name} locally`}>
                  <div class="ops-card__top">
                    <span class="ops-card__id label">{vein.id}</span>
                    <span class:list={['ops-status', `ops-status--${vein.status}`]}>{vein.status}</span>
                  </div>
                  <h3 class="ops-card__title">{vein.name}</h3>
                  <p class="ops-card__copy">{vein.description}</p>
                  <div class="ops-card__meta">
                    <span>{vein.count}</span>
                    <span>{vein.notion}</span>
                  </div>
                  <span class="ops-card__action label">Open local folder</span>
                </button>
              ))}
            </div>
          </section>

          <section class="ops-section ops-section--split">
            <article class="field-surface">
              <div class="ops-section__head">
                <p class="label ops-section__label">Live projects</p>
                <h2 class="ops-section__title">Active deployments and repositories</h2>
              </div>

              <div class="ops-list">
                {activeProjects.map((project) => (
                  <div class="ops-list__row">
                    <div>
                      <p class="ops-list__title">{project.name}</p>
                      <code class="ops-list__path">{project.path}</code>
                    </div>
                    {project.link ? (
                      <a href={project.link} class="ops-list__link" target={project.link.startsWith('http') ? '_blank' : undefined} rel={project.link.startsWith('http') ? 'noopener noreferrer' : undefined}>
                        {project.link.startsWith('http') ? 'GitHub' : 'Open'}
                      </a>
                    ) : (
                      <span class="ops-list__muted">Local only</span>
                    )}
                  </div>
                ))}
              </div>
            </article>

            <article class="field-surface">
              <div class="ops-section__head">
                <p class="label ops-section__label">Bridge boundary</p>
                <h2 class="ops-section__title">Notion and launch controls</h2>
              </div>

              <div class="ops-list">
                {notionLinks.map((item) => (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="ops-list__row ops-list__row--link">
                    <span class="ops-list__title">{item.label}</span>
                    <span class="ops-list__link">Open</span>
                  </a>
                ))}
              </div>

              <div class="ops-engine">
                <p class="label ops-engine__label">HOT SDC Engine</p>
                <p class="ops-engine__copy">This launcher is local-only. It should fail closed on deployments that do not own the machine boundary.</p>
                <code class="ops-engine__command">python main_hot_cli.py</code>
                <button id="launch-engine-btn" class="btn btn--primary" data-local-control="true" type="button">Launch local engine</button>
              </div>
            </article>
          </section>

          <section class="ops-section field-surface">
            <div class="ops-section__head">
              <p class="label ops-section__label">Topology</p>
              <h2 class="ops-section__title">Public field versus local inference space</h2>
            </div>

            <div class="ops-topology">
              <div class="ops-topology__layer">
                <p class="label ops-topology__label">Public boundary</p>
                <div class="ops-topology__nodes">
                  <div class="ops-topology__node">Notion HQ</div>
                  <div class="ops-topology__node">Intelligence Site</div>
                  <div class="ops-topology__node">Agent SEA</div>
                </div>
              </div>

              <div class="ops-topology__bridge">
                <span></span>
                <p class="label">Sync boundary</p>
                <span></span>
              </div>

              <div class="ops-topology__layer ops-topology__layer--local">
                <p class="label ops-topology__label">Local inference space</p>
                <div class="ops-topology__nodes">
                  <div class="ops-topology__node ops-topology__node--local">HOT SDC Engine</div>
                  <div class="ops-topology__node ops-topology__node--local">7-Vein Knowledge Spine</div>
                  <div class="ops-topology__node ops-topology__node--local">ADB Phone Harvest</div>
                </div>
              </div>
            </div>
          </section>
        </div>

        <FieldRail
          heading="Operational field"
          facts={[
            { label: 'Knowledge spine', value: 'G:\\My Drive\\RSPS Knowledge Spine' },
            { label: 'Boundary', value: 'Outbound sync only' },
            { label: 'Deployment rule', value: 'Local actions fail closed' },
          ]}
          prompt={prompt}
        >
          <div class="field-panel">
            <p class="field-panel__eyebrow label">Ops note</p>
            <p class="ops-rail-copy">Public pages can describe the local system, but local launch and folder controls remain subordinate to the corpus and should never impersonate portable web behavior.</p>
          </div>
        </FieldRail>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const isLocalHost = ['localhost', '127.0.0.1'].includes(window.location.hostname);
    const localControls = document.querySelectorAll('[data-local-control="true"]');

    if (!isLocalHost) {
      localControls.forEach((control) => {
        if (control instanceof HTMLButtonElement) {
          control.disabled = true;
        }
        control.setAttribute('title', 'Local machine required');
      });
    }

    const buttons = document.querySelectorAll('.open-local-btn');

    buttons.forEach((button) => {
      button.addEventListener('click', async () => {
        if (!isLocalHost) return;
        const path = button.getAttribute('data-path');
        if (!path) return;

        button.classList.add('ops-card--pending');

        try {
          const response = await fetch(`/api/open-local?path=${encodeURIComponent(path)}`);
          if (!response.ok) {
            console.error('Failed to open local path:', await response.text());
          }
        } catch (error) {
          console.error('Local path error:', error);
        }

        setTimeout(() => button.classList.remove('ops-card--pending'), 300);
      });
    });

    const launchButton = document.getElementById('launch-engine-btn');
    if (!launchButton) return;

    launchButton.addEventListener('click', async () => {
      if (!isLocalHost) return;
      const originalText = launchButton.textContent;
      launchButton.textContent = 'Launching...';
      launchButton.setAttribute('disabled', 'true');

      try {
        const response = await fetch('/api/launch-engine', { method: 'POST' });
        launchButton.textContent = response.ok ? 'Engine launched' : 'Launch failed';
      } catch (error) {
        console.error('Engine launch error:', error);
        launchButton.textContent = 'Connection error';
      }

      setTimeout(() => {
        launchButton.textContent = originalText;
        launchButton.removeAttribute('disabled');
      }, 2500);
    });
  });
</script>

<style>
  .ops-section {
    display: grid;
    gap: var(--space-8);
  }

  .ops-section--split {
    display: grid;
    gap: var(--space-5);
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .ops-section__head {
    display: grid;
    gap: var(--space-3);
    max-width: 72ch;
  }

  .ops-section__label,
  .ops-engine__label,
  .ops-topology__label {
    color: var(--ember);
  }

  .ops-section__title {
    font-size: var(--text-2xl);
  }

  .ops-section__copy,
  .ops-engine__copy,
  .ops-rail-copy {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .ops-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-4);
  }

  .ops-metric-card {
    display: grid;
    gap: var(--space-1);
    padding: var(--space-5);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
  }

  .ops-metric-card__value {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--ember);
    line-height: 1;
  }

  .ops-metric-card__sub {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
  }

  .ops-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }

  .ops-card {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
    text-align: left;
    color: inherit;
    font: inherit;
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }

  .ops-card:hover {
    border-color: var(--border-mid);
    background: var(--surface-3);
    transform: translateY(-1px);
  }

  .ops-card--pending {
    border-color: var(--ember);
    background: rgba(196, 112, 58, 0.08);
  }

  .ops-card__top,
  .ops-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    color: var(--text-tertiary);
    font-size: var(--text-xs);
  }

  .ops-card__title,
  .ops-list__title {
    font-size: var(--text-base);
    color: var(--text-primary);
  }

  .ops-card__copy {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    font-size: var(--text-sm);
  }

  .ops-card__action {
    color: var(--ember);
  }

  .ops-status {
    padding: 2px 8px;
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.08em;
  }

  .ops-status--live {
    border-color: rgba(100, 220, 150, 0.4);
    color: #64dc96;
  }

  .ops-status--active {
    border-color: rgba(196, 112, 58, 0.4);
    color: var(--ember);
  }

  .ops-list {
    display: grid;
    gap: var(--space-3);
  }

  .ops-list__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
  }

  .ops-list__row--link {
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }

  .ops-list__row--link:hover {
    border-color: var(--border-mid);
    background: var(--surface-3);
  }

  .ops-list__path {
    color: var(--text-tertiary);
    font-size: 11px;
  }

  .ops-list__link {
    color: var(--ember);
    text-decoration: none;
    white-space: nowrap;
  }

  .ops-list__muted {
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .ops-engine {
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-3);
    padding: var(--space-5);
    border: 1px solid rgba(196, 112, 58, 0.3);
    border-radius: var(--radius-md);
    background: rgba(196, 112, 58, 0.05);
  }

  .ops-engine__command {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    background: var(--surface-1);
    color: var(--ember);
  }

  .ops-topology {
    display: grid;
    gap: var(--space-4);
  }

  .ops-topology__layer {
    display: grid;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
  }

  .ops-topology__layer--local {
    background: rgba(196, 112, 58, 0.05);
  }

  .ops-topology__bridge {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .ops-topology__bridge span {
    flex: 1;
    height: 1px;
    background: var(--border-mid);
  }

  .ops-topology__nodes {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .ops-topology__node {
    padding: var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-sm);
    background: var(--surface-3);
    color: var(--text-primary);
  }

  .ops-topology__node--local {
    border-color: rgba(196, 112, 58, 0.35);
  }

  @media (max-width: 900px) {
    .ops-section--split {
      grid-template-columns: 1fr;
    }
  }
</style>
