---

<BaseLayout title="Sovereign Ops — Hillary Njuguna" description="The unified command surface for the Sovereign Cognitive Node. Monitor the 7-Vein Knowledge Spine, active engines, and Notion deployment boundary.">

  <section class="ops-hero">
    <div class="container">
      <div class="ops-hero__inner">
        <div class="ops-status-badge">
          <span class="ops-pulse"></span>
          <span class="label">Sovereign Node — Operational</span>
        </div>
        <h1 class="ops-headline">Sovereign Ops<br /><span class="ops-headline--sub">Command Surface</span></h1>
        <p class="ops-desc">
          The unified cognitive dashboard. The local Knowledge Spine, the HOT SDC Engine,
          and the Notion public boundary — wired into one view.
        </p>
        <div class="ops-timestamp label">
          Last restructured: 2026-03-25 | Local node: <code>G:\My Drive\RSPS Knowledge Spine</code>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="metrics-row">
        {engineMetrics.map(m => (
          <div class="metric-card">
            <span class="metric-card__val">{m.val}</span>
            <span class="metric-card__label label">{m.label}</span>
            <span class="metric-card__sub label">{m.sub}</span>
