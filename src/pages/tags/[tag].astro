---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldCard from '@components/field/FieldCard.astro';
import { loadTaxonomyIndex, loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, getNeighborLabel, getNodeHref, getTagHref } from '@lib/field';
import { formatDateShort } from '@lib/content';

export async function getStaticPaths() {
  const taxonomy = await loadTaxonomyIndex();

  const allTags = new Set([
    ...Object.keys(taxonomy.domains),
    ...Object.keys(taxonomy.themes),
    ...Object.keys(taxonomy.tags),
  ]);

  return Array.from(allTags).map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, '-') },
    props: { originalTag: tag },
  }));
}

const { tag } = Astro.params;
const { originalTag } = Astro.props;
const taxonomy = await loadTaxonomyIndex();
const graph = await loadContentGraph();

const group = taxonomy.domains[originalTag] || taxonomy.themes[originalTag] || taxonomy.tags[originalTag];

if (!group) {
  return Astro.redirect('/404');
}

const relatedNodes = graph.nodes
  .filter((node) => group.contentIds.includes(node.id))
  .sort((left, right) => {
    const leftDate = left.publishedAt ? new Date(left.publishedAt).getTime() : 0;
    const rightDate = right.publishedAt ? new Date(right.publishedAt).getTime() : 0;
    return rightDate - leftDate;
  });
const prompt = buildFieldPrompt('trace', {
  title: group.label,
  nodeHref: `/tags/${tag}`,
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title={`${group.label} | Hillary Njuguna`}
  description={`All content related to ${group.label} in the Hillary Njuguna research corpus.`}
  eyebrow="Filtered corpus"
  summary={`${group.count} ${group.count === 1 ? 'node' : 'nodes'} share this term across the corpus. Use this view to widen from one label into the local network around it.`}
  breadcrumbs={[
    { name: 'Taxonomy', href: '/tags' },
    { name: group.label, href: `/tags/${tag}` },
  ]}
  meta={[{ label: 'Nodes', value: String(group.count) }]}
  actions={[
    { label: 'Open taxonomy', href: '/tags', tone: 'ghost' },
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Mode', value: 'Trace from one term into nearby nodes' },
    { label: 'Category', value: taxonomy.domains[originalTag] ? 'Domain' : taxonomy.themes[originalTag] ? 'Theme' : 'Topic' },
    { label: 'Node count', value: String(group.count) },
  ]}
  containerClass="container--wide"
>
  <div class="card-grid">
    {relatedNodes.map((node) => (
      <FieldCard
        href={getNodeHref(node)}
        accent={node.contentType === 'product' ? 'products' : node.contentType === 'clause' ? 'clauses' : node.contentType === 'digest' ? 'digest' : 'research'}
        eyebrow={node.contentType}
        title={node.title}
        summary={node.description}
        meta={[
          ...(node.publishedAt ? [formatDateShort(new Date(node.publishedAt))] : []),
          node.crystallization,
        ]}
        chips={[...new Set([...node.domains, ...node.tags])].slice(0, 4).map((term) => ({ label: term, href: getTagHref(term) }))}
        neighborhoodLabel={getNeighborLabel(countNodeNeighbors(graph, node.id))}
        linkLabel="Open node"
      />
    ))}
  </div>
</FieldShellLayout>
