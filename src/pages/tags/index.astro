---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldCard from '@components/field/FieldCard.astro';
import { loadTaxonomyIndex } from '@lib/generated/loaders';
import { buildFieldPrompt, slugifyFieldTerm } from '@lib/field';

const taxonomy = await loadTaxonomyIndex();

const categories = [
  { id: 'domains', label: 'Domains', description: 'Core operational spheres and research fields.' },
  { id: 'themes', label: 'Themes', description: 'Cross-cutting conceptual frameworks.' },
  { id: 'tags', label: 'Topics', description: 'Specific technical and theoretical anchors.' },
] as const;
const prompt = buildFieldPrompt('orient', {
  title: 'Taxonomy hub',
  nodeHref: '/tags',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Taxonomy Hub"
  description="Explore the intellectual architecture of Hillary Njuguna through domains, themes, and technical topics."
  eyebrow="Mapping the corpus"
  summary="Taxonomy is not a separate destination from the corpus. It is one of the ways the field exposes structure, density, and adjacency."
  actions={[
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
    { label: 'Query Intelligence', href: '/orchestra-operation', tone: 'ghost' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Domains', value: String(Object.keys(taxonomy.domains).length) },
    { label: 'Themes', value: String(Object.keys(taxonomy.themes).length) },
    { label: 'Topics', value: String(Object.keys(taxonomy.tags).length) },
  ]}
  containerClass="container--wide"
>
  <div class="field-stack">
    {categories.map((category) => (
      <section class="taxonomy-group">
        <div class="taxonomy-section-header">
          <p class="label">{category.label}</p>
          <h2>{category.label}</h2>
          <p class="taxonomy-section-copy">{category.description}</p>
        </div>
        <div class="card-grid">
          {Object.entries(taxonomy[category.id])
            .sort((left, right) => right[1].count - left[1].count)
            .map(([key, group]) => (
              <FieldCard
                href={`/tags/${slugifyFieldTerm(key)}`}
                accent="research"
                eyebrow={category.label}
                title={group.label}
                summary={`${group.count} connected ${group.count === 1 ? 'node' : 'nodes'} in this part of the field.`}
                meta={[`${group.count} nodes`]}
                linkLabel="Explore tag"
              />
            ))}
        </div>
      </section>
    ))}
  </div>
</FieldShellLayout>

<style>
  .taxonomy-section-header {
    margin-bottom: var(--space-6);
    display: grid;
    gap: var(--space-2);
  }

  .taxonomy-section-copy {
    color: var(--text-secondary);
    max-width: 60ch;
  }
</style>
