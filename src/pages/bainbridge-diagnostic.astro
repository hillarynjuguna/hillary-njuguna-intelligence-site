---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import BainbridgeDiagnostic from '@components/tools/BainbridgeDiagnostic';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('query', {
  title: 'Bainbridge Diagnostic',
  nodeHref: '/bainbridge-diagnostic',
});
---

<BaseLayout
  title="Bainbridge Diagnostic Tool"
  description="Run a live structural diagnostic of your organization's AI capability-governance gap."
>
  <div class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Instrument node"
        title="Bainbridge Diagnostic"
        summary="This is a live intake-to-output diagnostic surface. The point is not just to produce a score, but to expose the structure of the capability-governance gap while keeping the corpus behind it visible."
        meta={[
          { label: 'Mode', value: 'Query' },
          { label: 'Frames', value: '4-stage diagnostic' },
          { label: 'Output', value: 'Risk gap report' },
        ]}
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Read Bainbridge', href: '/research/bainbridge-warning', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <BainbridgeDiagnostic client:visible />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
