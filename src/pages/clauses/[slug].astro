---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import FieldRail from '@components/field/FieldRail.astro';
import { getRelatedContent } from '@lib/related/getRelatedContent';
import { formatDate } from '@lib/content';
import { buildFieldPrompt } from '@lib/field';

export async function getStaticPaths() {
  const entries = await getCollection('clauses', ({ data }) => data.visibility === 'public');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;

const contentId = data.id ?? `clause-${entry.slug}`;
const allRelated = await getRelatedContent(contentId, 6);

const governanceItems = allRelated.filter(
  (item) => item.node.contentType !== 'clause' && (
    item.edge.type === 'governance_relevant_to' ||
    item.edge.type === 'derives_from' ||
    item.edge.type === 'crystallizes'
  ),
);
const otherRelated = allRelated.filter((item) => !governanceItems.includes(item)).slice(0, 3);

const statusLabels: Record<string, string> = {
  candidate: 'Candidate',
  provisional: 'Provisional',
  active: 'Active',
  retired: 'Retired',
  crystallized: 'Crystallized',
};

const clauseStatus = data.clauseStatus ?? 'candidate';
const publishedDate = data.publishedAt ?? data.generatedAt;
const prompt = buildFieldPrompt('trace', {
  title: data.title,
  nodeHref: `/clauses/${entry.slug}`,
});
---

<BaseLayout
  title={`${data.title} | Governance Clause`}
  description={data.sourceContext ?? data.clauseText?.slice(0, 160) ?? data.description ?? data.title}
>
  <article class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Governance clause"
        title={data.title}
        summary={data.sourceContext ?? 'A governance node crystallized from the research corpus.'}
        breadcrumbs={[
          { name: 'Clauses', href: '/clauses' },
          { name: data.title, href: `/clauses/${entry.slug}` },
        ]}
        meta={[
          { label: 'Status', value: statusLabels[clauseStatus] ?? clauseStatus },
          ...(data.governanceDomain ? [{ label: 'Domain', value: data.governanceDomain }] : []),
          ...(publishedDate ? [{ label: 'Generated', value: formatDate(publishedDate) }] : []),
        ]}
        chips={data.tags.map((tag) => ({ label: `#${tag}` }))}
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Ask the field', href: '/orchestra-operation', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <div class="clause-shell">
            <div class="clause-text-section">
              <blockquote class="clause-text">
                {data.clauseText}
              </blockquote>
            </div>

            {data.applicability && (
              <div class="clause-section">
                <h2 class="clause-section__title">Applicability</h2>
                <p class="clause-section__body">{data.applicability}</p>
              </div>
            )}

            {data.objections && data.objections.length > 0 && (
              <div class="clause-section">
                <h2 class="clause-section__title">Known objections</h2>
                <ul class="clause-objections">
                  {data.objections.map((objection) => (
                    <li class="clause-objection">{objection}</li>
                  ))}
                </ul>
              </div>
            )}

            {data.crystallizationThreshold !== undefined && (
              <div class="clause-section">
                <h2 class="clause-section__title">Crystallization threshold</h2>
                <div class="clause-threshold">
                  <div class="clause-threshold__bar">
                    <div
                      class="clause-threshold__fill"
                      style={`width: ${Math.round(data.crystallizationThreshold * 100)}%`}
                    />
                  </div>
                  <span class="label clause-threshold__value">
                    {Math.round(data.crystallizationThreshold * 100)}% supporting content must reach crystallized state
                  </span>
                </div>
              </div>
            )}

          </div>
        </div>

        <FieldRail
          heading="Clause field"
          lineage={data.lineage}
          domains={data.governanceDomain ? [data.governanceDomain] : []}
          tags={data.tags}
          related={otherRelated}
          governance={governanceItems}
          prompt={prompt}
          facts={data.reviewCadence ? [{ label: 'Review cadence', value: data.reviewCadence }] : []}
        />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .clause-shell {
    display: grid;
    gap: var(--space-10);
  }

  .clause-text {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--pale-gold);
    border-left: 3px solid var(--ember);
    padding: var(--space-6) var(--space-8);
    background: var(--surface-2);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    margin: 0;
  }

  .clause-section {
    display: grid;
    gap: var(--space-3);
  }

  .clause-section__title {
    font-size: var(--text-xl);
  }

  .clause-section__body {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .clause-objections {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  .clause-objection {
    padding: var(--space-3) var(--space-5);
    border-left: 2px solid var(--border-mid);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    background: var(--surface-2);
  }

  .clause-threshold {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 360px;
  }

  .clause-threshold__bar {
    height: 4px;
    background: var(--surface-3);
    border-radius: 2px;
    overflow: hidden;
  }

  .clause-threshold__fill {
    height: 100%;
    background: var(--ember);
    border-radius: 2px;
  }

  .clause-threshold__value {
    color: var(--text-tertiary);
  }
</style>
