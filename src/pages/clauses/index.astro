---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllClauses, formatDate } from '@lib/content';

const clauses = await getAllClauses();
---

<BaseLayout
  title="Governance Clauses"
  description="The living constitutional governance layer of the Oscillatory Fields research corpus. Clause candidates generated through active synthesis — accumulating, public, traceable."
>
  <div class="page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Constitutional Layer</p>
        <h1 class="page-title">Clause Archive</h1>
        <p class="page-desc">
          Every synthesis run has the potential to generate a clause candidate —
          a fragment of the evolving constitutional framework that governs how
          the Oscillatory Fields research corpus and AI systems operate.
          These candidates are public, traceable, and accumulating.
        </p>
        <div class="clause-note">
          <p class="label clause-note__text">
            This is not a legal document. It is a living governance architecture —
            explicit where most AI systems are implicit.
          </p>
        </div>
      </header>

      {clauses.length === 0 ? (
        <div class="clauses-empty">
          <p class="label">Clause archive is being populated through active synthesis.</p>
          <p>
            As the research corpus grows and synthesis sessions generate governance-relevant
            insights, they will appear here. <a href="/corpus">Query the corpus</a> to
            generate new synthesis — and new candidates.
          </p>
        </div>
      ) : (
        <div class="clauses-list">
          {clauses.map((clause) => (
            <article class="clause-card" data-reveal>
              <div class="clause-card__header">
                <div class="clause-card__meta">
                  <span class={`badge ${clause.data.status === 'adopted' ? 'badge--live' : clause.data.status === 'candidate' ? 'badge--dev' : 'badge--soon'}`}>
                    {clause.data.status}
                  </span>
                  <time class="label" datetime={clause.data.generatedAt.toISOString()}>
                    Generated {formatDate(clause.data.generatedAt)}
                  </time>
                </div>
                <h2 class="clause-card__title">{clause.data.title}</h2>
              </div>

              <blockquote class="clause-card__text">
                {clause.data.clauseText}
              </blockquote>

              {clause.data.sourceContext && (
                <div class="clause-card__source">
                  <span class="label">Source context:</span>
                  <p>{clause.data.sourceContext}</p>
                </div>
              )}

              {clause.data.tags.length > 0 && (
                <div class="clause-card__tags">
                  {clause.data.tags.map((tag) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      )}

      <section class="clauses-cta" data-reveal>
        <div class="clauses-cta__inner">
          <h2 class="clauses-cta__title">Generate new synthesis</h2>
          <p class="clauses-cta__desc">
            Every query to the corpus is a potential synthesis event.
            Some produce clause candidates. All deepen the research field.
          </p>
          <a href="/corpus" class="btn btn--primary">Open the corpus →</a>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: var(--space-24) 0 var(--space-32);
  }

  .page-header {
    max-width: 64ch;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .page-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .page-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-5);
  }

  @media (max-width: 768px) {
    .page-title { font-size: var(--text-4xl); }
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .clause-note {
    padding: var(--space-4) var(--space-5);
    background: var(--surface-2);
    border: 1px solid var(--border-dim);
    border-left: 2px solid var(--ember);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .clause-note__text {
    color: var(--text-tertiary);
    font-style: italic;
  }

  .clauses-empty {
    padding: var(--space-16) 0;
    max-width: 56ch;
  }

  .clauses-empty .label {
    color: var(--ember);
    margin-bottom: var(--space-5);
  }

  .clauses-empty p {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .clauses-empty a {
    color: var(--ember);
  }

  .clauses-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  .clause-card {
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-md);
    padding: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .clause-card__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .clause-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .clause-card__meta .label {
    color: var(--text-tertiary);
  }

  .clause-card__title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .clause-card__text {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--pale-gold);
    border-left: 2px solid var(--ember);
    padding: var(--space-4) var(--space-6);
    background: var(--surface-1);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    margin: 0;
  }

  .clause-card__source {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .clause-card__source .label {
    color: var(--ember);
  }

  .clause-card__source p {
    color: var(--text-tertiary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .clause-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* CTA */
  .clauses-cta {
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    padding: var(--space-12);
  }

  .clauses-cta__title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-4);
  }

  .clauses-cta__desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
    max-width: 52ch;
  }
</style>
