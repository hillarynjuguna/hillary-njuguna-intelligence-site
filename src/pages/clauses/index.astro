---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldCard from '@components/field/FieldCard.astro';
import { getAllClauses, formatDate } from '@lib/content';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, findGraphNode, getNeighborLabel } from '@lib/field';

const clauses = await getAllClauses();
const graph = await loadContentGraph();
const prompt = buildFieldPrompt('trace', {
  title: 'Constitutional clauses',
  nodeHref: '/clauses',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Governance Clauses"
  description="The living constitutional governance layer of the Hillary Njuguna research corpus."
  eyebrow="Governance"
  summary="Clauses are the governance layer that crystallizes from the research corpus. They should behave like field nodes with provenance and support, not detached policy copy."
  actions={[
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
    { label: 'Research archive', href: '/research', tone: 'ghost' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Clauses', value: String(clauses.length) },
    { label: 'Mode', value: 'Trace governance crystallization' },
    { label: 'Identity', value: 'Governance layer derived from research' },
  ]}
  containerClass="container--wide"
>
  {clauses.length === 0 ? (
    <div class="clauses-empty">
      <p class="label" style="color: var(--accent-clauses)">Clause archive is being populated through active synthesis.</p>
      <p>
        As the research corpus grows and synthesis sessions generate governance-relevant insight, they will appear here.
      </p>
    </div>
  ) : (
    <div class="card-grid">
      {clauses.map((clause) => {
        const node = findGraphNode(graph, {
          id: clause.data.id,
          slug: clause.slug,
          sourceCollection: 'clauses',
        });
        const neighborCount = countNodeNeighbors(graph, node?.id);

        return (
          <FieldCard
            href={`/clauses/${clause.slug}`}
            accent="clauses"
            eyebrow={clause.data.governanceDomain ?? 'Clause'}
            title={clause.data.title}
            summary={clause.data.sourceContext ?? clause.data.clauseText ?? ''}
            meta={[
              clause.data.clauseStatus,
              formatDate(clause.data.generatedAt),
            ]}
            chips={clause.data.tags.slice(0, 3).map((tag) => ({ label: `#${tag}` }))}
            neighborhoodLabel={getNeighborLabel(neighborCount, 'Emergent clause')}
            linkLabel="Open clause"
          />
        );
      })}
    </div>
  )}
</FieldShellLayout>

<style>
  .clauses-empty {
    padding: var(--space-16) 0;
    max-width: 56ch;
  }

  .clauses-empty p {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
