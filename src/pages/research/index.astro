---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllResearchEntries, formatDate } from '@lib/content';

const entries = await getAllResearchEntries();
---

<BaseLayout
  title="Research"
  description="The Oscillatory Fields research corpus — DCFB theory, constitutional AI governance, cognitive infrastructure readiness, and the architecture of distributed intelligence."
>
  <div class="page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Archive</p>
        <h1 class="page-title">Research</h1>
        <p class="page-desc">
          Frameworks, essays, and theoretical architecture from 18 months of active research
          across distributed cognition, constitutional AI governance, and the design of
          intelligent institutional systems.
        </p>
      </header>

      {entries.length === 0 ? (
        <p class="empty label">Research entries loading…</p>
      ) : (
        <div class="research-list">
          {entries.map((entry) => (
            <a href={`/research/${entry.slug}`} class="research-entry hover-lift" data-reveal>
              <div class="research-entry__meta">
                <time class="label" datetime={entry.data.publishedAt.toISOString()}>
                  {formatDate(entry.data.publishedAt)}
                </time>
                {entry.data.featured && (
                  <span class="badge badge--live">Featured</span>
                )}
              </div>
              <div class="research-entry__body">
                <h2 class="research-entry__title">{entry.data.title}</h2>
                <p class="research-entry__summary">{entry.data.summary}</p>
                <div class="research-entry__tags">
                  {entry.data.themes.slice(0, 3).map((t) => (
                    <span class="tag">{t}</span>
                  ))}
                </div>
              </div>
              <span class="research-entry__arrow">→</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: var(--space-24) 0 var(--space-32);
  }

  .page-header {
    max-width: 64ch;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .page-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .page-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-5);
  }

  @media (max-width: 768px) {
    .page-title { font-size: var(--text-4xl); }
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .research-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .research-entry {
    display: grid;
    grid-template-columns: 180px 1fr auto;
    gap: var(--space-8);
    align-items: start;
    padding: var(--space-7) 0;
    border-bottom: 1px solid var(--border-dim);
    text-decoration: none;
    transition: all var(--duration-mid) var(--ease-out);
  }

  @media (max-width: 768px) {
    .research-entry {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .research-entry__arrow {
      display: none;
    }
  }

  .research-entry:hover {
    background: var(--surface-2);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    border-radius: var(--radius-md);
  }

  .research-entry__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 3px;
  }

  .research-entry__meta .label {
    color: var(--text-tertiary);
  }

  .research-entry__title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
  }

  .research-entry:hover .research-entry__title {
    color: var(--pale-gold);
  }

  .research-entry__summary {
    font-size: var(--text-base);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-3);
  }

  .research-entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .research-entry__arrow {
    color: var(--text-tertiary);
    font-size: var(--text-lg);
    padding-top: 3px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .research-entry:hover .research-entry__arrow {
    color: var(--ember);
  }

  .empty {
    color: var(--text-tertiary);
    padding: var(--space-12) 0;
  }
</style>
