---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldListItem from '@components/field/FieldListItem.astro';
import { getAllResearchEntries, formatDate } from '@lib/content';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, findGraphNode, getNeighborLabel } from '@lib/field';

const entries = await getAllResearchEntries();
const graph = await loadContentGraph();
const prompt = buildFieldPrompt('orient', {
  title: 'Research archive',
  nodeHref: '/research',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Research"
  description="The Oscillatory Fields research corpus, DCFB theory, constitutional AI governance, cognitive infrastructure readiness, and the architecture of distributed intelligence."
  eyebrow="Archive"
  summary="Frameworks, essays, and theoretical architecture from active work across distributed cognition, constitutional AI governance, and institutional intelligence."
  actions={[
    { label: 'Intelligence digest', href: '/digest', tone: 'ghost' },
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Entries', value: String(entries.length) },
    { label: 'Mode', value: 'Orient into doctrine' },
    { label: 'Surface', value: 'Archive plus graph-backed neighborhood counts' },
  ]}
>
  {entries.length === 0 ? (
    <p class="empty label">Research entries loading...</p>
  ) : (
    <div class="field-stack">
      {entries.map((entry) => {
        const node = findGraphNode(graph, {
          id: entry.data.id,
          slug: entry.slug,
          sourceCollection: 'research',
        });
        const neighborCount = countNodeNeighbors(graph, node?.id);

        return (
          <FieldListItem
            href={`/research/${entry.slug}`}
            accent="research"
            eyebrow={entry.data.researchType ?? 'Research node'}
            title={entry.data.title}
            summary={entry.data.summary}
            aside={[
              formatDate(entry.data.publishedAt),
              entry.data.crystallization,
            ]}
            chips={entry.data.themes.slice(0, 3).map((theme) => ({ label: theme }))}
            footer={getNeighborLabel(neighborCount, 'Standalone node')}
            badge={entry.data.featured ? 'Featured' : undefined}
          />
        );
      })}
    </div>
  )}
</FieldShellLayout>

<style>
  .empty {
    color: var(--text-tertiary);
    padding: var(--space-12) 0;
  }
</style>
