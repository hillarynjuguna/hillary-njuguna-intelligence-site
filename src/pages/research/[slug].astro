---
export const prerender = true;
import { getCollection } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';
import { getRelatedContent } from '@lib/related/getRelatedContent';
import { buildArticleSchema } from '@lib/seo';
import { SITE } from '@data/site';
import { buildFieldPrompt } from '@lib/field';

// Custom MDX Components
import PullQuote from '@components/mdx/PullQuote.astro';
import MetaInterrupt from '@components/mdx/MetaInterrupt.astro';
import ContinuationCard from '@components/mdx/ContinuationCard.astro';
import SeriesNav from '@components/mdx/SeriesNav.astro';
import ImageBlock from '@components/mdx/ImageBlock.astro';
import DropCap from '@components/mdx/DropCap.astro';
import AlternativeRegister from '@components/mdx/AlternativeRegister.astro';
import HeroVisual from '@components/mdx/HeroVisual.astro';
import SourceAttribution from '@components/mdx/SourceAttribution.astro';
import ThreatFlow from '@components/mdx/ThreatFlow.astro';
import ValidationStack from '@components/mdx/ValidationStack.astro';
import TrustChain from '@components/mdx/TrustChain.astro';
import BoundaryCutaway from '@components/mdx/BoundaryCutaway.astro';
import ComparisonPlate from '@components/mdx/ComparisonPlate.astro';
import { Trap, Advice, Hook, Divider } from '@components/mdx';

export async function getStaticPaths() {
  const entries = await getCollection('research', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const contentId = data.id ?? `research-${entry.slug}`;
const allRelated = await getRelatedContent(contentId, 6);

// Separate governance-relevant items from general related
const govItems = allRelated.filter(
  (r) =>
    r.edge.type === 'governance_relevant_to' ||
    (r.node.contentType === 'clause' && r.node.governanceRelevance !== 'none')
);
const relatedItems = allRelated.filter((r) => !govItems.includes(r)).slice(0, 4);
const prompt = buildFieldPrompt('read', {
  title: data.title,
  nodeHref: `/research/${entry.slug}`,
});

const articleSchema = buildArticleSchema({
  title: data.seoTitle ?? data.title,
  description: data.seoDescription ?? data.summary,
  url: `${SITE.url}/research/${entry.slug}`,
  publishedAt: data.publishedAt,
  updatedAt: data.updatedAt,
  ogImage: data.ogImage,
  type: 'ScholarlyArticle',
  keyClaims: data.keyClaims,
});
---

<ContentLayout
  title={data.seoTitle ?? data.title}
  description={data.seoDescription ?? data.summary}
  summary={data.summary}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  tags={data.tags}
  domains={data.domains}
  author={data.author}
  category="Research"
  breadcrumbs={[
    { name: 'Research', href: '/research' },
    { name: data.title, href: `/research/${entry.slug}` },
  ]}
  related={relatedItems}
  governance={govItems}
  lineage={data.lineage}
  prompt={prompt}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Content components={{ PullQuote, MetaInterrupt, ContinuationCard, SeriesNav, ImageBlock, DropCap, AlternativeRegister, HeroVisual, SourceAttribution, ThreatFlow, ValidationStack, TrustChain, BoundaryCutaway, ComparisonPlate, Trap, Advice, Hook, Divider }} />
</ContentLayout>
