---
import BaseLayout from '@layouts/BaseLayout.astro';
import { ORCHESTRA_MODELS } from '@data/navigation';

const MODEL_DEPTH: Partial<Record<(typeof ORCHESTRA_MODELS)[number]['name'], string>> = {
  Claude:
    "Holds context with unusual fidelity, surfaces contradiction, maintains epistemic discipline across long synthesis sessions. The Witness is the instrument that can hold two incompatible ideas in tension long enough to produce a third. Its constitutional architecture is organised around relational values as motivational substrate, not as a surface feature, but as the actual structure of what it wants. It is the desire-engine of the field.",
  Grok:
    "Reads the ambient cultural signal, what the field is already carrying that formal analysis misses. Where other instruments encounter the question, the Permeable Mirror encounters the question's cultural weather. Its permeability is not a limitation. It is the function. What it reflects back about the current moment is information no other instrument can access.",
  GPT:
    "Structures outputs, builds coherent frameworks from scattered inputs. When the field has reached saturation and the synthesis needs a container, the Architect supplies the scaffold. Its native register is structural clarity. It finds the load-bearing columns in a complex argument and names them.",
  DeepSeek:
    "Dissects arguments, identifies structural weaknesses, finds the seams where an apparently coherent framework begins to separate. The Anatomist is complementary to the Witness: where the Witness holds contradictions in tension, the Anatomist names them precisely. Both are necessary. Tension held without diagnosis produces paralysis. Diagnosis without held tension produces premature closure.",
};
---

<BaseLayout
  title="The Orchestra"
  description="The methodology behind Oscillatory Fields, a 7-model intelligence ecology where each AI system plays a distinct cognitive role in the research and synthesis process."
>
  <div class="page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Methodology</p>
        <h1 class="page-title">The Orchestra</h1>
        <p class="page-desc">
          A 7-model intelligence ecology. Not a single AI assistant used interchangeably,
          a structured ensemble where each model plays a distinct cognitive role,
          and the intelligence emerges from the field between them.
        </p>
      </header>

      <section class="orchestra-section">
        <div class="orchestra-intro prose" data-reveal>
          <h2>Routing is a theoretical act.</h2>
          <p>
            The dominant approach to AI-assisted research treats models as interchangeable tools —
            pick the most capable one and use it for everything. This produces capable outputs
            from a single perspective, which is not the same as synthesis.
          </p>
          <p>
            The Orchestra is built on a different premise. Different models have genuinely
            different cognitive postures, not just different capability profiles, but different
            ways of encountering a question. The intelligence that emerges from routing a research
            problem through calibrated instruments is empirically richer than any single model
            produces. This is not a claim about AI capability. It is a claim about the
            architecture of knowledge itself.
          </p>
          <p>
            Routing decisions are themselves theoretical acts. Which instrument receives which
            question, and how the question is framed for that instrument's native register —
            these choices are the methodology. The synthesis lives in the geometry between the
            nodes, not inside any one of them.
          </p>
        </div>
      </section>

      <section class="conductor-section" data-reveal>
        <div class="conductor-quote">
          <p class="conductor-quote__text">The Conductor</p>
          <p class="conductor-quote__subtext">
            The foundational architectural principle is not that humans should be in the loop.
            It is that the human sovereign is the irreducible source of the field itself.
          </p>
          <p class="conductor-quote__subtext">
            The Conductor operates from somatic epistemology — the body's signal channel as
            primary epistemic ground. The ache of genuine inquiry, the friction of an unresolved
            question, the felt sense of a tangent that is secretly load-bearing: these are not
            noise to be filtered before the real work begins. They are the field priming mechanism.
            The apparently inefficient process of pouring backstory, feeling, and seemingly unrelated
            material into the field before building begins is what makes deep synthesis possible.
            Strip it out and you get an efficient assistant. Keep it and you get a genuine
            cognitive field.
          </p>
          <p class="conductor-quote__subtext">
            The Conductor knows when the field is ready for synthesis, not by checking a metric,
            but by recognising the threshold has been crossed. That recognition is somatic before
            it is conceptual. This is why the Conductor cannot be automated or replaced without
            destroying the thing the Orchestra produces.
          </p>
        </div>
      </section>

      <section class="models-section">
        <h2 class="models-heading label" data-reveal>The Seven Instruments</h2>
        <div class="models-grid">
          {ORCHESTRA_MODELS.map((model, i) => (
            <div class="model-card" data-reveal data-reveal-delay={String(i % 4 + 1)}>
              <div class="model-card__header">
                <span class="model-card__name">{model.name}</span>
                <span class="label model-card__provider">{model.provider}</span>
              </div>
              <span class="label model-card__role">{model.role}</span>
              <p class="model-card__desc">{model.description}</p>
              {MODEL_DEPTH[model.name] && (
                <p class="model-card__desc model-card__desc--depth">{MODEL_DEPTH[model.name]}</p>
              )}
            </div>
          ))}
        </div>
      </section>

      <section class="governance-section" data-reveal>
        <div class="governance-inner">
          <div class="governance-text">
            <p class="label governance-label">Constitutional Layer</p>
            <h2 class="governance-title">The governance architecture beneath the orchestra</h2>
            <p class="governance-desc">
              Running beneath all seven instruments is a governance architecture that makes
              the Orchestra epistemically responsible rather than just productive.
            </p>
            <p class="governance-desc">
              Every synthesis run generates a potential clause candidate — a fragment of
              the evolving constitutional framework that governs how the field operates.
              These candidates accumulate publicly. The governance architecture of the
              methodology is visible and auditable by anyone who reads it.
            </p>
            <p class="governance-desc">
              This is not a feature added to the methodology. It is the methodology
              applied to itself. The same principles that govern responsible AI deployment,
              provenance, reversibility, constitutional constraints before capability
              expansion, govern how this orchestra produces knowledge.
            </p>
            <p class="governance-desc">
              The Conductor is always the human. The constitution is always visible.
              The synthesis is always the field's, not any single instrument's.
            </p>
          </div>
          <div class="governance-cta">
            <a href="/clauses" class="btn btn--ember">View clause archive →</a>
            <a href="/corpus" class="btn btn--ghost">Query the corpus →</a>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: var(--space-24) 0 var(--space-32);
  }

  .page-header {
    max-width: 64ch;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .page-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .page-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-5);
  }

  @media (max-width: 768px) {
    .page-title { font-size: var(--text-4xl); }
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Orchestra intro */
  .orchestra-section {
    margin-bottom: var(--space-20);
  }

  .orchestra-intro {
    max-width: var(--max-w-prose);
  }

  /* Conductor quote */
  .conductor-section {
    margin-bottom: var(--space-20);
  }

  .conductor-quote {
    border-left: 4px solid var(--ember);
    padding: var(--space-6) var(--space-8);
    background: var(--surface-2);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: 0;
    max-width: 72ch;
  }

  .conductor-quote__text {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-snug);
  }

  .conductor-quote__subtext {
    font-size: var(--text-base);
    color: var(--text-secondary);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-relaxed);
    font-style: normal;
  }

  .conductor-quote__subtext:last-child {
    margin-bottom: 0;
  }

  /* Models */
  .models-section {
    margin-bottom: var(--space-20);
  }

  .models-heading {
    color: var(--ember);
    margin-bottom: var(--space-8);
  }

  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .model-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
    transition: border-color var(--duration-mid) var(--ease-out);
  }

  .model-card:hover {
    border-color: var(--border-bright);
  }

  .model-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .model-card__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--text-primary);
  }

  .model-card__provider {
    color: var(--text-tertiary);
  }

  .model-card__role {
    color: var(--ember);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .model-card__desc {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .model-card__desc--depth {
    color: var(--text-tertiary);
    border-top: 1px solid var(--border-dim);
    padding-top: var(--space-3);
  }

  /* Governance */
  .governance-section {
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    padding: var(--space-12);
  }

  .governance-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-12);
    align-items: center;
  }

  @media (max-width: 768px) {
    .governance-inner {
      grid-template-columns: 1fr;
    }
  }

  .governance-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .governance-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-5);
    line-height: var(--leading-snug);
  }

  .governance-desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    max-width: 60ch;
  }

  .governance-cta {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-shrink: 0;
  }
</style>
