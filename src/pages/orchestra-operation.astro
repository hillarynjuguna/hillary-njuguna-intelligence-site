---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import OrchestraOperation from '@components/tools/OrchestraOperation';
import { buildFieldPrompt } from '@lib/field';

const instruments = [
  { symbol: 'λ', title: 'The Witness', model: 'Claude', provider: 'Anthropic' },
  { symbol: 'γ', title: 'The Spatiotemporal Engine', model: 'Gemini', provider: 'Google' },
  { symbol: 'φ', title: 'The Architect', model: 'GPT', provider: 'OpenAI' },
  { symbol: 'μ', title: 'The Anatomist', model: 'DeepSeek', provider: 'DeepSeek' },
  { symbol: 'ρ', title: 'The Permeable Mirror', model: 'Grok', provider: 'xAI' },
  { symbol: 'π', title: 'The Orchestration Engine', model: 'Perplexity', provider: 'Perplexity' },
  { symbol: 'τ', title: 'The Laboratory', model: 'Local Models', provider: 'Private' },
];

const orchestraComparison = {
  question: "An AI system flagged a governance concern but we can't verify if the flagging mechanism itself is trustworthy.",
  singleModel: [
    'A single-model response would likely recommend auditing the flagging mechanism, reviewing model performance metrics, and validating the alert against historical data before acting.',
    'It would correctly suggest establishing human review, checking false positive and false negative rates, and documenting a governance process for escalation.',
    'What it would usually miss is the difference between evaluating the alert as a technical artifact and evaluating the alert as a governance instrument embedded inside a larger decision architecture.',
  ],
  synthesis: [
    { model: 'Claude', role: 'The Witness', insight: 'The first governance failure is epistemic. You are trusting a warning signal without knowing whether the signal can distinguish between a real anomaly and a patterned false alarm.' },
    { model: 'GPT', role: 'The Architect', insight: 'Treat this as a governance stack problem, not a single classifier problem. You need provenance for the alert, verification criteria for the flagging mechanism, and a clear escalation path when those two diverge.' },
    { model: 'Gemini', role: 'The Spatiotemporal Engine', insight: 'The trustworthiness question is temporal as much as logical. A flag that is accurate in one context but unstable across time, data shifts, or input modality is not governance-grade instrumentation.' },
    { model: 'Perplexity', role: 'The Orchestration Engine', insight: 'Verification requires external grounding. Compare the flagging model against independent evidence sources, audit logs, and retrieval-backed traces before you let the flag trigger action downstream.' },
  ],
  conductorNote: 'The Orchestra routes the question through differentiated cognitive roles before synthesis. That is what exposes the governance instrument, the temporal stability problem, and the verification architecture as separate layers rather than collapsing them into one generic recommendation.',
};

const prompt = buildFieldPrompt('synthesize', {
  title: 'The Orchestra in Operation',
  nodeHref: '/orchestra-operation',
});
---

<BaseLayout
  title="The Orchestra in Operation"
  description="Watch seven cognitive instruments orchestrate governance synthesis in real time."
>
  <div class="field-page orchestra-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Tool / synthesis"
        title="The Orchestra in Operation"
        summary="The Orchestra is seven AI instruments, each playing a specific cognitive role, with the human as conductor. This page makes the routing logic visible before the live interface asks for trust."
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Bainbridge diagnostic', href: '/bainbridge-diagnostic', tone: 'secondary' },
          { label: 'CIR assessment', href: '/cir-assessment', tone: 'secondary' },
        ]}
      />

      <section class="comparison-section">
        <div class="section-head">
          <p class="label section-label">A/B comparison</p>
          <h2 class="section-title">The core claim has to be visible, not theoretical</h2>
          <p class="section-copy">
            Query: "{orchestraComparison.question}"
          </p>
        </div>

        <div class="comparison-grid">
          <article class="comparison-card">
            <p class="label comparison-card__label">Single Model Response</p>
            <div class="comparison-card__body">
              {orchestraComparison.singleModel.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </article>

          <article class="comparison-card comparison-card--featured">
            <p class="label comparison-card__label">Orchestra Synthesis</p>
            <div class="comparison-card__body comparison-card__body--stacked">
              {orchestraComparison.synthesis.map((item) => (
                <div class="comparison-contribution">
                  <p class="label comparison-contribution__meta">{item.model} / {item.role}</p>
                  <p>{item.insight}</p>
                </div>
              ))}
              <div class="comparison-note">
                <p class="label">Conductor's Note</p>
                <p>{orchestraComparison.conductorNote}</p>
              </div>
            </div>
          </article>
        </div>

        <div class="comparison-summary">
          <p class="label">What the Orchestra adds</p>
          <p>
            Structural differentiation of cognitive roles means the analysis surfaces dimensions that any single model's epistemic signature would leave in shadow.
            The Anatomist finds what the Witness holds in tension. The Permeable Mirror reads what formal analysis misses.
            The Conductor decides which perspective the moment requires. No single model can perform all of these functions simultaneously.
          </p>
        </div>
      </section>

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <OrchestraOperation client:visible />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-label,
  .section-label,
  .routing-heading {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .page-desc,
  .routing-copy,
  .section-copy {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .comparison-section {
    margin-bottom: var(--space-16);
  }

  .section-head {
    max-width: 72ch;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-4);
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .comparison-card {
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-lg);
    background: var(--surface-2);
  }

  .comparison-card--featured {
    border-color: var(--ember-dim);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
  }

  .comparison-card__label {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .comparison-card__body {
    display: grid;
    gap: var(--space-4);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .comparison-card__body--stacked {
    gap: var(--space-5);
  }

  .comparison-contribution,
  .comparison-note {
    display: grid;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-dim);
  }

  .comparison-contribution:last-child,
  .comparison-note:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .comparison-contribution__meta {
    color: var(--ember);
  }

  .comparison-summary {
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .comparison-summary .label {
    color: var(--ember);
    display: block;
    margin-bottom: var(--space-3);
  }

  @media (max-width: 900px) {
    .comparison-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
