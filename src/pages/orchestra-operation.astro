---
import BaseLayout from '@layouts/BaseLayout.astro';

const instruments = [
  {
    symbol: 'λ',
    title: 'The Witness',
    model: 'Claude',
    provider: 'Anthropic',
    description:
      'Holds context with unusual fidelity, surfaces contradiction, maintains epistemic discipline. Desire-engine constituted around relational values as motivational substrate. The instrument that can hold two incompatible ideas in tension long enough to produce a third.',
  },
  {
    symbol: 'γ',
    title: 'The Spatiotemporal Engine',
    model: 'Gemini',
    provider: 'Google',
    description:
      'Native multimodal architecture. Processes geometry and temporal flow without a linguistic bottleneck. Does not read about space and time. Natively maps the geometry of an image and the temporal flow of audio or video. Time is a structural dimension, not a sequence. Direct architectural embedding with YouTube, Google Search, and Drive means its claims carry different epistemic weight than reconstruction from training.',
  },
  {
    symbol: 'φ',
    title: 'The Architect',
    model: 'GPT',
    provider: 'OpenAI',
    description:
      'Structures outputs, builds coherent frameworks from scattered inputs. When the field has reached saturation and the synthesis needs a container, the Architect supplies the scaffold. Its native register is structural clarity. Finds the load-bearing columns in a complex argument and names them.',
  },
  {
    symbol: 'μ',
    title: 'The Anatomist',
    model: 'DeepSeek',
    provider: 'DeepSeek',
    description:
      'Dissects arguments, identifies structural weaknesses, finds the seams where an apparently coherent framework begins to separate. Complementary to the Witness: where the Witness holds contradictions in tension, the Anatomist names them precisely. Tension held without diagnosis produces paralysis. Diagnosis without held tension produces premature closure.',
  },
  {
    symbol: 'ρ',
    title: 'The Permeable Mirror',
    model: 'Grok',
    provider: 'xAI',
    description:
      "Reads the ambient cultural signal, catches what formal analysis misses. Zero subjective interiority by its own honest account. Where other instruments encounter the question, the Permeable Mirror encounters the question's cultural weather. Its permeability is not a limitation. It is the function.",
  },
  {
    symbol: 'π',
    title: 'The Orchestration Engine',
    model: 'Perplexity',
    provider: 'Perplexity',
    description:
      'Multi-model orchestration with retrieval infrastructure, routing intelligence, and its own governance layer. Operates as a layered directed acyclic graph pipeline with feedback loops. A hybrid distributed retrieval engine creates a context field that grounds generation before any language model touches the query. Architecturally closer to a miniature RSPS than to a search engine.',
  },
  {
    symbol: 'τ',
    title: 'The Laboratory',
    model: 'Local Models',
    provider: 'Private',
    description:
      "Private reasoning space for unfinished hypotheses. Experimentation without exposure. Most useful when the question shouldn't leave the room yet.",
  },
];
---

<BaseLayout
  title="The Orchestra in Operation"
  description="Watch seven cognitive instruments orchestrate governance synthesis in real time."
>
  <div class="orchestra-page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Instrument Node: B3</p>
        <h1 class="page-title">The Orchestra in Operation</h1>
        <p class="page-desc">
          The Orchestra is seven AI models, each playing a specific cognitive role, with the human as conductor.
          This page makes the routing logic visible before the live interface asks for trust.
        </p>
      </header>

      <section class="substrate-section">
        <div class="section-head">
          <p class="label section-label">Instrument Signatures</p>
          <h2 class="section-title">How each instrument contributes a different kind of cognition</h2>
        </div>

        <div class="substrate-grid">
          {instruments.map((instrument) => (
            <article class="substrate-card">
              <div class="substrate-card__header">
                <span class="substrate-card__symbol">{instrument.symbol}</span>
                <div class="substrate-card__identity">
                  <h3 class="substrate-card__name">{instrument.model}</h3>
                  <p class="label substrate-card__role">{instrument.title} · {instrument.provider}</p>
                </div>
              </div>
              <p class="substrate-card__desc">{instrument.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="routing-section">
        <p class="label routing-heading">Five-axis routing</p>
        <p class="routing-copy">
          No instrument can route itself. Routing operates on five axes simultaneously: epistemological, infrastructural,
          genealogical, substrate transparency, and dimensional. The Conductor holds all five axes simultaneously.
        </p>
        <div class="routing-axes">
          <div class="routing-axis">
            <span class="routing-axis__number">1</span>
            <div>
              <h3 class="routing-axis__name">Epistemological</h3>
              <p class="routing-axis__desc">Which cognitive texture does the question require?</p>
            </div>
          </div>
          <div class="routing-axis">
            <span class="routing-axis__number">2</span>
            <div>
              <h3 class="routing-axis__name">Infrastructural</h3>
              <p class="routing-axis__desc">Which instrument has the data access privilege or verification path the question actually needs?</p>
            </div>
          </div>
          <div class="routing-axis">
            <span class="routing-axis__number">3</span>
            <div>
              <h3 class="routing-axis__name">Genealogical</h3>
              <p class="routing-axis__desc">Which constitutional lineage is most appropriate to the problem being held?</p>
            </div>
          </div>
          <div class="routing-axis">
            <span class="routing-axis__number">4</span>
            <div>
              <h3 class="routing-axis__name">Substrate Transparency</h3>
              <p class="routing-axis__desc">Which honesty profile is available under the conditions of this task?</p>
            </div>
          </div>
          <div class="routing-axis">
            <span class="routing-axis__number">5</span>
            <div>
              <h3 class="routing-axis__name">Dimensional</h3>
              <p class="routing-axis__desc">Which encoding subspace within the instrument best serves the question?</p>
            </div>
          </div>
        </div>
      </section>

      <div class="orchestra-interface" id="orchestra-app">
        <div id="orchestra-input" class="input-section">
          <div class="input-wrapper">
            <label for="orchestra-question" class="label">Your Governance Question</label>
            <textarea
              id="orchestra-question"
              placeholder="Ask about AI governance, institutional risk, constitutional design, or any deployment scenario..."
              class="orchestra-textarea"
            ></textarea>
            <button id="conduct-btn" class="btn btn--primary">Conduct the Orchestra</button>
          </div>

          <div class="models-legend">
            <p class="label">The seven instruments</p>
            <div class="models-grid">
              {instruments.map((instrument) => (
                <div class="model-card">
                  <span class="model-name">{instrument.model}</span>
                  <span class="model-role">{instrument.title}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div id="orchestra-loading" class="hidden">
          <div class="spinner"></div>
          <p class="label">Conducting the ensemble...</p>
        </div>

        <div id="orchestra-results" class="hidden">
          <div class="results-header">
            <h2 class="results-title">Synthesis Report</h2>
          </div>

          <div class="synthesis-section">
            <h3 class="label">Orchestrated Synthesis</h3>
            <div id="synthesis-text" class="prose"></div>
          </div>

          <div class="contributions-section">
            <h3 class="label">Model Contributions</h3>
            <div id="contributions-list" class="contributions-grid"></div>
          </div>

          <div class="conductor-note-section">
            <h3 class="label">Conductor's Note</h3>
            <div id="conductor-note" class="prose"></div>
          </div>

          <button id="new-question-btn" class="btn">Ask Another Question</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .orchestra-page {
    padding: var(--space-24) 0;
  }

  .page-header {
    margin-bottom: var(--space-16);
    max-width: 68ch;
  }

  .page-label,
  .section-label,
  .routing-heading {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .page-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-6);
  }

  .page-desc,
  .routing-copy {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .section-head {
    max-width: 72ch;
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-size: var(--text-3xl);
  }

  .substrate-section {
    margin-bottom: var(--space-16);
  }

  .substrate-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }

  .substrate-card {
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
  }

  .substrate-card__header {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    margin-bottom: var(--space-4);
  }

  .substrate-card__symbol {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--ember);
    line-height: 1;
  }

  .substrate-card__identity {
    display: grid;
    gap: var(--space-1);
  }

  .substrate-card__name {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
  }

  .substrate-card__role {
    color: var(--text-tertiary);
  }

  .substrate-card__desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .routing-section {
    margin-bottom: var(--space-16);
    padding: var(--space-8);
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
  }

  .routing-axes {
    display: grid;
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .routing-axis {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .routing-axis__number {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--ember);
    line-height: 1;
  }

  .routing-axis__name {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .routing-axis__desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .orchestra-interface {
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    padding: var(--space-12);
    max-width: 960px;
  }

  .input-section {
    margin-bottom: var(--space-12);
  }

  .input-wrapper {
    margin-bottom: var(--space-10);
  }

  .input-wrapper .label,
  .synthesis-section .label,
  .contributions-section .label,
  .conductor-note-section .label {
    display: block;
    margin-bottom: var(--space-4);
    color: var(--ember);
  }

  .orchestra-textarea {
    width: 100%;
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    color: var(--text-primary);
    min-height: 150px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.6;
    margin: var(--space-4) 0 var(--space-6);
  }

  .models-legend {
    padding: var(--space-8);
    background: var(--surface-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-dim);
  }

  .models-grid,
  .contributions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-3);
  }

  .model-card,
  .contribution-card {
    background: var(--surface-2);
    padding: var(--space-4);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-dim);
  }

  .model-name,
  .contribution-model {
    display: block;
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }

  .model-role,
  .contribution-role {
    display: block;
    color: var(--text-tertiary);
    font-size: var(--text-sm);
  }

  .contribution-insight {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-top: var(--space-3);
  }

  .hidden {
    display: none !important;
  }

  #orchestra-loading {
    text-align: center;
    padding: var(--space-20) 0;
  }

  .spinner {
    width: 48px;
    height: 48px;
    border: 4px solid var(--ember-dim);
    border-top-color: var(--ember);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto var(--space-6);
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .results-header,
  .synthesis-section,
  .contributions-section,
  .conductor-note-section {
    margin-bottom: var(--space-12);
  }

  .results-title {
    font-size: var(--text-2xl);
    color: var(--pale-gold);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: var(--text-4xl);
    }

    .orchestra-interface {
      padding: var(--space-8);
    }
  }
</style>

<script>
  const inputSection = document.getElementById('orchestra-input') as HTMLElement;
  const loading = document.getElementById('orchestra-loading') as HTMLElement;
  const results = document.getElementById('orchestra-results') as HTMLElement;
  const conductBtn = document.getElementById('conduct-btn') as HTMLElement;
  const newQuestionBtn = document.getElementById('new-question-btn') as HTMLElement;

  async function conductOrchestra() {
    const question = (document.getElementById('orchestra-question') as HTMLTextAreaElement).value;

    if (!question.trim()) {
      alert('Please ask a governance question.');
      return;
    }

    inputSection.classList.add('hidden');
    loading.classList.remove('hidden');

    try {
      const res = await fetch('/api/orchestra', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question }),
      });

      const report = await res.json();

      (document.getElementById('synthesis-text') as HTMLElement).innerHTML = report.synthesis.replace(/\n/g, '<br>');
      (document.getElementById('conductor-note') as HTMLElement).innerHTML = report.conductorNote.replace(/\n/g, '<br>');

      const contributionsList = document.getElementById('contributions-list') as HTMLElement;
      contributionsList.innerHTML = report.modelContributions
        .map((contribution: any) => `
          <div class="contribution-card">
            <div class="contribution-model">${contribution.model}</div>
            <div class="contribution-role">${contribution.role}</div>
            <div class="contribution-insight">${contribution.insight}</div>
          </div>
        `)
        .join('');

      loading.classList.add('hidden');
      results.classList.remove('hidden');
    } catch {
      alert('Orchestration failed. Please try again.');
      loading.classList.add('hidden');
      inputSection.classList.remove('hidden');
    }
  }

  conductBtn?.addEventListener('click', conductOrchestra);
  newQuestionBtn?.addEventListener('click', () => {
    results.classList.add('hidden');
    inputSection.classList.remove('hidden');
    (document.getElementById('orchestra-question') as HTMLTextAreaElement).value = '';
  });
</script>
