---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';

---

<BaseLayout 
  title="Bainbridge Diagnostic Tool"
  description="Run a live structural diagnostic of your organization's AI capability-governance gap."
>
  <div class="diagnostic-page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Instrument Node: B1</p>
        <h1 class="page-title">Bainbridge Diagnostic</h1>
        <p class="page-desc">
          This is a live intake-to-output system. Input your organisation's AI deployment state to run the 
          four-stage diagnostic and identify structural failure modes before they occur.
        </p>
      </header>

      <div class="diagnostic-interface" id="diagnostic-app">
        <!-- Form Section -->
        <div class="diagnostic-form" id="diagnostic-form">
          <div class="form-group">
            <label for="systems" class="label">AI Systems Deployed</label>
            <textarea id="systems" placeholder="e.g., GPT-4o for customer support, custom RAG for legal, automated code review..."></textarea>
          </div>
          
          <div class="form-group">
            <label for="permissions" class="label">Permissions & Autonomy</label>
            <textarea id="permissions" placeholder="What can these systems do autonomously? Do they have write access to databases? Can they trigger emails?"></textarea>
          </div>

          <div class="form-group">
            <label for="governance" class="label">Governance Infrastructure</label>
            <textarea id="governance" placeholder="What oversight exists? Who is accountable for failures? Is there live monitoring? (Be specific)"></textarea>
          </div>

          <div class="form-group">
            <label for="history" class="label">Incident History</label>
            <textarea id="history" placeholder="Any past near-misses, hallucinations, or unexpected behaviors?"></textarea>
          </div>

          <button id="run-diagnostic" class="btn btn--primary">Run Diagnostic →</button>
        </div>

        <!-- Loading State -->
        <div id="diagnostic-loading" class="hidden">
          <div class="spinner"></div>
          <p class="label">Synthesizing Diagnostic...</p>
        </div>

        <!-- Results Section -->
        <div id="diagnostic-results" class="hidden">
          <div class="results-header">
            <h2 class="results-title">Diagnostic Report</h2>
            <div id="risk-badge" class="badge"></div>
          </div>
          
          <div class="score-grid">
            <div class="score-card">
              <span class="label">Capability Score</span>
              <div id="cap-score" class="score-val">0/10</div>
            </div>
            <div class="score-card">
              <span class="label">Governance Score</span>
              <div id="gov-score" class="score-val">0/10</div>
            </div>
          </div>

          <div class="results-content">
            <div class="results-section">
              <h3 class="label">Executive Summary</h3>
              <p id="results-summary"></p>
            </div>

            <div class="results-section">
              <h3 class="label">Bainbridge Zones (Gaps)</h3>
              <ul id="results-zones" class="results-list"></ul>
            </div>

            <div class="results-section">
              <h3 class="label">Predictable Failure Modes</h3>
              <ul id="results-failures" class="results-list"></ul>
            </div>

            <div class="results-section">
              <h3 class="label">Closing the Gap</h3>
              <ul id="results-recommendations" class="results-list"></ul>
            </div>
          </div>

          <button id="reset-diagnostic" class="btn">New Diagnostic</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .diagnostic-page { padding: var(--space-24) 0; }
  .page-header { margin-bottom: var(--space-16); max-width: 64ch; }
  .page-label { color: var(--ember); margin-bottom: var(--space-4); }
  .page-title { font-size: var(--text-5xl); margin-bottom: var(--space-6); }
  .page-desc { font-size: var(--text-lg); color: var(--text-secondary); line-height: 1.6; }

  .diagnostic-interface {
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
    max-width: 800px;
  }

  .form-group { margin-bottom: var(--space-8); }
  .form-group label { display: block; margin-bottom: var(--space-3); color: var(--text-tertiary); }
  .form-group textarea {
    width: 100%;
    background: var(--surface-3);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    color: var(--text-primary);
    min-height: 100px;
    font-family: var(--font-body);
  }

  .hidden { display: none !important; }

  #diagnostic-loading {
    text-align: center;
    padding: var(--space-16) 0;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--ember-dim);
    border-top-color: var(--ember);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin: 0 auto var(--space-4);
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .results-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8); }
  .results-title { font-size: var(--text-2xl); color: var(--pale-gold); }
  
  .score-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6); margin-bottom: var(--space-10); }
  .score-card { background: var(--surface-3); padding: var(--space-6); border-radius: var(--radius-md); text-align: center; }
  .score-val { font-size: var(--text-3xl); font-family: var(--font-display); color: var(--ember); margin-top: var(--space-2); }

  .results-section { margin-bottom: var(--space-8); padding-bottom: var(--space-6); border-bottom: 1px solid var(--border-dim); }
  .results-section:last-child { border-bottom: none; }
  .results-section h3 { color: var(--ember); margin-bottom: var(--space-4); }
  .results-list { list-style: none; padding: 0; }
  .results-list li { margin-bottom: var(--space-3); color: var(--text-secondary); padding-left: var(--space-4); border-left: 2px solid var(--border-mid); }

  .badge--critical { background: rgba(220, 38, 38, 0.2); color: #ef4444; border: 1px solid #ef4444; }
  .badge--high { background: rgba(196, 112, 58, 0.2); color: var(--ember); border: 1px solid var(--ember); }
</style>

<script>
  const form = document.getElementById('diagnostic-form');
  const loading = document.getElementById('diagnostic-loading');
  const results = document.getElementById('diagnostic-results');
  const runBtn = document.getElementById('run-diagnostic');
  const resetBtn = document.getElementById('reset-diagnostic');

  async function runDiagnostic() {
    const data = {
      systems: (document.getElementById('systems') as HTMLTextAreaElement).value,
      permissions: (document.getElementById('permissions') as HTMLTextAreaElement).value,
      governance: (document.getElementById('governance') as HTMLTextAreaElement).value,
      history: (document.getElementById('history') as HTMLTextAreaElement).value,
    };

    if (!data.systems || !data.governance) {
      alert('Please fill in at least the Systems and Governance fields.');
      return;
    }

    form?.classList.add('hidden');
    loading?.classList.remove('hidden');

    try {
      const res = await fetch('/api/diagnostic', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const report = await res.json();
      
      // Populate results
      (document.getElementById('cap-score') as HTMLElement).innerText = `${report.capabilityScore}/10`;
      (document.getElementById('gov-score') as HTMLElement).innerText = `${report.governanceScore}/10`;
      (document.getElementById('results-summary') as HTMLElement).innerText = report.summary;
      
      const riskBadge = document.getElementById('risk-badge') as HTMLElement;
      riskBadge.innerText = `${report.gapMagnitude} RISK GAP`;
      riskBadge.className = `badge badge--${report.gapMagnitude.toLowerCase()}`;

      const zonesList = document.getElementById('results-zones') as HTMLElement;
      zonesList.innerHTML = report.zones.map((z: any) => `<li><strong>${z.area}:</strong> ${z.risk}</li>`).join('');

      const failuresList = document.getElementById('results-failures') as HTMLElement;
      failuresList.innerHTML = report.failureModes.map((f: any) => `<li><strong>${f.mode}:</strong> ${f.predictability}</li>`).join('');

      const recsList = document.getElementById('results-recommendations') as HTMLElement;
      recsList.innerHTML = report.recommendations.map((r: any) => `<li>${r}</li>`).join('');

      loading?.classList.add('hidden');
      results?.classList.remove('hidden');
    } catch (err) {
      alert('Diagnostic failed. Please try again.');
      loading?.classList.add('hidden');
      form?.classList.remove('hidden');
    }
  }

  runBtn?.addEventListener('click', runDiagnostic);
  resetBtn?.addEventListener('click', () => {
    results?.classList.add('hidden');
    form?.classList.remove('hidden');
  });
</script>
