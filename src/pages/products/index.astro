---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldCard from '@components/field/FieldCard.astro';
import { getAllProducts, getStatusLabel } from '@lib/content';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, findGraphNode, getNeighborLabel } from '@lib/field';

const products = await getAllProducts();
const graph = await loadContentGraph();
const prompt = buildFieldPrompt('query', {
  title: 'Products and specimens',
  nodeHref: '/products',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Products & Specimens"
  description="Products, specimens, and assessment surfaces built from the Hillary Njuguna corpus. Governance doctrine becomes live instruments here."
  eyebrow="Applied work"
  summary="These are public operating surfaces built from the corpus. Some are assessments, some are specimens, and some are emerging tools. Each should still read like a node in the same field."
  actions={[
    { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
    { label: 'Ask the Orchestra', href: '/orchestra-operation', tone: 'secondary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Products', value: String(products.length) },
    { label: 'Mode', value: 'Query into applied nodes' },
    { label: 'Identity', value: 'Products are field states, not separate products' },
  ]}
>
  <div class="card-grid">
    {products.map((product) => {
      const node = findGraphNode(graph, {
        id: product.data.id,
        slug: product.slug,
        sourceCollection: 'products',
      });
      const neighborCount = countNodeNeighbors(graph, node?.id);

      return (
        <FieldCard
          href={`/products/${product.slug}`}
          accent="products"
          eyebrow={product.data.productType}
          title={product.data.title}
          summary={product.data.summary}
          meta={[getStatusLabel(product.data.status), ...(product.data.price ? [product.data.price] : [])]}
          chips={product.data.relatedResearch.slice(0, 3).map((item) => ({ label: item }))}
          neighborhoodLabel={getNeighborLabel(neighborCount, 'Applied node')}
          linkLabel="View details"
        />
      );
    })}
  </div>
</FieldShellLayout>
