---
import BaseLayout from '@layouts/BaseLayout.astro';
import CorpusGraph from '@components/ui/CorpusGraph.astro';
import { loadContentGraph } from '@lib/generated/loaders';

const graph = await loadContentGraph();

const title = "Research Corpus | Oscillatory Fields";
const description = "An interactive visualization of the Oscillatory Fields intelligence architecture. Explore the nodes and edges of our research, products, and legal infrastructure.";
---

<BaseLayout title={title} description={description} breadcrumbs={[{ name: 'Corpus', href: '/corpus' }]}>
  <div class="corpus-page">
    <header class="page-header" data-reveal>
      <div class="header-main">
        <p class="label accent">Interactive Map</p>
        <h1 class="page-title h1">Research Corpus</h1>
        <p class="page-subtitle">A semantic layer for AI systems. Drag to explore, scroll to zoom, click to dive into specific research streams.</p>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-value">{graph.nodes.length}</span>
          <span class="stat-label">Intelligence Nodes</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{graph.edges.length}</span>
          <span class="stat-label">Semantic Relations</span>
        </div>
        <div class="stat-card">
          <span class="stat-value">{new Set(graph.nodes.flatMap(n => n.tags)).size}</span>
          <span class="stat-label">Taxonomy Vectors</span>
        </div>
      </div>
    </header>

    <div class="graph-wrapper" data-reveal>
      <CorpusGraph data={graph} />
    </div>

    <section class="corpus-info" data-reveal>
      <div class="info-grid">
        <div class="info-cell">
          <h3>The Semantic Layer</h3>
          <p>Our corpus isn't just a collection of Markdown files; it's a directed graph of intelligence. Every research paper, digest entry, and product is a node connected by themes, domains, and explicit references.</p>
        </div>
        <div class="info-cell">
          <h3>Physics-Driven Discovery</h3>
          <p>The visualization uses a force-directed simulation where related content pulls together. This reveals hidden clusters in our thinking—where technical research overlaps with institutional governance.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .corpus-page {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }

  .page-header {
    margin-bottom: var(--space-16);
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .header-main {
    max-width: 600px;
  }

  .page-title {
    margin: var(--space-3) 0 var(--space-4);
  }

  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--text-dim);
    line-height: 1.6;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-6);
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    transition: border-color 0.3s ease;
  }

  .stat-card:hover {
    border-color: var(--accent-main);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-bright);
  }

  .stat-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    font-weight: 600;
  }

  .graph-wrapper {
    margin-bottom: var(--space-16);
    box-shadow: 0 40px 100px -20px rgba(0,0,0,0.5);
  }

  .corpus-info {
    border-top: 1px solid var(--border-dim);
    padding-top: var(--space-16);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-12);
  }

  .info-cell h3 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--text-bright);
  }

  .info-cell p {
    color: var(--text-dim);
    line-height: 1.7;
  }

  .accent {
    color: var(--accent-main);
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .corpus-page {
      padding: var(--space-8) var(--space-4);
    }
    
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
