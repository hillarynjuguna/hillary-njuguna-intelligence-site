---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import FieldRail from '@components/field/FieldRail.astro';
import CorpusGraph from '@components/ui/CorpusGraph.astro';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt } from '@lib/field';

const graph = await loadContentGraph();
const prompt = buildFieldPrompt('orient', {
  title: 'Research Corpus',
  nodeHref: '/corpus',
  primaryCorpusHref: '/corpus',
});
---

<BaseLayout
  title="Research Corpus | Oscillatory Fields"
  description="An interactive visualization of the Oscillatory Fields intelligence architecture. Explore the nodes and edges of our research, products, and legal infrastructure."
>
  <div class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Interactive map"
        title="Research Corpus"
        summary="The corpus is not only an archive of pages. It is a semantic field of authored nodes, typed relations, and governance-relevant adjacencies."
        meta={[
          { label: 'Nodes', value: String(graph.nodes.length) },
          { label: 'Relations', value: String(graph.edges.length) },
          { label: 'Vectors', value: String(new Set(graph.nodes.flatMap((node) => node.tags)).size) },
        ]}
        width="wide"
        actions={[
          { label: 'Browse taxonomy', href: '/tags', tone: 'ghost' },
          { label: 'Ask the field', href: '/orchestra-operation', tone: 'secondary' },
        ]}
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main field-stack">
          <div class="field-surface">
            <CorpusGraph data={graph} />
          </div>

          <div class="card-grid corpus-panels">
            <div class="field-panel">
              <h2>Semantic layer</h2>
              <p>
                Every research entry, digest note, product surface, and governance clause is a node.
                Relations are derived from authored metadata, not bolted on after the fact.
              </p>
            </div>
            <div class="field-panel">
              <h2>Neighborhood behavior</h2>
              <p>
                Use the graph to widen from one node into nearby structures. The goal is not map-first spectacle. It is a readable local field around authored documents.
              </p>
            </div>
          </div>
        </div>

        <FieldRail
          heading="Corpus orientation"
          facts={[
            { label: 'Nodes', value: String(graph.nodes.length) },
            { label: 'Relations', value: String(graph.edges.length) },
            { label: 'Vectors', value: String(new Set(graph.nodes.flatMap((node) => node.tags)).size) },
          ]}
          prompt={prompt}
        >
          <div class="field-panel">
            <p class="field-panel__eyebrow label">Graph visibility</p>
            <p>
              The graph stays present as low-level orientation first. Widen only when you need a broader neighborhood or a cross-cutting route.
            </p>
          </div>
        </FieldRail>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .corpus-panels p {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
