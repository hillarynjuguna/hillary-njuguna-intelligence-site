---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import DualInvariantDemo from '@components/tools/DualInvariantDemo';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('trace', {
  title: 'AI action approval desk',
  nodeHref: '/tools/dual-invariant-demo',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="AI Action Approval Desk"
  description="A business-facing control-plane demo for deciding whether an autonomous AI action should be approved, held, escalated, or blocked."
  eyebrow="Interactive tool"
  summary="See what happens when an AI agent tries to release a $100,000 wire transfer to a changed bank account."
  actions={[
    { label: 'Request implementation review', href: '/contact', tone: 'primary' },
    { label: 'Run CIR assessment', href: '/products/cir-assessment', tone: 'secondary' },
    { label: 'Return to Orchestra', href: '/orchestra-operation', tone: 'ghost' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Mode', value: 'Operational approval console' },
    { label: 'Decisions', value: 'Approve, hold, escalate, or block' },
    { label: 'Coverage', value: 'Money, production, customer refunds' },
  ]}
>
  <div class="dual-demo page-enter">
    <div class="container">

      <DualInvariantDemo client:visible />

      <section class="demo-intro card">
        <div class="intro-grid">
          <div>
            <p class="label section-label">The business problem</p>
            <p>
              Most AI safety demos stop at prompts and responses. Operators need a control plane for actions: who or what is asking, which system will be touched, whether the evidence is trustworthy, and whether the action should wait for human review.
            </p>
          </div>
          <div>
            <p class="label section-label">The formal layer</p>
            <p>
              Under the console is the same dual-invariant logic: irreversible action must wait long enough to be recallable, and the request must preserve a clean chain of provenance and authorization. The UI translates that into business decisions.
            </p>
          </div>
        </div>
      </section>

      <section class="demo-next card">
        <div class="demo-next__main">
          <p class="label section-label">Implementation path</p>
          <h3>Turn this from a demo into an action-control layer.</h3>
          <p>
            The practical work is mapping your irreversible actions, defining approval windows, connecting source-of-truth evidence, and deciding which cases are automatic, held, escalated, or blocked.
          </p>
        </div>
        <div class="demo-next__actions">
          <a href="/contact" class="btn btn--primary">Request implementation review</a>
          <a href="/products/cir-assessment" class="btn btn--secondary">Run CIR assessment</a>
        </div>
        <div class="demo-next__links">
          <span class="label">For technical readers</span>
          <a href="/research/aurora-consciousness-architecture" class="label">Technical basis</a>
          <a href="/research/r0-r3-classification" class="label">Reversibility model</a>
          <a href="/corpus" class="label">Open corpus</a>
        </div>
      </section>
    </div>
  </div>
</FieldShellLayout>

<style>
  .dual-demo {
    padding: var(--space-24) 0 var(--space-32);
  }

  .demo-header {
    max-width: 72ch;
    margin-bottom: var(--space-14);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .demo-label,
  .section-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .demo-title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-5);
  }

  .demo-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .card {
    padding: var(--space-7);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
    margin-bottom: var(--space-8);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .intro-grid p:not(.label) {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .demo-next {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-6);
    align-items: center;
  }

  .demo-next__main {
    max-width: 68ch;
  }

  .demo-next__main h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
  }

  .demo-next__main p:not(.label) {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .demo-next__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: flex-end;
  }

  .demo-next__links {
    grid-column: 1 / -1;
    padding-top: var(--space-5);
    border-top: 1px solid var(--border-dim);
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
    align-items: center;
  }

  .demo-next__links span {
    color: var(--text-tertiary);
  }

  .demo-next__links a {
    color: var(--text-tertiary);
    text-decoration: none;
  }

  .demo-next__links a:hover {
    color: var(--ember);
  }

  @media (max-width: 860px) {
    .demo-next {
      grid-template-columns: 1fr;
    }

    .demo-next__actions {
      justify-content: flex-start;
    }
  }
</style>
