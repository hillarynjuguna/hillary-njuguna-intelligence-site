---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import DualInvariantDemo from '@components/tools/DualInvariantDemo';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('trace', {
  title: 'Dual-Invariant demo',
  nodeHref: '/tools/dual-invariant-demo',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Governance Gate Demo"
  description="Interactive demo showing how a dual-invariant governance gate evaluates whether an AI action should proceed, pause, or block."
  eyebrow="Interactive tool"
  summary="An interactive state machine demonstrating how timing constraints and relational integrity checks combine to govern AI action execution in real time."
  actions={[
    { label: 'Read AURORA', href: '/research/aurora-consciousness-architecture', tone: 'secondary' },
    { label: 'Return to Orchestra', href: '/orchestra-operation', tone: 'ghost' },
    { label: 'Open corpus', href: '/corpus', tone: 'primary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Mode', value: 'Trace formal verification logic' },
    { label: 'Core rule', value: 'Both invariants must hold' },
    { label: 'Surface', value: 'Interactive state machine specimen' },
  ]}
>
  <div class="dual-demo page-enter">
    <div class="container">
      <header class="demo-header">
        <p class="label demo-label">Interactive Playground</p>
        <h2 class="demo-title">Governance Gate Simulator</h2>
        <p class="demo-desc">
          See how a Dual-Invariant Governance Gate operates in real time. Autonomous AI agents are granted operational power only when both timing safety and relational integrity invariants pass. Select a business scenario below to explore how this prevents catastrophic failures in practice.
        </p>
        <div class="demo-links">
          <a href="/research/aurora-consciousness-architecture" class="label">Read the AURORA research entry</a>
          <a href="/research/r0-r3-classification" class="label">Read Reversibility &amp; Invariants</a>
        </div>
      </header>

      <section class="demo-intro card">
        <div class="intro-grid">
          <div>
            <p class="label section-label">The Core Principle</p>
            <p>
              Security isn't built by policing output strings; it's built by establishing invariants. The timing gate prevents instant, unrecallable actions. The relational check ensures the action has an unbroken chain of human authorization.
            </p>
          </div>
          <div>
            <p class="label section-label">Operational Sandbox</p>
            <p>
              Use the controls in the simulator below to modify the agent's environmental conditions. If any security constraint is violated, the gate immediately flags, pauses, or blocks execution.
            </p>
          </div>
        </div>
      </section>

      <DualInvariantDemo client:visible />
    </div>
  </div>
</FieldShellLayout>

<style>
  .dual-demo {
    padding: var(--space-24) 0 var(--space-32);
  }

  .demo-header {
    max-width: 72ch;
    margin-bottom: var(--space-14);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .demo-label,
  .section-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .demo-title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-5);
  }

  .demo-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .demo-links {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .demo-links a {
    color: var(--text-tertiary);
    text-decoration: none;
  }

  .demo-links a:hover {
    color: var(--ember);
  }

  .card {
    padding: var(--space-7);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
    margin-bottom: var(--space-8);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .intro-grid p:not(.label) {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
