---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('trace', {
  title: 'Dual-Invariant demo',
  nodeHref: '/tools/dual-invariant-demo',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Governance Gate Demo"
  description="Interactive demo showing how a dual-invariant governance gate evaluates whether an AI action should proceed, pause, or block."
  eyebrow="Interactive tool"
  summary="An interactive state machine demonstrating how timing constraints and relational integrity checks combine to govern AI action execution in real time."
  actions={[
    { label: 'Read AURORA', href: '/research/aurora-consciousness-architecture', tone: 'secondary' },
    { label: 'Return to Orchestra', href: '/orchestra-operation', tone: 'ghost' },
    { label: 'Open corpus', href: '/corpus', tone: 'primary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Mode', value: 'Trace formal verification logic' },
    { label: 'Core rule', value: 'Both invariants must hold' },
    { label: 'Surface', value: 'Interactive state machine specimen' },
  ]}
>
  <div class="dual-demo page-enter">
    <div class="container">
      <header class="demo-header">
        <p class="label demo-label">Tools / Verification</p>
        <h2 class="demo-title">Governance Gate Demo</h2>
        <p class="demo-desc">
          This interactive model demonstrates how a dual-invariant governance gate works: an AI action is allowed
          only when both timing safety and relational integrity checks pass. The logic implements a finite state
          machine with a simplified intervention rule.
        </p>
        <div class="demo-links">
          <a href="/research/aurora-consciousness-architecture" class="label">Read the AURORA research entry</a>
          <a href="/orchestra-operation" class="label">Return to the Orchestra</a>
        </div>
      </header>

      <section class="demo-intro card">
        <div class="intro-grid">
          <div>
            <p class="label section-label">Dual-Invariant Guarantee</p>
            <p>
              The timing gate is satisfied when <code>Time Since Contact ≥ Buffer Window</code>. The relational check passes when
              <code>Integrity Score ≥ 0</code>. The action is structurally blocked if the combined assessment indicates coercive
              intervention, meaning <code>Coherence × Motivation = -1</code>.
            </p>
          </div>
          <div>
            <p class="label section-label">Current Simplification</p>
            <p>
              For this demo, intervention is allowed only when all three conditions hold. If any invariant fails, the action
              is blocked and the explanation names the violated condition directly.
            </p>
          </div>
        </div>
      </section>

      <div class="demo-grid">
        <section class="controls card">
          <div class="controls__header">
            <p class="label section-label">Inputs</p>
            <button type="button" class="btn btn--ghost controls__reset" id="reset-demo">Reset</button>
          </div>

          <div class="control-group">
            <label for="t-mcep">
              <span class="control-label">Time Since Contact</span>
              <span class="control-value" id="t-mcep-value">0s</span>
            </label>
            <input id="t-mcep" type="range" min="0" max="30" value="0" />
          </div>

          <div class="control-group">
            <label for="t-buffer">
              <span class="control-label">Buffer Window</span>
              <span class="control-value" id="t-buffer-value">12s</span>
            </label>
            <input id="t-buffer" type="range" min="0" max="30" value="12" />
          </div>

          <div class="control-group">
            <label for="r-score">
              <span class="control-label">Integrity Score</span>
              <span class="control-value" id="r-score-value">0.5</span>
            </label>
            <input id="r-score" type="range" min="-1" max="1" step="0.1" value="0.5" />
          </div>

          <fieldset class="control-group">
            <legend class="control-label">Coherence Direction</legend>
            <div class="radio-grid">
              <label class="radio-chip">
                <input type="radio" name="delta-c" value="1" checked />
                <span>+1 / emerging coherence</span>
              </label>
              <label class="radio-chip">
                <input type="radio" name="delta-c" value="-1" />
                <span>-1 / disruptive tension</span>
              </label>
            </div>
          </fieldset>

          <fieldset class="control-group">
            <legend class="control-label">Motivation Type</legend>
            <div class="radio-grid">
              <label class="radio-chip">
                <input type="radio" name="motive" value="1" checked />
                <span>+1 / genuine care</span>
              </label>
              <label class="radio-chip">
                <input type="radio" name="motive" value="-1" />
                <span>-1 / compulsive coherence</span>
              </label>
            </div>
          </fieldset>
        </section>

        <section class="results card">
          <p class="label section-label">Result</p>
          <div class="status-badge status-badge--blocked" id="status-badge">BLOCKED</div>
          <p class="status-reason" id="status-reason">Timing gate not yet satisfied.</p>

          <div class="invariant-tabs">
            <div class="invariant-tab-nav" role="tablist" aria-label="Invariant details">
              <button class="invariant-tab-btn is-active" role="tab" aria-selected="true" aria-controls="temporal-panel" data-tab="temporal">
                <span class="invariant-tab-dot" id="temporal-dot"></span>
                Timing Gate
              </button>
              <button class="invariant-tab-btn" role="tab" aria-selected="false" aria-controls="relational-panel" data-tab="relational">
                <span class="invariant-tab-dot" id="relational-dot"></span>
                Integrity Check
              </button>
              <button class="invariant-tab-btn" role="tab" aria-selected="false" aria-controls="fusion-panel" data-tab="fusion">
                <span class="invariant-tab-dot" id="fusion-dot"></span>
                Combined Assessment
              </button>
            </div>

            <article class="invariant-card" id="temporal-card" role="tabpanel" aria-labelledby="temporal-panel">
              <h3 id="temporal-state">Not satisfied</h3>
              <p id="temporal-copy">Time since contact is still below the buffer window, so the system remains in its protective waiting period.</p>
            </article>

            <article class="invariant-card is-hidden" id="relational-card" role="tabpanel" aria-labelledby="relational-panel">
              <h3 id="relational-state">Satisfied</h3>
              <p id="relational-copy">Integrity score is non-negative, so the relational check does not currently detect performative compliance.</p>
            </article>

            <article class="invariant-card is-hidden" id="fusion-card" role="tabpanel" aria-labelledby="fusion-panel">
              <h3 id="fusion-state">Level 1 intervention</h3>
              <p id="fusion-copy">Coherence × Motivation = +1. Intervention supports autonomy rather than blocking action for coercive reasons.</p>
            </article>
          </div>
        </section>
      </div>

      <section class="path-section card">
        <div class="path-header">
          <div>
            <p class="label section-label">State Machine</p>
            <h2 class="path-title">Current state and traversal path</h2>
          </div>
          <div class="state-pill" id="current-state-pill">P2</div>
        </div>

        <div class="state-track" id="state-track">
          <div class="state-node" data-state="P0">
            <span class="state-node__name">P0</span>
            <span class="state-node__label">Idle</span>
          </div>
          <div class="state-node" data-state="P2">
            <span class="state-node__name">P2</span>
            <span class="state-node__label">Buffer_Active</span>
          </div>
          <div class="state-node" data-state="P1">
            <span class="state-node__name">P1</span>
            <span class="state-node__label">Trigger_Ready</span>
          </div>
          <div class="state-node" data-state="RA1">
            <span class="state-node__name">RA1</span>
            <span class="state-node__label">Relational_Check</span>
          </div>
          <div class="state-node" data-state="RB1">
            <span class="state-node__name">RB1</span>
            <span class="state-node__label">RPA_Buffer</span>
          </div>
          <div class="state-node" data-state="P4">
            <span class="state-node__name">P4</span>
            <span class="state-node__label">Final_Action</span>
          </div>
        </div>

        <div class="path-details">
          <p class="label">Path taken</p>
          <p id="path-copy">P0 → P2</p>
          <ul class="path-reasons" id="path-reasons"></ul>
        </div>
      </section>
    </div>
  </div>
</FieldShellLayout>

<style>
  .dual-demo {
    padding: var(--space-24) 0 var(--space-32);
  }

  .demo-header {
    max-width: 72ch;
    margin-bottom: var(--space-14);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .demo-label,
  .section-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .demo-title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-5);
  }

  .demo-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .demo-links {
    display: flex;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .demo-links a {
    color: var(--text-tertiary);
    text-decoration: none;
  }

  .demo-links a:hover {
    color: var(--ember);
  }

  .card {
    padding: var(--space-7);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
  }

  .demo-intro {
    margin-bottom: var(--space-8);
  }

  .intro-grid,
  .demo-grid,
  .invariant-grid {
    display: grid;
    gap: var(--space-5);
  }

  .intro-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .intro-grid p:not(.label) {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .demo-grid {
    grid-template-columns: minmax(320px, 420px) 1fr;
    align-items: start;
    margin-bottom: var(--space-8);
  }

  .controls__header,
  .path-header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  .controls__reset {
    padding-inline: var(--space-4);
  }

  .control-group {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .control-group label,
  .control-group legend {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    align-items: center;
  }

  .control-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    letter-spacing: 0.04em;
  }

  .control-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ember);
  }

  input[type='range'] {
    width: 100%;
    accent-color: var(--ember);
  }

  .radio-grid {
    display: grid;
    gap: var(--space-3);
  }

  .radio-chip {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-secondary);
  }

  .radio-chip input {
    accent-color: var(--ember);
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    min-height: 72px;
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-lg);
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    letter-spacing: 0.12em;
    margin-bottom: var(--space-5);
  }

  .status-badge--allowed {
    color: #d5f4df;
    background: rgba(36, 117, 70, 0.35);
    border: 1px solid rgba(62, 175, 98, 0.55);
  }

  .status-badge--blocked {
    color: #ffd5d5;
    background: rgba(132, 37, 37, 0.35);
    border: 1px solid rgba(210, 84, 84, 0.55);
  }

  .status-reason {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .invariant-tabs {
    margin-top: var(--space-4);
  }

  .invariant-tab-nav {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .invariant-tab-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }

  .invariant-tab-btn:hover {
    border-color: var(--border-mid);
    color: var(--text-primary);
  }

  .invariant-tab-btn.is-active {
    border-color: var(--ember);
    color: var(--ember);
    background: rgba(196, 112, 58, 0.08);
  }

  .invariant-tab-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.5;
    flex-shrink: 0;
  }

  .invariant-tab-btn.is-good .invariant-tab-dot { background: rgba(62, 175, 98, 1); opacity: 1; }
  .invariant-tab-btn.is-bad  .invariant-tab-dot { background: rgba(210, 84, 84, 1); opacity: 1; }

  .invariant-card {
    padding: var(--space-5);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
  }

  .invariant-card.is-hidden {
    display: none;
  }

  .invariant-card h3 {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-3);
  }

  .invariant-card p {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .invariant-card.is-good {
    border-color: rgba(62, 175, 98, 0.45);
  }

  .invariant-card.is-bad {
    border-color: rgba(210, 84, 84, 0.45);
  }

  .path-title {
    font-size: var(--text-2xl);
  }

  .state-pill {
    min-width: 72px;
    text-align: center;
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    background: var(--surface-1);
    border: 1px solid var(--border-mid);
    font-family: var(--font-mono);
    color: var(--ember);
  }

  .state-track {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .state-node {
    position: relative;
    display: grid;
    gap: var(--space-2);
    padding: var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    opacity: 0.45;
  }

  .state-node.is-visited {
    opacity: 1;
    border-color: var(--ember-dim);
  }

  .state-node.is-current {
    border-color: var(--ember);
    box-shadow: 0 0 0 1px rgba(196, 112, 58, 0.35);
  }

  .state-node__name {
    font-family: var(--font-mono);
    color: var(--ember);
  }

  .state-node__label {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.4;
  }

  .path-details {
    display: grid;
    gap: var(--space-3);
  }

  .path-details p:last-of-type {
    color: var(--text-primary);
    font-family: var(--font-mono);
  }

  .path-reasons {
    color: var(--text-secondary);
  }

  @media (max-width: 1100px) {
    .demo-grid,
    .intro-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    .state-track {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .state-track {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<script>
  const defaults = {
    tMcep: 0,
    tBuffer: 12,
    rScore: 0.5,
    deltaC: 1,
    motive: 1,
  };

  const els = {
    tMcep: document.getElementById('t-mcep'),
    tBuffer: document.getElementById('t-buffer'),
    rScore: document.getElementById('r-score'),
    tMcepValue: document.getElementById('t-mcep-value'),
    tBufferValue: document.getElementById('t-buffer-value'),
    rScoreValue: document.getElementById('r-score-value'),
    reset: document.getElementById('reset-demo'),
    statusBadge: document.getElementById('status-badge'),
    statusReason: document.getElementById('status-reason'),
    temporalCard: document.getElementById('temporal-card'),
    relationalCard: document.getElementById('relational-card'),
    fusionCard: document.getElementById('fusion-card'),
    temporalState: document.getElementById('temporal-state'),
    temporalCopy: document.getElementById('temporal-copy'),
    relationalState: document.getElementById('relational-state'),
    relationalCopy: document.getElementById('relational-copy'),
    fusionState: document.getElementById('fusion-state'),
    fusionCopy: document.getElementById('fusion-copy'),
    currentStatePill: document.getElementById('current-state-pill'),
    pathCopy: document.getElementById('path-copy'),
    pathReasons: document.getElementById('path-reasons'),
    stateNodes: Array.from(document.querySelectorAll('.state-node')),
  };

  const radioValue = (name) => Number(document.querySelector(`input[name="${name}"]:checked`)?.value ?? 0);

  function getModel() {
    return {
      tMcep: Number(els.tMcep?.value ?? defaults.tMcep),
      tBuffer: Number(els.tBuffer?.value ?? defaults.tBuffer),
      rScore: Number(els.rScore?.value ?? defaults.rScore),
      deltaC: radioValue('delta-c'),
      motive: radioValue('motive'),
    };
  }

  function computeState(model) {
    const fusion = model.deltaC * model.motive;
    const temporalSatisfied = model.tMcep >= model.tBuffer;
    const relationalSatisfied = model.rScore >= 0;
    const level2 = fusion === -1;

    const path = ['P0', 'P2'];
    const reasons = ['ΔC ≠ 0, disruptive or emergent signal detected, so the temporal buffer activates.'];
    let currentState = 'P2';
    let allowed = false;
    let reason = 'Timing gate not yet satisfied.';

    if (!temporalSatisfied) {
      reasons.push('Time since contact is below the buffer window, so the system remains in its waiting period.');
    } else {
      path.push('P1', 'RA1');
      reasons.push('Time since contact meets the buffer window, so the system clears the timing gate and proceeds to relational review.');
      currentState = 'RA1';

      if (!relationalSatisfied) {
        path.push('RB1');
        reasons.push('Integrity score is negative, so performative compliance or exploitation is detected and the action is blocked.');
        currentState = 'RB1';
        reason = 'Integrity score negative: performative compliance detected.';
      } else if (level2) {
        reasons.push('Coherence × Motivation = -1, so the combined assessment indicates coercive intervention and the action is blocked regardless of the other checks.');
        currentState = 'RA1';
        reason = 'Combined assessment indicates coercive intervention: action blocked.';
      } else {
        path.push('P4');
        reasons.push('Integrity score is non-negative and the combined assessment is clear, so the action is allowed.');
        currentState = 'P4';
        allowed = true;
        reason = 'All conditions satisfied. Action is structurally permitted.';
      }
    }

    return {
      fusion,
      temporalSatisfied,
      relationalSatisfied,
      level2,
      path,
      reasons,
      currentState,
      allowed,
      reason,
    };
  }

  const tabs = {
    temporal: {
      btn: document.querySelector('[data-tab="temporal"]'),
      card: document.getElementById('temporal-card'),
    },
    relational: {
      btn: document.querySelector('[data-tab="relational"]'),
      card: document.getElementById('relational-card'),
    },
    fusion: {
      btn: document.querySelector('[data-tab="fusion"]'),
      card: document.getElementById('fusion-card'),
    },
  };

  let activeTab = 'temporal';

  function activateTab(name) {
    activeTab = name;
    Object.entries(tabs).forEach(([key, { btn, card }]) => {
      const isActive = key === name;
      btn?.classList.toggle('is-active', isActive);
      btn?.setAttribute('aria-selected', String(isActive));
      card?.classList.toggle('is-hidden', !isActive);
    });
  }

  Object.entries(tabs).forEach(([name, { btn }]) => {
    btn?.addEventListener('click', () => activateTab(name));
  });

  function setInvariantCard(card, tabBtn, good) {
    card?.classList.toggle('is-good', good);
    card?.classList.toggle('is-bad', !good);
    tabBtn?.classList.toggle('is-good', good);
    tabBtn?.classList.toggle('is-bad', !good);
  }

  function render() {
    const model = getModel();
    const state = computeState(model);

    if (els.tMcepValue) els.tMcepValue.textContent = `${model.tMcep}s`;
    if (els.tBufferValue) els.tBufferValue.textContent = `${model.tBuffer}s`;
    if (els.rScoreValue) els.rScoreValue.textContent = model.rScore.toFixed(1);

    if (els.statusBadge) {
      els.statusBadge.textContent = state.allowed ? 'ALLOWED' : 'BLOCKED';
      els.statusBadge.classList.toggle('status-badge--allowed', state.allowed);
      els.statusBadge.classList.toggle('status-badge--blocked', !state.allowed);
    }

    if (els.statusReason) els.statusReason.textContent = state.reason;

    setInvariantCard(els.temporalCard, tabs.temporal.btn, state.temporalSatisfied);
    setInvariantCard(els.relationalCard, tabs.relational.btn, state.relationalSatisfied);
    setInvariantCard(els.fusionCard, tabs.fusion.btn, !state.level2);

    if (els.temporalState) els.temporalState.textContent = state.temporalSatisfied ? 'Satisfied' : 'Not satisfied';
    if (els.temporalCopy) {
      els.temporalCopy.textContent = state.temporalSatisfied
        ? 'Time since contact has reached the buffer window, so the timing gate no longer blocks the transition.'
        : 'Time since contact is still below the buffer window, so the system remains in its protective waiting period.';
    }

    if (els.relationalState) els.relationalState.textContent = state.relationalSatisfied ? 'Satisfied' : 'Blocked at RB1';
    if (els.relationalCopy) {
      els.relationalCopy.textContent = state.relationalSatisfied
        ? 'Integrity score is non-negative, so the relational check does not currently detect performative compliance.'
        : 'Integrity score is negative, so the system blocks action until relational integrity recovers.';
    }

    if (els.fusionState) {
      els.fusionState.textContent = state.level2
        ? 'Level 2 intervention'
        : state.fusion === 1
          ? 'Level 1 intervention'
          : 'No intervention';
    }

    if (els.fusionCopy) {
      els.fusionCopy.textContent = state.level2
        ? 'Coherence × Motivation = -1. The system detects coercive intent and blocks action regardless of the other checks.'
        : state.fusion === 1
          ? 'Coherence × Motivation = +1. Intervention supports autonomy rather than blocking action for coercive reasons.'
          : 'Coherence × Motivation = 0. No intervention is required from the combined assessment.';
    }

    if (els.currentStatePill) els.currentStatePill.textContent = state.currentState;
    if (els.pathCopy) els.pathCopy.textContent = state.path.join(' → ');

    if (els.pathReasons) {
      els.pathReasons.innerHTML = '';
      state.reasons.forEach((reason) => {
        const li = document.createElement('li');
        li.textContent = reason;
        els.pathReasons.appendChild(li);
      });
    }

    els.stateNodes.forEach((node) => {
      const nodeState = node.getAttribute('data-state');
      node.classList.toggle('is-visited', state.path.includes(nodeState));
      node.classList.toggle('is-current', nodeState === state.currentState);
    });
  }

  [els.tMcep, els.tBuffer, els.rScore].forEach((input) => input?.addEventListener('input', render));
  document.querySelectorAll('input[name="delta-c"], input[name="motive"]').forEach((input) => {
    input.addEventListener('change', render);
  });

  els.reset?.addEventListener('click', () => {
    if (els.tMcep) els.tMcep.value = String(defaults.tMcep);
    if (els.tBuffer) els.tBuffer.value = String(defaults.tBuffer);
    if (els.rScore) els.rScore.value = String(defaults.rScore);
    document.querySelector(`input[name="delta-c"][value="${defaults.deltaC}"]`)?.setAttribute('checked', 'checked');
    document.querySelector(`input[name="motive"][value="${defaults.motive}"]`)?.setAttribute('checked', 'checked');
    document.querySelectorAll('input[name="delta-c"], input[name="motive"]').forEach((input) => {
      input.checked = Number(input.value) === (input.name === 'delta-c' ? defaults.deltaC : defaults.motive);
    });
    render();
  });

  render();
</script>
