---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getAllDigestEntries, formatDate } from '@lib/content';

const entries = await getAllDigestEntries();
---

<BaseLayout
  title="Intelligence Digest"
  description="Field notes from active synthesis, The Oscillatory Fields Intelligence Digest. Live analysis across AI governance, institutional deployment, and constitutional design."
>
  <div class="page page-enter">
    <div class="container">
      <header class="page-header">
        <p class="label page-label">Publication</p>
        <h1 class="page-title">Intelligence Digest</h1>
        <p class="page-desc">
          Field notes from active synthesis. Published on a rolling basis as analysis
          emerges from the research corpus. Each entry is produced through human-AI synthesis
          and reflects live research across the Oscillatory Fields corpus.
        </p>
        <div class="page-meta">
          <a href="/rss.xml" class="label page-rss">↗ RSS feed</a>
          <span class="label" style="color: var(--text-tertiary)">·</span>
          <a href="https://substack.com/@achetype1" target="_blank" rel="noopener noreferrer" class="label page-rss">
            AcheType on Substack ↗
          </a>
        </div>
      </header>

      {entries.length === 0 ? (
        <p class="empty label">Digest entries loading…</p>
      ) : (
        <div class="digest-list">
          {entries.map((entry) => (
            <a href={`/digest/${entry.slug}`} class="digest-entry hover-lift" data-reveal>
              <div class="digest-entry__left">
                <time class="label digest-entry__date" datetime={entry.data.publishedAt.toISOString()}>
                  {formatDate(entry.data.publishedAt)}
                </time>
                <span class="label digest-entry__category">{entry.data.category}</span>
                {entry.data.featured && (
                  <span class="badge badge--live" style="font-size: 10px;">Featured</span>
                )}
              </div>
              <div class="digest-entry__body">
                <h2 class="digest-entry__title">{entry.data.title}</h2>
                <p class="digest-entry__summary">{entry.data.summary}</p>
                <div class="digest-entry__tags">
                  {entry.data.tags.slice(0, 4).map((tag) => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    padding: var(--space-24) 0 var(--space-32);
  }

  .page-header {
    max-width: 64ch;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-dim);
  }

  .page-label {
    color: var(--ember);
    margin-bottom: var(--space-3);
  }

  .page-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-5);
  }

  @media (max-width: 768px) {
    .page-title { font-size: var(--text-4xl); }
  }

  .page-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .page-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .page-rss {
    color: var(--ember);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .page-rss:hover {
    color: var(--ember-bright);
  }

  .digest-list {
    display: flex;
    flex-direction: column;
  }

  .digest-entry {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-8);
    align-items: start;
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-dim);
    text-decoration: none;
    transition: all var(--duration-mid) var(--ease-out);
  }

  @media (max-width: 768px) {
    .digest-entry {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }

  .digest-entry:hover {
    background: var(--surface-2);
    padding-left: var(--space-4);
    padding-right: var(--space-4);
    border-radius: var(--radius-md);
  }

  .digest-entry__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 4px;
  }

  .digest-entry__date {
    color: var(--text-tertiary);
  }

  .digest-entry__category {
    color: var(--ember);
  }

  .digest-entry__title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: var(--leading-snug);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .digest-entry:hover .digest-entry__title {
    color: var(--pale-gold);
  }

  .digest-entry__summary {
    font-size: var(--text-base);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .digest-entry__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .empty {
    color: var(--text-tertiary);
    padding: var(--space-12) 0;
  }
</style>
