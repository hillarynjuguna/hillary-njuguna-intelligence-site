---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import FieldListItem from '@components/field/FieldListItem.astro';
import { getAllDigestEntries, formatDate } from '@lib/content';
import { loadContentGraph } from '@lib/generated/loaders';
import { buildFieldPrompt, countNodeNeighbors, findGraphNode, getNeighborLabel } from '@lib/field';

const entries = await getAllDigestEntries();
const graph = await loadContentGraph();
const prompt = buildFieldPrompt('orient', {
  title: 'Intelligence digest',
  nodeHref: '/digest',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Intelligence Digest"
  description="Field notes from active synthesis, The Hillary Njuguna Intelligence Digest. Live analysis across AI governance, institutional deployment, and constitutional design."
  eyebrow="Publication"
  summary="Field notes from active synthesis. Each entry stays attached to the research field it emerged from, rather than pretending to be a detached article."
  actions={[
    { label: 'RSS feed', href: '/rss.xml', tone: 'ghost' },
    { label: 'Open corpus', href: '/corpus', tone: 'secondary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'Entries', value: String(entries.length) },
    { label: 'Mode', value: 'Orient into live synthesis' },
    { label: 'Transition', value: 'Digest clarifies doctrine and products' },
  ]}
>
  {entries.length === 0 ? (
    <p class="empty label">Digest entries loading...</p>
  ) : (
    <div class="field-stack">
      {entries.map((entry) => {
        const node = findGraphNode(graph, {
          id: entry.data.id,
          slug: entry.slug,
          sourceCollection: 'digest',
        });
        const neighborCount = countNodeNeighbors(graph, node?.id);

        return (
          <FieldListItem
            href={`/digest/${entry.slug}`}
            accent="digest"
            eyebrow={entry.data.category}
            title={entry.data.title}
            summary={entry.data.summary}
            aside={[
              formatDate(entry.data.publishedAt),
              entry.data.crystallization,
            ]}
            chips={entry.data.tags.slice(0, 4).map((tag) => ({ label: `#${tag}` }))}
            footer={getNeighborLabel(neighborCount, 'Field note')}
            badge={entry.data.featured ? 'Featured' : undefined}
          />
        );
      })}
    </div>
  )}
</FieldShellLayout>

<style>
  .empty {
    color: var(--text-tertiary);
    padding: var(--space-12) 0;
  }
</style>
