---
export const prerender = true;
import { getCollection } from 'astro:content';
import ContentLayout from '@layouts/ContentLayout.astro';
import GovernanceLinks from '@components/relations/GovernanceLinks.astro';
import { getRelatedContent } from '@lib/related/getRelatedContent';
import { buildArticleSchema } from '@lib/seo';
import { SITE } from '@data/site';

export async function getStaticPaths() {
  const entries = await getCollection('digest', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { data } = entry;

const contentId = data.id ?? `digest-${entry.slug}`;
const allRelated = await getRelatedContent(contentId, 5);

const govItems = allRelated.filter(
  (r) =>
    r.edge.type === 'governance_relevant_to' ||
    r.node.contentType === 'clause'
);
const relatedItems = allRelated.filter((r) => !govItems.includes(r)).slice(0, 3);

const articleSchema = buildArticleSchema({
  title: data.seoTitle ?? data.title,
  description: data.seoDescription ?? data.summary,
  url: `${SITE.url}/digest/${entry.slug}`,
  publishedAt: data.publishedAt,
  updatedAt: data.updatedAt,
  ogImage: data.ogImage,
  type: data.structuredDataType,
});
---

<ContentLayout
  title={data.seoTitle ?? data.title}
  description={data.seoDescription ?? data.summary}
  category={data.category}
  publishedAt={data.publishedAt}
  updatedAt={data.updatedAt}
  tags={data.tags}
  author={data.author}
  breadcrumbs={[
    { name: 'Digest', href: '/digest' },
    { name: data.title, href: `/digest/${entry.slug}` },
  ]}
  related={relatedItems}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Content />
  {govItems.length > 0 && (
    <GovernanceLinks clauseItems={govItems} />
  )}
</ContentLayout>
