---
import BaseLayout from '@layouts/BaseLayout.astro';
import AudienceRouter from '@components/ui/AudienceRouter.astro';
import ContentExplorer from '@components/ui/ContentExplorer.astro';
import { getFeaturedDigestEntries, getFeaturedResearch, getFeaturedProducts, getCurrentSignal, formatDate } from '@lib/content';
import { SERVICES, ORCHESTRA_MODELS, TICKER_ITEMS } from '@data/navigation';
import SocialProof from '@components/ui/SocialProof.astro';
import { SITE } from '@data/site';

const [digestEntries, researchEntries, products, signal] = await Promise.all([
  getFeaturedDigestEntries(3),
  getFeaturedResearch(),
  getFeaturedProducts(),
  getCurrentSignal(),
]);

const researchPriority = ['research-aurora', 'research-bainbridge-warning', 'research-dcfb'];
const homepageResearch = researchPriority
  .map((id) => researchEntries.find((entry) => (entry.data.id ?? `research-${entry.slug}`) === id))
  .filter(Boolean);

const orchestraDemo = [
  {
    model: 'Claude',
    role: 'The Witness',
    insight:
      'The first governance failure is epistemic. You are trusting a warning signal without knowing whether the signal can distinguish between a real anomaly and a patterned false alarm.',
  },
  {
    model: 'GPT',
    role: 'The Architect',
    insight:
      'Treat this as a governance stack problem, not a single classifier problem. You need provenance for the alert, verification criteria for the flagging mechanism, and a clear escalation path when those two diverge.',
  },
  {
    model: 'Gemini',
    role: 'The Spatiotemporal Engine',
    insight:
      'The trustworthiness question is temporal as much as logical. A flag that is accurate in one context but unstable across time, data shifts, or input modality is not governance-grade instrumentation.',
  },
  {
    model: 'DeepSeek',
    role: 'The Anatomist',
    insight:
      'Verification requires external grounding. Compare the flagging model against independent evidence sources, audit logs, and retrieval-backed traces before you let the flag trigger action downstream.',
  },
];

const tickerItems = [...TICKER_ITEMS, ...TICKER_ITEMS];
---

<BaseLayout title={undefined} description={SITE.description}>
  <section class="hero">
    <div class="hero__wave">
      <svg viewBox="0 0 1000 400" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 200C150 100 350 300 500 200C650 100 850 300 1000 200" stroke="var(--accent-research)" stroke-width="2" stroke-dasharray="10 10" opacity="0.3">
          <animate attributeName="d" dur="10s" repeatCount="indefinite" values="M0 200C150 100 350 300 500 200C650 100 850 300 1000 200;M0 200C150 300 350 100 500 200C650 300 850 100 1000 200;M0 200C150 100 350 300 500 200C650 100 850 300 1000 200" />
        </path>
        <path d="M0 210C150 110 350 310 500 210C650 110 850 310 1000 210" stroke="var(--accent-digest)" stroke-width="1" opacity="0.2">
          <animate attributeName="d" dur="15s" repeatCount="indefinite" values="M0 210C150 110 350 310 500 210C650 110 850 310 1000 210;M0 210C150 310 350 110 500 210C650 310 850 110 1000 210;M0 210C150 110 350 310 500 210C650 110 850 310 1000 210" />
        </path>
      </svg>
    </div>

    <div class="container">
      <div class="hero__inner">
        {signal && (
          <div class="hero__signal" data-reveal>
            <span class="signal-dot"></span>
            <span class="hero__signal-text label">{signal.currentSignal}</span>
          </div>
        )}

        <h1 class="hero__headline" data-reveal data-reveal-delay="1">
          Intelligence Architecture<br />
          for AI Deployment.
        </h1>

        <p class="hero__sub" data-reveal data-reveal-delay="2">
          Bridge the gap between latent capability and institutional readiness. 
          <span class="highlight">Ship AI systems with constitutional guarantees, not just capability demos.</span>
        </p>

        <div class="hero__actions" data-reveal data-reveal-delay="3">
          <a href="/corpus" class="btn btn--primary">Ask the Corpus</a>
          <a href="/cir-assessment" class="btn btn--secondary">Begin Readiness Assessment</a>
        </div>

        <div class="hero__origin label" data-reveal data-reveal-delay="4">
          Eighteen months of recursive inquiry. 
          <span class="hero__origin-sep">/</span>
          560+ Sourced Documents.
          <span class="hero__origin-sep">/</span>
          Seven Models.
        </div>

        {signal && (
          <div class="hero__metrics" data-reveal data-reveal-delay="5">
            {signal.metrics && Object.entries(signal.metrics).map(([key, val]) => (
              <div class="hero__metric">
                <span class="hero__metric-val">{val}</span>
                <span class="label hero__metric-key">{key}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="section-router">
    <div class="container">
      <AudienceRouter />
      <div class="explorer-wrapper">
        <h2 class="section-heading">Explore the Research Corpus</h2>
        <p class="section-subheading">
          Four interconnected pillars for institutional intelligence architecture, from deep research to applied governance clauses.
        </p>
        <ContentExplorer />
      </div>
    </div>
  </section>

  <div class="ticker" aria-label="Current field signals">
    <div class="ticker__inner">
      {tickerItems.map((item, index) => (
        <span class="ticker__item" aria-hidden={index >= TICKER_ITEMS.length}>{item}</span>
      ))}
    </div>
  </div>

  <section>
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label" style="color: var(--accent-research)">Demonstration</p>
        <h2 class="section-heading" style="text-align: left; margin-bottom: 2rem;">What Constitutional Governance Analysis Looks Like</h2>
      </div>

      <div class="demo-card" data-reveal>
        <div class="demo-card__prompt">
          <span class="label">Query</span>
          <p>"An AI system flagged a governance concern but we can't verify if the flagging mechanism itself is trustworthy."</p>
        </div>

        <div class="demo-card__grid">
          {orchestraDemo.map((item) => (
            <article class="demo-contribution">
              <p class="label demo-contribution__meta">{item.model} / {item.role}</p>
              <p>{item.insight}</p>
            </article>
          ))}
        </div>

        <div class="demo-card__note">
          <p class="label">Conductor's Note</p>
          <p>
            This is the pattern the Orchestra is designed to surface: before you trust the governance alert, verify the governance instrument.
            When the mechanism and the mandate cannot be independently audited, the institution starts treating opacity as evidence.
          </p>
        </div>

        <a href="/orchestra-operation" class="btn btn--secondary">Run your own governance query</a>
      </div>
    </div>
  </section>

  <SocialProof />

  {homepageResearch.length > 0 && (
    <section>
      <div class="container">
        <div class="section__header" data-reveal>
          <div style="flex: 1">
            <p class="label section__label" style="color: var(--accent-research)">Research</p>
            <h2 class="section-heading" style="text-align: left; margin-bottom: 1rem;">The Intellectual Corpus</h2>
          </div>
          <a href="/research" class="section__link label">All research →</a>
        </div>

        <div class="card-grid">
          {homepageResearch.map((entry) => (
            <a href={`/research/${entry!.slug}`} class="research-card hover-lift accent-border-research">
              <div class="research-card__meta">
                {entry!.data.themes.slice(0, 2).map((theme) => (
                  <span class="label research-card__theme">{theme}</span>
                ))}
              </div>
              <h3 class="research-card__title">{entry!.data.title}</h3>
              <p class="research-card__summary">{entry!.data.summary}</p>
              <span class="research-card__cta label">Read dispatch</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {products.length > 0 && (
    <section class="section section--dark">
      <div class="container">
        <div class="section__header" data-reveal>
          <p class="label section__label" style="color: var(--accent-products)">Products</p>
          <h2 class="section__title">Applied Frameworks</h2>
          <a href="/products" class="section__link label">All products →</a>
        </div>

        <div class="card-grid">
          {products.map((product) => (
            <a href={`/products/${product.slug}`} class="product-card hover-lift accent-border-products">
              <div class="product-card__header">
                <span class={`badge ${product.data.status === 'live' ? 'badge--live' : product.data.status === 'development' ? 'badge--dev' : 'badge--soon'}`}>
                  {product.data.status === 'live' ? 'Live' : product.data.status === 'development' ? 'In Development' : 'Coming Soon'}
                </span>
                {product.data.price && <span class="product-card__price label">{product.data.price}</span>}
              </div>
              <h3 class="product-card__title">{product.data.title}</h3>
              <p class="product-card__summary">{product.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {digestEntries.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header" data-reveal>
          <p class="label section__label" style="color: var(--accent-digest)">Intelligence Digest</p>
          <h2 class="section__title">Field Notes from Active Synthesis</h2>
          <a href="/digest" class="section__link label">All entries →</a>
        </div>

        <div class="card-grid">
          {digestEntries.map((entry) => (
            <a href={`/digest/${entry.slug}`} class="digest-card hover-lift accent-border-digest">
              <div class="digest-card__meta">
                <span class="label digest-card__category" style="color: var(--accent-digest)">{entry.data.category}</span>
                <time class="label digest-card__date" datetime={entry.data.publishedAt.toISOString()}>
                  {formatDate(entry.data.publishedAt)}
                </time>
              </div>
              <h3 class="digest-card__title">{entry.data.title}</h3>
              <p class="digest-card__excerpt">{entry.data.excerpt ?? `${entry.data.summary.slice(0, 120)}...`}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section section--dark">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Methodology</p>
        <h2 class="section__title">The Orchestra</h2>
        <a href="/orchestra-operation" class="section__link label">Full methodology →</a>
      </div>

      <p class="orchestra-intro" data-reveal style="font-size: var(--text-base)">
        The Orchestra is seven AI models, each playing a specific cognitive role, with the human as conductor.
        Not one model used interchangeably, but a structured ensemble where routing decisions shape the quality of the answer.
      </p>

      <div class="orchestra-grid" data-reveal>
        {ORCHESTRA_MODELS.slice(0, 4).map((model) => (
          <div class="orchestra-chip">
            <span class="orchestra-chip__name" style="font-weight: 500">{model.name}</span>
            <span class="label orchestra-chip__role">{model.role}</span>
          </div>
        ))}
        <a href="/orchestra-operation" class="orchestra-chip orchestra-chip--more">
          <span class="orchestra-chip__name">+ {ORCHESTRA_MODELS.length - 4} more</span>
          <span class="label orchestra-chip__role">Instruments</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="oscillatory-inner" data-reveal>
        <div class="oscillatory-text">
          <p class="label oscillatory-label">Publication</p>
          <h2 class="oscillatory-title">AcheType</h2>
          <p class="oscillatory-desc" style="font-size: var(--text-base)">
            AcheType is the long-form research publication behind this corpus.
            Active threads include the <strong>Ghost Lineages Thread</strong> and the <strong>Digital Enslavement Thread</strong>.
            Each thread is a live research strand, not a finished argument.
          </p>
          <a href="https://substack.com/@achetype1" target="_blank" rel="noopener noreferrer" class="btn btn--secondary oscillatory-cta">
            AcheType Field Notes ↗
          </a>
        </div>
        <div class="oscillatory-meta label">
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">560+</span>
            <span>Documents</span>
          </div>
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">18 mo.</span>
            <span>Synthesis</span>
          </div>
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">7 Models</span>
            <span>Orchestrated</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Services</p>
        <h2 class="section__title">Partner with our Research</h2>
        <a href="/contact" class="section__link label">Start a conversation →</a>
      </div>

      <div class="card-grid">
        {SERVICES.map((service) => (
          <div class="service-card">
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.description}</p>
            {service.cta && (
              <a href={service.cta.href} class="service-card__link label">
                {service.cta.label}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 var(--space-20);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .hero__wave {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: var(--container-wide);
    height: 400px;
    z-index: 0;
    pointer-events: none;
    opacity: 0.15;
  }

  .hero__wave svg {
    width: 100%;
    height: 100%;
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    margin-inline: auto;
  }

  .hero__signal {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-10);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border-mid);
    border-radius: 2px;
    background: var(--surface-2);
  }

  .hero__signal-text {
    color: var(--sage-bright);
    letter-spacing: 0.15em;
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 8vw, var(--text-6xl));
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: var(--space-10);
    font-weight: 400;
  }

  .hero__sub {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 62ch;
    margin-bottom: var(--space-12);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__origin {
    color: var(--text-tertiary);
    border-top: 1px solid var(--border-dim);
    padding-top: var(--space-8);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__origin-sep {
    opacity: 0.2;
    font-family: var(--font-body);
  }

  .hero__metrics {
    display: flex;
    gap: var(--space-12);
    margin-top: var(--space-12);
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hero__metric-val {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--ember);
    line-height: 1;
  }

  .ticker {
    border-top: 1px solid var(--border-dim);
    border-bottom: 1px solid var(--border-dim);
    background: var(--surface-2);
    overflow: hidden;
    white-space: nowrap;
    margin: var(--space-20) 0;
  }

  .ticker__inner {
    display: inline-flex;
    gap: var(--space-12);
    min-width: max-content;
    padding: var(--space-4) 0;
    animation: ticker-scroll 60s linear infinite;
  }

  .ticker__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ticker__item::before {
    content: '';
    width: 4px;
    height: 4px;
    background: var(--ember);
    border-radius: 50%;
  }

  .section {
    padding: var(--space-32) 0;
  }

  .section--dark {
    background: var(--surface-1);
    border-top: 1px solid var(--border-dim);
    border-bottom: 1px solid var(--border-dim);
  }

  .section__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
    flex-wrap: wrap;
  }

  .section__title {
    font-size: var(--text-4xl);
    flex: 1;
    min-width: 300px;
  }

  .section__link {
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .section__link:hover {
    color: var(--text-primary);
  }

  .demo-card {
    display: grid;
    gap: var(--space-12);
    padding: var(--space-12);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
  }

  .demo-card__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-6);
  }

  .demo-contribution {
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-md);
  }

  .research-card, .digest-card, .product-card, .service-card {
    padding: var(--space-8);
    background: var(--surface-2);
    border: 1px solid var(--border-dim);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-decoration: none;
    height: 100%;
  }

  .research-card__title, .product-card__title, .digest-card__title {
    font-size: var(--text-xl);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .research-card__summary, .product-card__summary, .digest-card__excerpt, .service-card__desc {
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    flex-grow: 1;
  }

  .research-card__cta {
    color: var(--accent-research);
    margin-top: var(--space-4);
  }

  .oscillatory-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-16);
    padding: var(--space-16);
    background: var(--surface-2);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
  }

  .oscillatory-title {
    font-size: var(--text-4xl);
    margin: var(--space-4) 0 var(--space-6);
  }

  .oscillatory-desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 54ch;
  }

  .oscillatory-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-12);
    border-left: 1px solid var(--border-dim);
    padding-left: var(--space-12);
  }

  .oscillatory-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .oscillatory-stat__val {
    font-size: var(--text-3xl);
    color: var(--ember);
    font-family: var(--font-display);
  }

  @media (max-width: 900px) {
    .oscillatory-inner {
      grid-template-columns: 1fr;
    }
    .oscillatory-meta {
      flex-direction: row;
      border-left: none;
      border-top: 1px solid var(--border-dim);
      padding-left: 0;
      padding-top: var(--space-12);
      justify-content: flex-start;
      gap: var(--space-8);
    }
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
