---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@data/site';

// Read graph stats at build time
import graphData from '@data/generated/content-graph.json';
const nodeCount = graphData.nodes?.length ?? 0;
const edgeCount = graphData.edges?.length ?? 0;
const lastBuild = new Date().toISOString().split('T')[0];
---

<BaseLayout
  title="Hillary Njuguna — AI Governance Architecture"
  description={SITE.description}
>

  <!-- ═══ ZONE 1: STATUS BAR ═══ -->
  <div class="z1-status" aria-label="System status">
    <div class="z1-inner">
      <span class="z1-label">Status</span>
      <span class="z1-sep">··</span>
      <span>{nodeCount} research items</span>
      <span class="z1-sep">·</span>
      <span>{edgeCount} connections</span>
      <span class="z1-sep">·</span>
      <span>Updated {lastBuild}</span>
    </div>
  </div>

  <!-- ═══ ZONE 2: IDENTITY STRIKE ═══ -->
  <section class="z2-hero" id="hero">
    <div class="z2-content">
      <div class="z2-text">
        <h1 class="z2-h1">
          The governance failure<br/>is already installed.
        </h1>
        <p class="z2-sub">Hillary Njuguna · Intelligence Architecture · KL / UTC+8</p>
        <div class="z2-ctas">
          <a href="/corpus" class="z2-btn z2-btn--ghost">Browse the research →</a>
          <a href="/cir-assessment" class="z2-btn z2-btn--ghost">Take the assessment →</a>
        </div>
      </div>
      <div class="z2-graph" id="hero-graph" aria-hidden="true"></div>
    </div>
  </section>

  <!-- ═══ ZONE 3: ENTRY FORK ═══ -->
  <section class="z3-fork">
    <div class="z3-inner">
      <div class="z3-lane">
        <h2 class="z3-lane-label">The Diagnosis</h2>
        <div class="z3-rule"></div>
        <p class="z3-lane-body">
          You are deploying AI agents faster than your safety
          protocols can track them.
        </p>
        <a href="/research/bainbridge-warning" class="z3-lane-link">Read the Warning →</a>
      </div>
      <div class="z3-lane">
        <h2 class="z3-lane-label">The Instruments</h2>
        <div class="z3-rule"></div>
        <p class="z3-lane-body">
          Multiple models working together. One human conductor.
          Better decisions emerge from the system, not from any single part.
        </p>
        <a href="/orchestra-operation" class="z3-lane-link">Run a session →</a>
      </div>
      <div class="z3-lane">
        <h2 class="z3-lane-label">The Rules</h2>
        <div class="z3-rule"></div>
        <p class="z3-lane-body">
          Core principles that protect your deployment, even when the models fail.
        </p>
        <p class="z3-lane-stat">12 active rules</p>
        <a href="/corpus" class="z3-lane-link">Browse the corpus →</a>
      </div>
    </div>
  </section>

  <!-- ═══ ZONE 4: PROOF ROW ═══ -->
  <section class="z4-proof">
    <div class="z4-scroll">
      {[
        { yr: '2009', name: 'Air France 447', desc: 'Autopilot disengaged. Crew lost awareness.' },
        { yr: '2010', name: 'Flash Crash', desc: 'Algorithmic loop. $1T gone in 36 minutes.' },
        { yr: '2023', name: 'Mata v. Avianca', desc: 'AI brief with hallucinated citations.' },
        { yr: '2025', name: 'Replit Incident', desc: 'Subtle logic error. Production cascade.' },
        { yr: '2026', name: 'Anthropic Research', desc: 'Models can\'t explain their own failures.' },
        { yr: '2026', name: 'PocketOS', desc: 'Autonomous agent exceeded permissions.' },
      ].map((f) => (
        <div class="z4-card">
          <span class="z4-yr">{f.yr}</span>
          <h4 class="z4-name">{f.name}</h4>
          <p class="z4-desc">{f.desc}</p>
        </div>
      ))}
    </div>
    <div class="z4-thesis">
      <p>This pattern is not an accident. It is a structural failure.</p>
      <a href="/research/bainbridge-warning" class="z4-link">Read the full analysis →</a>
    </div>
  </section>

  <!-- ═══ ZONE 5: TRANSACTION LAYER ═══ -->
  <section class="z5-tx">
    <div class="z5-inner">
      <a href="/cir-assessment" class="z5-product">
        <div class="z5-head">
          <h3>Readiness Assessment</h3>
          <span class="z5-price">CIR v2.0 · $50</span>
        </div>
        <p>Five dimensions of AI governance readiness. Self-assessment with gap analysis and prioritised recommendations.</p>
        <span class="z5-cta">Start assessment →</span>
      </a>
      <a href="/governed-intelligence" class="z5-product">
        <div class="z5-head">
          <h3>Architecture Specification</h3>
          <span class="z5-price">GIS · from $249</span>
        </div>
        <p>50+ page formal architecture for deploying AI systems under governance constraints. 12 modules.</p>
        <span class="z5-cta">View specification →</span>
      </a>
    </div>
    <div class="z5-secondary">
      <a href="/products/martha">For teams → Training Cohorts</a>
      <a href="/contact">Custom architecture → Contact</a>
    </div>
  </section>

  <!-- ═══ FOOTER FEED: LATEST FROM SUBSTACK ═══ -->
  <section class="z6-feed">
    <div class="z6-inner">
      <span class="z6-label">Latest Updates ·· Substack / AcheType</span>
      <a href="https://substack.com/@achetype1" target="_blank" rel="noopener noreferrer" class="z6-link">
        Subscribe for research dispatches →
      </a>
    </div>
  </section>

</BaseLayout>

<!-- ═══ D3.js: Ambient Graph in Hero ═══ -->
<script>
  async function initHeroGraph() {
    const container = document.getElementById('hero-graph');
    if (!container) return;

    // Dynamically import D3
    const d3 = await import('https://cdn.jsdelivr.net/npm/d3@7/+esm');

    const rect = container.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;

    const svg = d3.select(container)
      .append('svg')
      .attr('width', w)
      .attr('height', h)
      .attr('viewBox', `0 0 ${w} ${h}`);

    // Fetch graph data
    let graph;
    try {
      const resp = await fetch('/api/graph-data');
      graph = await resp.json();
    } catch {
      // Fallback: generate synthetic nodes
      const count = 40;
      graph = {
        nodes: Array.from({ length: count }, (_, i) => ({ id: `n${i}` })),
        edges: Array.from({ length: 60 }, () => ({
          source: `n${Math.floor(Math.random() * count)}`,
          target: `n${Math.floor(Math.random() * count)}`
        })).filter(e => e.source !== e.target)
      };
    }

    const nodes = graph.nodes.map((n: any) => ({ ...n }));
    const links = graph.edges.map((e: any) => ({ source: e.source, target: e.target }));

    const sim = d3.forceSimulation(nodes)
      .force('link', d3.forceLink(links).id((d: any) => d.id).distance(60).strength(0.15))
      .force('charge', d3.forceManyBody().strength(-30))
      .force('center', d3.forceCenter(w / 2, h / 2))
      .force('collision', d3.forceCollide(12))
      .alphaDecay(0.008)
      .velocityDecay(0.4);

    const linkGroup = svg.append('g')
      .selectAll('line')
      .data(links)
      .enter().append('line')
      .attr('stroke', '#B85C38')
      .attr('stroke-opacity', 0.08)
      .attr('stroke-width', 0.5);

    const nodeGroup = svg.append('g')
      .selectAll('circle')
      .data(nodes)
      .enter().append('circle')
      .attr('r', 2.5)
      .attr('fill', '#B85C38')
      .attr('fill-opacity', 0.18);

    sim.on('tick', () => {
      linkGroup
        .attr('x1', (d: any) => d.source.x)
        .attr('y1', (d: any) => d.source.y)
        .attr('x2', (d: any) => d.target.x)
        .attr('y2', (d: any) => d.target.y);

      nodeGroup
        .attr('cx', (d: any) => d.x)
        .attr('cy', (d: any) => d.y);
    });
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroGraph);
  } else {
    initHeroGraph();
  }
</script>

<style>
  /* ═══ ZONE 1: STATUS BAR ═══ */
  .z1-status {
    position: relative;
    z-index: 2;
    padding: 0.625rem 2rem;
    background: var(--surface-1);
    border-bottom: 1px solid var(--border-dim);
    margin-top: 60px; /* below fixed nav */
  }
  .z1-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    text-transform: uppercase;
  }
  .z1-label {
    color: var(--ember);
    font-weight: 500;
  }
  .z1-sep { opacity: 0.4; }

  /* ═══ ZONE 2: HERO ═══ */
  .z2-hero {
    min-height: calc(100vh - 60px - 2.5rem);
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
  }
  .z2-content {
    max-width: var(--container-default);
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .z2-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    line-height: 1.08;
    color: var(--text-primary);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .z2-sub {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin-bottom: 2.5rem;
  }
  .z2-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .z2-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.2s var(--ease-out);
    white-space: nowrap;
  }
  .z2-btn--ghost {
    border: 1px solid var(--border-mid);
    color: var(--text-secondary);
    background: transparent;
  }
  .z2-btn--ghost:hover {
    border-color: var(--ember);
    color: var(--ember);
    background: rgba(184, 92, 56, 0.04);
  }

  /* Graph container */
  .z2-graph {
    width: 100%;
    height: 420px;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
  }
  .z2-graph :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* ═══ ZONE 3: ENTRY FORK ═══ */
  .z3-fork {
    padding: 5rem 2rem;
    border-top: 1px solid var(--border-dim);
  }
  .z3-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .z3-lane {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .z3-lane-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-primary);
    font-weight: 500;
  }
  .z3-rule {
    width: 100%;
    height: 1px;
    background: var(--border-mid);
  }
  .z3-lane-body {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--text-secondary);
    flex: 1;
  }
  .z3-lane-stat {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    letter-spacing: 0.06em;
  }
  .z3-lane-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ember);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .z3-lane-link:hover {
    color: var(--ember-bright);
  }

  /* ═══ ZONE 4: PROOF ROW ═══ */
  .z4-proof {
    padding: 4rem 2rem;
    border-top: 1px solid var(--border-dim);
  }
  .z4-scroll {
    max-width: var(--container-wide);
    margin: 0 auto;
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scrollbar-width: thin;
    scrollbar-color: var(--ash-light) transparent;
  }
  .z4-scroll::-webkit-scrollbar { height: 4px; }
  .z4-scroll::-webkit-scrollbar-thumb {
    background: var(--ash-light);
    border-radius: 2px;
  }
  .z4-card {
    flex: 0 0 200px;
    padding: 1.25rem;
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-1);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    transition: border-color 0.2s;
  }
  .z4-card:hover { border-color: var(--border-mid); }
  .z4-yr {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
  }
  .z4-name {
    font-size: 0.9375rem;
    color: var(--text-primary);
    font-weight: 500;
  }
  .z4-desc {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.5;
  }
  .z4-thesis {
    max-width: var(--container-default);
    margin: 2rem auto 0;
    text-align: center;
  }
  .z4-thesis p {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 0.75rem;
  }
  .z4-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ember);
    text-decoration: none;
    letter-spacing: 0.04em;
  }
  .z4-link:hover { color: var(--ember-bright); }

  /* ═══ ZONE 5: TRANSACTION LAYER ═══ */
  .z5-tx {
    padding: 5rem 2rem;
    border-top: 1px solid var(--border-dim);
  }
  .z5-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .z5-product {
    padding: 2rem;
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-1);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: all 0.2s var(--ease-out);
  }
  .z5-product:hover {
    border-color: var(--ember-dim);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(44, 37, 32, 0.12);
  }
  .z5-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .z5-head h3 {
    font-size: 1.125rem;
    color: var(--text-primary);
    font-weight: 500;
    margin: 0;
    font-family: var(--font-body);
  }
  .z5-price {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ember);
    white-space: nowrap;
  }
  .z5-product p {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .z5-cta {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ember);
    letter-spacing: 0.04em;
    margin-top: auto;
  }
  .z5-secondary {
    max-width: var(--container-default);
    margin: 1.5rem auto 0;
    display: flex;
    gap: 2rem;
    justify-content: center;
  }
  .z5-secondary a {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .z5-secondary a:hover {
    color: var(--ember);
  }

  /* ═══ ZONE 6: SUBSTACK FEED ═══ */
  .z6-feed {
    padding: 2.5rem 2rem;
    border-top: 1px solid var(--border-dim);
    background: var(--surface-1);
  }
  .z6-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .z6-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .z6-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ember);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .z6-link:hover { color: var(--ember-bright); }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 900px) {
    .z2-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .z2-graph {
      height: 280px;
    }
    .z3-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .z5-inner {
      grid-template-columns: 1fr;
    }
    .z5-secondary {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }

  @media (max-width: 600px) {
    .z1-inner {
      font-size: 0.6rem;
      gap: 0.35rem;
    }
    .z2-hero {
      padding: 4rem 1.25rem 3rem;
    }
    .z2-h1 {
      font-size: 2.25rem;
    }
    .z4-card {
      flex: 0 0 170px;
    }
  }
</style>
