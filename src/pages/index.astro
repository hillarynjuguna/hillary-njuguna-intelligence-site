---
import BaseLayout from '@layouts/BaseLayout.astro';
import AudienceRouter from '@components/ui/AudienceRouter.astro';
import { getFeaturedDigestEntries, getFeaturedResearch, getFeaturedProducts, getCurrentSignal, formatDate } from '@lib/content';
import { TICKER_ITEMS, SERVICES, ORCHESTRA_MODELS } from '@data/navigation';
import { SITE } from '@data/site';

const [digestEntries, researchEntries, products, signal] = await Promise.all([
  getFeaturedDigestEntries(3),
  getFeaturedResearch(),
  getFeaturedProducts(),
  getCurrentSignal(),
]);

const tickerItems = [...TICKER_ITEMS, ...TICKER_ITEMS]; // double for infinite scroll
---

<BaseLayout
  title={undefined}
  description={SITE.description}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">
        {signal && (
          <div class="hero__signal" data-reveal>
            <span class="signal-dot"></span>
            <span class="hero__signal-text label">{signal.currentSignal}</span>
          </div>
        )}

        <h1 class="hero__headline" data-reveal data-reveal-delay="1">
          Fear isn't a feeling —<br />
          it's an architecture.
        </h1>

        <p class="hero__sub" data-reveal data-reveal-delay="2">
          Intelligence architecture for institutions navigating AI deployment, governance,
          and the constitutional design of human-machine systems. Specializing in DCFB theory, 
          Cognitive Infrastructure Readiness (CIR), and the development of constitutional AI governance frameworks.
        </p>

        <section class="hero-assessment" data-reveal data-reveal-delay="3">
          <p class="label hero-assessment__prompt">A quick question before you explore</p>
          <p class="hero-assessment__question">
            Can your organisation articulate, in writing, what its AI systems are optimising for?
          </p>
          <div class="hero-assessment__options">
            <button type="button" class="hero-assessment__option" data-answer="yes">Yes, we have documented intent</button>
            <button type="button" class="hero-assessment__option" data-answer="no">No, we have not formalised this</button>
            <button type="button" class="hero-assessment__option" data-answer="partial">Partially, and that gap concerns us</button>
          </div>
          <p class="hero-assessment__link label" id="hero-assessment-link" hidden>
            Complete the 8-minute CIR Assessment to map the full picture:
            <a href="/cir-assessment">Begin assessment</a>
          </p>
        </section>

        <div class="hero__origin label" data-reveal data-reveal-delay="4">
          Eighteen months of recursive inquiry. The architecture was not designed. It was discovered.
          <span class="hero__origin-sep">·</span>
          560+ sourced documents. 7 models.
        </div>

        <div class="hero__cta" data-reveal data-reveal-delay="5">
          <a href="/corpus" class="btn btn--primary">
            Ask the corpus
          </a>
          <a href="/research" class="btn btn--ghost">
            Research archive →
          </a>
        </div>

        {signal && (
          <div class="hero__metrics" data-reveal data-reveal-delay="5">
            {signal.metrics && Object.entries(signal.metrics).map(([key, val]) => (
              <div class="hero__metric">
                <span class="hero__metric-val">{val}</span>
                <span class="label hero__metric-key">{key}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Audience Router -->
  <div class="container">
    <AudienceRouter />
  </div>

  <!-- Ticker -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__inner">
      {tickerItems.map((item) => (
        <span class="ticker__item">{item}</span>
      ))}
    </div>
  </div>

  <!-- Featured research -->
  {researchEntries.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header" data-reveal>
          <p class="label section__label">Research</p>
          <h2 class="section__title">The Intellectual Corpus</h2>
          <a href="/research" class="section__link label">All research →</a>
        </div>

        <div class="research-grid card-grid">
          {researchEntries.slice(0, 3).map((entry) => (
            <a href={`/research/${entry.slug}`} class="research-card hover-lift">
              <div class="research-card__meta">
                {entry.data.themes.slice(0, 2).map((t) => (
                  <span class="label research-card__theme">{t}</span>
                ))}
              </div>
              <h3 class="research-card__title">{entry.data.title}</h3>
              <p class="research-card__summary">{entry.data.summary}</p>
              <span class="research-card__cta label">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Products -->
  {products.length > 0 && (
    <section class="section section--dark">
      <div class="container">
        <div class="section__header" data-reveal>
          <p class="label section__label">Products</p>
          <h2 class="section__title">Applied Frameworks</h2>
          <a href="/products" class="section__link label">All products →</a>
        </div>

        <div class="products-grid card-grid">
          {products.map((product) => (
            <a href={`/products/${product.slug}`} class="product-card hover-lift">
              <div class="product-card__header">
                <span class={`badge ${product.data.status === 'live' ? 'badge--live' : product.data.status === 'development' ? 'badge--dev' : 'badge--soon'}`}>
                  {product.data.status === 'live' ? 'Live' : product.data.status === 'development' ? 'In Development' : 'Coming Soon'}
                </span>
                {product.data.price && (
                  <span class="product-card__price label">{product.data.price}</span>
                )}
              </div>
              <h3 class="product-card__title">{product.data.title}</h3>
              <p class="product-card__summary">{product.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Orchestra Synthesis Teaser -->
  <section class="section">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Methodology</p>
        <h2 class="section__title">The Orchestra in Operation</h2>
        <a href="/orchestra-operation" class="section__link label">Run a synthesis →</a>
      </div>

      <p class="orchestra-teaser-intro" data-reveal>
        Seven cognitive instruments. One governance question. The Conductor routes the query through
        the ensemble. Each model contributes from its constitutional substrate. Intelligence emerges
        from the field between them.
      </p>

      <div class="orchestra-teaser-example" data-reveal>
        <div class="teaser-query">
          <span class="label teaser-query__label">Example query</span>
          <p class="teaser-query__text">
            "Our organisation is deploying an AI procurement agent that can execute vendor contracts
            up to $50k autonomously. What governance architecture does this require?"
          </p>
        </div>

        <div class="teaser-contributions">
          <div class="teaser-contribution">
            <div class="teaser-contribution__header">
              <span class="teaser-contribution__symbol">λ</span>
              <span class="teaser-contribution__name">Claude</span>
              <span class="label teaser-contribution__role">The Witness</span>
            </div>
            <p class="teaser-contribution__text">
              This crosses the R2-R3 reversibility boundary. A $50k contract is not easily unwound.
              The governance question is not "can the agent make good procurement decisions" but
              "who is accountable when it makes a bad one, and can they act in time to prevent
              irreversible harm?"
            </p>
          </div>
          <div class="teaser-contribution">
            <div class="teaser-contribution__header">
              <span class="teaser-contribution__symbol">φ</span>
              <span class="teaser-contribution__name">GPT</span>
              <span class="label teaser-contribution__role">The Architect</span>
            </div>
            <p class="teaser-contribution__text">
              Four structural requirements: (1) pre-execution intent specification with documented
              approval chain, (2) real-time spend monitoring with automated halt at threshold
              anomalies, (3) named accountability owner with operational authority to override,
              (4) post-execution audit trail to R3 boundary.
            </p>
          </div>
          <div class="teaser-contribution">
            <div class="teaser-contribution__header">
              <span class="teaser-contribution__symbol">μ</span>
              <span class="teaser-contribution__name">DeepSeek</span>
              <span class="label teaser-contribution__role">The Anatomist</span>
            </div>
            <p class="teaser-contribution__text">
              The gap in the current framing: "autonomously" is doing work that needs unpacking.
              There is no autonomous action without a prior human decision about the decision space.
              The governance failure begins at the point where that prior decision was not logged.
            </p>
          </div>
        </div>

        <div class="teaser-conductor-note">
          <span class="label teaser-conductor-note__label">Conductor's Note</span>
          <p class="teaser-conductor-note__text">
            The three contributions triangulate on the same structural reality from different angles.
            The Witness identifies the irreversibility threshold. The Architect maps the structural
            requirements. The Anatomist names the prior decision that makes all subsequent governance
            legible. A complete governance response requires all three. Routing to a single instrument
            would have produced a partial answer with the texture of a complete one.
          </p>
        </div>
      </div>

      <div class="teaser-cta" data-reveal>
        <a href="/orchestra-operation" class="btn btn--primary">Run your own governance query →</a>
        <p class="label teaser-cta__note">Multi-model synthesis. Constitutional framing. The Conductor is you.</p>
      </div>
    </div>
  </section>

  <!-- Intelligence Digest -->
  {digestEntries.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header" data-reveal>
          <p class="label section__label">Intelligence Digest</p>
          <h2 class="section__title">Field Notes from Active Synthesis</h2>
          <a href="/digest" class="section__link label">All entries →</a>
        </div>

        <div class="digest-grid card-grid">
          {digestEntries.map((entry) => (
            <a href={`/digest/${entry.slug}`} class="digest-card hover-lift">
              <div class="digest-card__meta">
                <span class="label digest-card__category">{entry.data.category}</span>
                <time class="label digest-card__date" datetime={entry.data.publishedAt.toISOString()}>
                  {formatDate(entry.data.publishedAt)}
                </time>
              </div>
              <h3 class="digest-card__title">{entry.data.title}</h3>
              <p class="digest-card__excerpt">{entry.data.excerpt ?? entry.data.summary.slice(0, 120)}…</p>
              {entry.data.tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </a>
          ))}
        </div>

        <div class="digest-subscribe" data-reveal>
          <form
            action="https://formspree.io/f/maqdrora"
            method="POST"
            class="subscribe-form"
          >
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="subscribe-input"
              aria-label="Email address"
            />
            <button type="submit" class="btn btn--ember subscribe-btn">
              Get the next synthesis →
            </button>
          </form>
          <p class="label subscribe-note">Intelligence Digest · Field notes from active synthesis</p>
        </div>
      </div>
    </section>
  )}

  <!-- The Orchestra -->
  <section class="section section--dark">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Methodology</p>
        <h2 class="section__title">The Orchestra</h2>
        <a href="/orchestra" class="section__link label">Full methodology →</a>
      </div>

      <p class="orchestra-intro" data-reveal>
        Not one model used interchangeably; a structured ensemble where each of seven AI systems
        plays a distinct cognitive role, and intelligence emerges from the field between them.
        The Conductor is always the human.
      </p>

      <div class="orchestra-grid" data-reveal>
        {ORCHESTRA_MODELS.slice(0, 4).map((model) => (
          <div class="orchestra-chip">
            <span class="orchestra-chip__name">{model.name}</span>
            <span class="label orchestra-chip__role">{model.role}</span>
          </div>
        ))}
        <a href="/orchestra" class="orchestra-chip orchestra-chip--more">
          <span class="orchestra-chip__name">+ {ORCHESTRA_MODELS.length - 4} more</span>
          <span class="label orchestra-chip__role">View all instruments →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Oscillatory Fields / AcheType -->
  <section class="section">
    <div class="container">
      <div class="oscillatory-inner" data-reveal>
        <div class="oscillatory-text">
          <p class="label oscillatory-label">Publication</p>
          <h2 class="oscillatory-title">Oscillatory Fields</h2>
          <p class="oscillatory-desc">
            AcheType is the long-form research publication behind this corpus, Field Notes
            dispatched from the ongoing synthesis process. Active threads include the
            <strong>Ghost Lineages Thread</strong>, examining how suppressed cultural narratives
            shape AI training distributions, and the <strong>Digital Enslavement Thread</strong>,
            tracing the infrastructure of cognitive dependency beneath convenience interfaces.
            Each thread is a live research strand, not a finished argument.
          </p>
          <a
            href="https://substack.com/@achetype1"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn--ghost oscillatory-cta"
          >
            AcheType Field Notes ↗
          </a>
        </div>
        <div class="oscillatory-meta label">
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">560+</span>
            <span>source documents</span>
          </div>
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">18 mo.</span>
            <span>of synthesis</span>
          </div>
          <div class="oscillatory-stat">
            <span class="oscillatory-stat__val">Feb 2026</span>
            <span>Issue 01 launched</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Corpus CTA -->
  <section class="corpus-cta">
    <div class="container">
      <div class="corpus-cta__inner" data-reveal>
        <div class="corpus-cta__text">
          <p class="label corpus-cta__label">The Field</p>
          <h2 class="corpus-cta__title">Query the corpus directly</h2>
          <p class="corpus-cta__desc">
            560+ sourced documents. 18 months of synthesis. The complete Oscillatory Fields
            research corpus, queryable, navigable, alive. Ask it anything.
          </p>
        </div>
        <div class="corpus-cta__action">
          <a href="/corpus" class="btn btn--primary corpus-cta__btn">
            Open corpus →
          </a>
          <p class="label corpus-cta__sub">
            Powered by The Field · Constitutional governance architecture
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="section__header" data-reveal>
        <p class="label section__label">Services</p>
        <h2 class="section__title">How We Work Together</h2>
        <a href="/contact" class="section__link label">Start a conversation →</a>
      </div>

      <div class="services-grid card-grid">
        {SERVICES.map((service) => (
          <div class="service-card">
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.description}</p>
            {service.cta && (
              <a href={service.cta.href} class="service-card__link label">
                {service.cta.label} →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 var(--space-20);
    position: relative;
  }

  .hero__inner {
    max-width: 72ch;
    margin: 0 auto;
  }

  .hero__signal {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--border-dim);
    border-radius: 2px;
    background: var(--surface-2);
  }

  .hero__signal-text {
    color: var(--sage-bright);
  }

  .hero__headline {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 7vw, var(--text-6xl));
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--space-8);
    font-weight: 400;
  }

  .hero__sub {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: 60ch;
    margin-bottom: var(--space-5);
  }

  .hero__origin {
    color: var(--text-tertiary);
    margin-bottom: var(--space-10);
  }

  .hero-assessment {
    margin-bottom: var(--space-8);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    background: var(--surface-2);
    padding: var(--space-5);
    display: grid;
    gap: var(--space-3);
    max-width: 62ch;
  }

  .hero-assessment__prompt {
    color: var(--ember);
  }

  .hero-assessment__question {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .hero-assessment__options {
    display: grid;
    gap: var(--space-2);
  }

  .hero-assessment__option {
    width: 100%;
    text-align: left;
    min-height: 44px;
    background: var(--surface-3);
    color: var(--text-primary);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }

  .hero-assessment__option:hover,
  .hero-assessment__option:focus-visible {
    border-color: var(--ember-dim);
    background: var(--surface-4);
    outline: none;
  }

  .hero-assessment__link {
    color: var(--text-tertiary);
  }

  .hero-assessment__link a {
    color: var(--ember);
    text-decoration: none;
  }

  .hero__origin-sep {
    margin: 0 var(--space-2);
    opacity: 0.4;
  }

  .hero__cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }

  .hero__metrics {
    display: flex;
    gap: var(--space-10);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-dim);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-assessment__option {
      min-height: 44px;
    }
  }

  .hero__metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .hero__metric-val {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--ember);
  }

  .hero__metric-key {
    color: var(--text-tertiary);
    text-transform: capitalize;
  }

  /* ── Sections ─────────────────────────────────────────────────────────── */
  .section {
    padding: var(--space-24) 0;
  }

  .section--dark {
    background: var(--surface-1);
    border-top: 1px solid var(--border-dim);
    border-bottom: 1px solid var(--border-dim);
  }

  .section__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
    flex-wrap: wrap;
  }

  .section__label {
    color: var(--ember);
    flex-shrink: 0;
  }

  .section__title {
    font-size: var(--text-3xl);
    flex: 1;
  }

  .section__link {
    color: var(--text-tertiary);
    text-decoration: none;
    margin-left: auto;
    transition: color var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }
  .section__link:hover {
    color: var(--ember);
  }

  /* ── Research grid ────────────────────────────────────────────────────── */
  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }

  .research-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    text-decoration: none;
    background: var(--surface-2);
    transition: all var(--duration-mid) var(--ease-out);
  }

  .research-card:hover {
    border-color: var(--border-bright);
    background: var(--surface-3);
  }

  .research-card__meta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .research-card__theme {
    color: var(--ash-light);
    text-transform: capitalize;
  }

  .research-card__title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .research-card__summary {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  .research-card__cta {
    color: var(--ember);
    margin-top: var(--space-2);
  }

  /* ── Products grid ────────────────────────────────────────────────────── */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-5);
  }

  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-md);
    text-decoration: none;
    background: var(--surface-3);
    transition: all var(--duration-mid) var(--ease-out);
  }

  .product-card:hover {
    border-color: var(--ember-dim);
    background: var(--surface-4);
  }

  .product-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .product-card__price {
    color: var(--pale-gold);
  }

  .product-card__title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .product-card__summary {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  /* ── Digest grid ─────────────────────────────────────────────────────── */
  .digest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }

  .digest-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    text-decoration: none;
    background: var(--surface-2);
    transition: all var(--duration-mid) var(--ease-out);
  }

  .digest-card:hover {
    border-color: var(--border-bright);
    background: var(--surface-3);
  }

  .digest-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    justify-content: space-between;
  }

  .digest-card__category {
    color: var(--ember);
  }

  .digest-card__date {
    color: var(--text-tertiary);
  }

  .digest-card__title {
    font-size: var(--text-lg);
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }

  .digest-card__excerpt {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  /* ── Corpus CTA ──────────────────────────────────────────────────────── */
  .corpus-cta {
