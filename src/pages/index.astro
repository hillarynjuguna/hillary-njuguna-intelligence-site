<script define:vars={{ heroAssessmentResponses }}>
  const heroAssessmentButtons = document.querySelectorAll('.hero-assessment__option');
  const heroAssessmentResponse = document.getElementById('hero-assessment-response');
  const heroAssessmentInsight = document.getElementById('hero-assessment-insight');

  heroAssessmentButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const answer = button.getAttribute('data-answer');
      const copy = answer ? heroAssessmentResponses[answer]?.insight : '';
      heroAssessmentButtons.forEach((item) => item.classList.remove('is-selected'));
      button.classList.add('is-selected');
      if (copy && heroAssessmentInsight && heroAssessmentResponse) {
        heroAssessmentInsight.textContent = copy;
        heroAssessmentResponse.removeAttribute('hidden');
      }
    });
  });
</script>
