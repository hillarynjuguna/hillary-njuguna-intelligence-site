---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import { getFeaturedDigestEntries, getFeaturedResearch, getFeaturedProducts, getCurrentSignal, formatDate } from '@lib/content';
import { TICKER_ITEMS, SERVICES } from '@data/navigation';
import LogoEmblem from '@components/ui/LogoEmblem.astro';
import { SITE } from '@data/site';

const [digestEntries, researchEntries, products, signal] = await Promise.all([
  getFeaturedDigestEntries(3),
  getFeaturedResearch(),
  getFeaturedProducts(),
  getCurrentSignal(),
]);

const tickerItems = [...TICKER_ITEMS, ...TICKER_ITEMS];
---

<BaseLayout title={undefined} description={SITE.description}>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">
        <div class="hero__emblem-wrap" data-reveal="fade">
          <LogoEmblem size={160} className="hero__emblem" />
        </div>

        <h1 class="hero__headline" data-reveal="sweep">
          Fear isn’t a feeling —<br />
          it’s an architecture.
        </h1>

        <p class="hero__sub" data-reveal="fade" data-reveal-delay="1">
          I study what happens when AI systems fail inside institutions that can't afford it.
          Then I build the governance architecture that makes those failures visible before they occur.
        </p>

        <div class="hero__origin label" data-reveal="fade" data-reveal-delay="2">
          <span class="hero__origin-name">Hillary Njuguna</span>
          <span class="hero__origin-sep">·</span>
          Nairobi → Kuala Lumpur
          <span class="hero__origin-sep">·</span>
          560+ sourced documents across 18 months
        </div>

        <!-- Intent routing — the first thing a visitor should understand -->
        <div class="hero__routes" data-reveal="sweep-group">
          <a href="/research/bainbridge-warning" class="route-card">
            <span class="route-card__label label">I want the diagnosis</span>
            <span class="route-card__title">The Bainbridge Warning</span>
            <span class="route-card__desc">Why AI governance fails — and what the failure pattern looks like before it becomes catastrophic.</span>
          </a>
          <a href="/research" class="route-card">
            <span class="route-card__label label">I want the research</span>
            <span class="route-card__title">The Research Corpus</span>
            <span class="route-card__desc">DCFB, AURORA, RSPS, and the full theoretical architecture behind the governance work.</span>
          </a>
          <a href="/cir-assessment" class="route-card">
            <span class="route-card__label label">I need to assess my team</span>
            <span class="route-card__title">CIR Assessment</span>
            <span class="route-card__desc">Five questions that reveal your organisation's AI readiness across constitutional dimensions.</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ticker -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__inner">
      {tickerItems.map((item) => (
        <span class="ticker__item">{item}</span>
      ))}
    </div>
  </div>

  <!-- Research -->
  {researchEntries.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header" data-reveal="fade">
          <p class="label section__label">Research</p>
          <h2 class="section__title">The Public Doctrine</h2>
          <a href="/research" class="section__link label">All dispatches →</a>
        </div>
        <div class="research-grid card-grid">
          {researchEntries.slice(0, 3).map((entry) => (
            <a href={`/research/${entry.slug}`} class="research-card hover-lift">
              <div class="research-card__meta">
                {entry.data.themes.slice(0, 2).map((t) => (
                  <span class="label research-card__theme">{t}</span>
                ))}
              </div>
              <h3 class="research-card__title">{entry.data.title}</h3>
              <p class="research-card__summary">{entry.data.summary}</p>
              <span class="research-card__cta label">Read →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Products -->
  {products.length > 0 && (
    <section class="section section--dark">
      <div class="container">
        <div class="section__header" data-reveal="fade">
          <p class="label section__label">Products</p>
          <h2 class="section__title">Applied Governance</h2>
          <a href="/products" class="section__link label">All products →</a>
        </div>
        <div class="products-grid card-grid">
          {products.map((product) => (
            <a href={`/products/${product.slug}`} class="product-card hover-lift">
              <div class="product-card__header">
                <span class={`badge ${product.data.status === 'live' ? 'badge--live' : product.data.status === 'development' ? 'badge--dev' : 'badge--soon'}`}>
                  {product.data.status === 'live' ? 'Live' : product.data.status === 'development' ? 'In Development' : 'Coming Soon'}
                </span>
                {product.data.price && <span class="product-card__price label">{product.data.price}</span>}
              </div>
              <h3 class="product-card__title">{product.data.title}</h3>
              <p class="product-card__summary">{product.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Digest -->
  {digestEntries.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section__header" data-reveal="fade">
          <p class="label section__label">Field Notes</p>
          <h2 class="section__title">From Active Synthesis</h2>
          <a href="/digest" class="section__link label">All entries →</a>
        </div>
        <div class="digest-grid card-grid">
          {digestEntries.map((entry) => (
            <a href={`/digest/${entry.slug}`} class="digest-card hover-lift">
              <div class="digest-card__meta">
                <span class="label digest-card__category">{entry.data.category}</span>
                <time class="label digest-card__date" datetime={entry.data.publishedAt.toISOString()}>
                  {formatDate(entry.data.publishedAt)}
                </time>
              </div>
              <h3 class="digest-card__title">{entry.data.title}</h3>
              <p class="digest-card__excerpt">{entry.data.excerpt ?? entry.data.summary.slice(0, 120)}…</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Corpus CTA -->
  <section class="corpus-cta">
    <div class="container">
      <div class="corpus-cta__inner" data-reveal="fade">
        <div class="corpus-cta__text">
          <p class="label corpus-cta__label">The Corpus</p>
          <h2 class="corpus-cta__title">Query the working research directly</h2>
          <p class="corpus-cta__desc">
            This isn't a brochure. The site runs on a live research substrate —
            every doctrine, field note, and product specimen is sourced from the
            same body of work and queryable through a single interface.
          </p>
        </div>
        <div class="corpus-cta__action">
          <a href="/corpus" class="btn btn--primary corpus-cta__btn">Open corpus →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section--dark">
    <div class="container">
      <div class="section__header" data-reveal="fade">
        <p class="label section__label">Practice</p>
        <h2 class="section__title">How This Becomes Your Practice</h2>
        <a href="/contact" class="section__link label">Start a conversation →</a>
      </div>
      <div class="services-grid card-grid">
        {SERVICES.map((service) => (
          <div class="service-card">
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__desc">{service.description}</p>
            {service.cta && (
              <a href={service.cta.href} class="service-card__link label">{service.cta.label} →</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero__emblem-wrap { margin-bottom: var(--space-8); }
  .hero__emblem { display: block; }
  .hero__emblem-wrap { margin-bottom: var(--space-8); }
  .hero__emblem { display: block; }
  .hero { min-height:90vh;display:flex;align-items:center;padding:120px 0 var(--space-16) }
  .hero__inner { width:100% }
  .hero__headline { font-family:var(--font-display);font-size:clamp(var(--text-4xl),7vw,var(--text-6xl));line-height:var(--leading-tight);color:var(--text-primary);margin-bottom:var(--space-6);font-weight:400 }
  .hero__sub { font-size:var(--text-lg);line-height:var(--leading-relaxed);color:var(--text-secondary);max-width:58ch;margin-bottom:var(--space-4) }
  .hero__origin { color:var(--text-tertiary);margin-bottom:var(--space-10) }
  .hero__origin-name { color:var(--ember) }
  .hero__origin-sep { margin:0 var(--space-2);opacity:.4 }

  /* Intent routing cards */
  .hero__routes { display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:var(--space-4) }
  .route-card { display:flex;flex-direction:column;gap:var(--space-2);padding:var(--space-5);border:1px solid rgba(196,112,58,0.18);border-radius:var(--radius-md);text-decoration:none;background:rgba(12,10,8,0.55);backdrop-filter:blur(16px) saturate(140%);-webkit-backdrop-filter:blur(16px) saturate(140%);box-shadow:0 8px 32px -8px rgba(0,0,0,0.6),inset 0 1px 0 rgba(196,112,58,0.08);transition:all .25s var(--ease-out) }
  .route-card:hover { border-color:rgba(196,112,58,0.38);background:rgba(12,10,8,0.68);transform:translateY(-2px);box-shadow:0 16px 48px -12px rgba(0,0,0,0.7),inset 0 1px 0 rgba(196,112,58,0.14) }
  .route-card__label { color:var(--ember);font-size:var(--text-xs) }
  .route-card__title { font-size:var(--text-base);color:var(--text-primary);font-weight:500 }
  .route-card__desc { font-size:var(--text-sm);color:var(--text-tertiary);line-height:var(--leading-relaxed) }

  /* Sections */
  .section { padding:var(--space-24) 0 }
  .section--dark { background:var(--surface-1);border-top:1px solid var(--border-dim);border-bottom:1px solid var(--border-dim) }
  .section__header { display:flex;align-items:baseline;gap:var(--space-4);margin-bottom:var(--space-10);flex-wrap:wrap }
  .section__label { color:var(--ember);flex-shrink:0 }
  .section__title { font-size:var(--text-3xl);flex:1 }
  .section__link { color:var(--text-tertiary);text-decoration:none;margin-left:auto;transition:color .15s;flex-shrink:0 }
  .section__link:hover { color:var(--ember) }

  /* Research cards */
  .research-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--space-5) }
  .research-card { display:flex;flex-direction:column;gap:var(--space-3);padding:var(--space-6);border:1px solid var(--border-dim);border-radius:var(--radius-md);text-decoration:none;background:var(--surface-2);transition:all .2s }
  .research-card:hover { border-color:var(--border-bright);background:var(--surface-3) }
  .research-card__meta { display:flex;gap:var(--space-3);flex-wrap:wrap }
  .research-card__theme { color:var(--ash-light);text-transform:capitalize }
  .research-card__title { font-size:var(--text-lg);color:var(--text-primary);line-height:var(--leading-snug) }
  .research-card__summary { font-size:var(--text-sm);color:var(--text-tertiary);line-height:var(--leading-relaxed);flex:1 }
  .research-card__cta { color:var(--ember);margin-top:var(--space-2) }

  /* Product cards */
  .products-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-5) }
  .product-card { display:flex;flex-direction:column;gap:var(--space-3);padding:var(--space-5);border:1px solid var(--border-dim);border-radius:var(--radius-md);text-decoration:none;background:var(--surface-2);transition:all .2s }
  .product-card:hover { border-color:var(--border-bright) }
  .product-card__header { display:flex;justify-content:space-between;align-items:center }
  .product-card__price { color:var(--ember) }
  .product-card__title { font-size:var(--text-base);color:var(--text-primary);font-weight:500 }
  .product-card__summary { font-size:var(--text-sm);color:var(--text-tertiary);line-height:var(--leading-relaxed) }

  /* Digest cards */
  .digest-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:var(--space-5) }
  .digest-card { display:flex;flex-direction:column;gap:var(--space-3);padding:var(--space-5);border:1px solid var(--border-dim);border-radius:var(--radius-md);text-decoration:none;background:var(--surface-2);transition:all .2s }
  .digest-card:hover { border-color:var(--border-bright) }
  .digest-card__meta { display:flex;gap:var(--space-4) }
  .digest-card__category { color:var(--ember) }
  .digest-card__date { color:var(--text-tertiary) }
  .digest-card__title { font-size:var(--text-base);color:var(--text-primary);line-height:var(--leading-snug) }
  .digest-card__excerpt { font-size:var(--text-sm);color:var(--text-tertiary);line-height:var(--leading-relaxed) }

  /* Corpus CTA */
  .corpus-cta { padding:var(--space-20) 0 }
  .corpus-cta__inner { display:flex;align-items:center;gap:var(--space-10);padding:var(--space-10);border:1px solid var(--border-dim);border-radius:var(--radius-lg);background:var(--surface-2);flex-wrap:wrap }
  .corpus-cta__text { flex:1;min-width:280px }
  .corpus-cta__label { color:var(--ember) }
  .corpus-cta__title { font-size:var(--text-2xl);margin:var(--space-2) 0 var(--space-4) }
  .corpus-cta__desc { color:var(--text-secondary);line-height:var(--leading-relaxed) }

  /* Services */
  .services-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-5) }
  .service-card { padding:var(--space-6);border:1px solid var(--border-dim);border-radius:var(--radius-md);background:var(--surface-2) }
  .service-card__title { font-size:var(--text-base);margin-bottom:var(--space-3);color:var(--text-primary) }
  .service-card__desc { font-size:var(--text-sm);color:var(--text-tertiary);line-height:var(--leading-relaxed);margin-bottom:var(--space-3) }
  .service-card__link { color:var(--ember);text-decoration:none }

  /* Ticker */
  .ticker { border-top:1px solid var(--border-dim);border-bottom:1px solid var(--border-dim);padding:var(--space-3) 0;overflow:hidden;background:var(--surface-1) }
  .ticker__inner { display:flex;gap:var(--space-8);animation:ticker 40s linear infinite;white-space:nowrap }
  .ticker__item { font-family:var(--font-mono);font-size:var(--text-xs);letter-spacing:.12em;color:var(--text-tertiary);text-transform:uppercase }
  @keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
</style>
