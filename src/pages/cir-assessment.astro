---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import CirAssessment from '@components/assessment/CirAssessment';
import '@styles/cir.css';
---

<BaseLayout
  title="CIR v2.0 Live Assessment"
  description="Run a live interactive version of the Cognitive Infrastructure Readiness framework."
>
  <div class="field-page page-enter">
    <div class="container">
      <FieldHeader
        eyebrow="Diagnostic tool"
        title="CIR v2.0 Assessment"
        summary="AI readiness is a constitutional question. This interactive diagnostic evaluates your organization's structural capability to deploy autonomous agents without governance failure."
        meta={[
          { label: 'Mode', value: 'Interactive' },
          { label: 'Duration', value: '5 minutes' },
          { label: 'Output', value: 'Readiness report' },
        ]}
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Read doctrine', href: '/research', tone: 'secondary' },
        ]}
      />

      <div class="field-layout">
        <div class="field-main">
          <CirAssessment client:load />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
