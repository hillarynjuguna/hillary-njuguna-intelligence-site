---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="This page does not exist in the published field. Return to the homepage, research archive, or corpus."
>
  <section class="not-found">
    <div class="container">
      <div class="not-found__card">
        <p class="label not-found__label">404</p>
        <h1 class="not-found__title">This page is not in the published field.</h1>
        <p class="not-found__desc">
          The link may be outdated, the page may have moved, or the public interface may not have published that thread yet.
        </p>
        <div class="not-found__actions">
          <a href="/" class="btn btn--primary">Return home</a>
          <a href="/research" class="btn btn--ghost">Open research archive</a>
          <a href="/corpus" class="btn btn--ghost">Enter the corpus</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: var(--space-24) 0;
  }

  .not-found__card {
    max-width: 60ch;
    padding: var(--space-10);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
  }

  .not-found__label {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .not-found__title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-5);
  }

  .not-found__desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
