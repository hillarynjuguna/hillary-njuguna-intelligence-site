---
export const prerender = true;
import FieldShellLayout from '@layouts/FieldShellLayout.astro';
import { buildFieldPrompt } from '@lib/field';

const prompt = buildFieldPrompt('orient', {
  title: 'Page not found',
  nodeHref: '/404',
  primaryCorpusHref: '/corpus',
});
---

<FieldShellLayout
  title="Page Not Found"
  description="This page does not exist in the published field. Return to the homepage, research archive, or corpus."
  eyebrow="404"
  summary="This route is not part of the currently published field. Recover by returning to a stable archive, the corpus map, or the homepage."
  actions={[
    { label: 'Return home', href: '/', tone: 'primary' },
    { label: 'Open research archive', href: '/research', tone: 'ghost' },
    { label: 'Enter the corpus', href: '/corpus', tone: 'secondary' },
  ]}
  prompt={prompt}
  facts={[
    { label: 'State', value: 'Missing route' },
    { label: 'Recovery', value: 'Use archive, corpus, or homepage' },
  ]}
>
  <section class="not-found">
    <div class="not-found__card">
      <p class="label not-found__label">404</p>
      <h2 class="not-found__title">This page is not in the published field.</h2>
      <p class="not-found__desc">
        The link may be outdated, the page may have moved, or the public interface may not have published that thread yet.
      </p>
      <div class="not-found__actions">
        <a href="/" class="btn btn--primary">Return home</a>
        <a href="/research" class="btn btn--ghost">Open research archive</a>
        <a href="/corpus" class="btn btn--ghost">Enter the corpus</a>
      </div>
    </div>
  </section>
</FieldShellLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: flex-start;
  }

  .not-found__card {
    max-width: 60ch;
    padding: var(--space-10);
    border: 1px solid var(--border-mid);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-2), var(--surface-3));
  }

  .not-found__label {
    color: var(--ember);
    margin-bottom: var(--space-4);
  }

  .not-found__title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-5xl));
    margin-bottom: var(--space-5);
  }

  .not-found__desc {
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
</style>
