---
import BaseLayout from './BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import type { SEOProps } from '@lib/seo';
import type { RelatedItem } from '@lib/graph/types';
import type { FieldPromptSpec } from '@lib/field';
import { formatDate } from '@lib/content';
import { getTagHref } from '@lib/field';

interface Props extends SEOProps {
  title: string;
  summary?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
  domains?: string[];
  category?: string;
  author?: string;
  breadcrumbs?: { name: string; href: string }[];
  related?: RelatedItem[];
  governance?: RelatedItem[];
  lineage?: string[];
  prompt?: FieldPromptSpec;
  showByline?: boolean;
  version?: string;
  changelog?: Array<{ version: string; date: Date | string; summary: string }>;
  crystallization?: string;
  slug?: string;
}

const {
  title,
  summary,
  publishedAt,
  updatedAt,
  tags = [],
  domains = [],
  category,
  author = 'Hillary Njuguna',
  breadcrumbs = [],
  related = [],
  governance = [],
  lineage = [],
  prompt,
  showByline = true,
  version,
  changelog = [],
  crystallization,
  slug,
  ...seoProps
} = Astro.props;

const meta = [
  category ? { label: 'Type', value: category } : null,
  showByline ? { label: 'Author', value: author } : null,
  publishedAt ? { label: 'Published', value: formatDate(publishedAt) } : null,
  updatedAt && publishedAt && updatedAt > publishedAt
    ? { label: 'Updated', value: formatDate(updatedAt) }
    : null,
  version ? { label: 'Version', value: `v${version}` } : null,
  crystallization ? { label: 'Maturity', value: crystallization.toUpperCase() } : null,
].filter((item): item is { label: string; value: string } => Boolean(item));

const chips = tags.slice(0, 6).map((tag) => ({
  label: `#${tag}`,
  href: getTagHref(tag),
}));

import Citation from '@components/mdx/Citation.astro';
---

<BaseLayout {...seoProps} title={title}>
  <article class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        title={title}
        summary={summary}
        breadcrumbs={breadcrumbs}
        eyebrow={category}
        meta={meta}
        chips={chips}
        width="wide"
      />

      <div class="field-layout">
        <div class="field-main">
          <div class="prose content-body">
            <slot />
            
            {changelog && changelog.length > 0 && (
              <div class="changelog-block">
                <div class="changelog-title">Version History</div>
                <div class="changelog-list">
                  {changelog.map((entry) => (
                    <div class="changelog-item">
                      <div class="changelog-meta">
                        <span class="changelog-version">v{entry.version}</span>
                        <span class="changelog-date">
                          {new Date(entry.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                        </span>
                      </div>
                      <div class="changelog-desc">{entry.summary}</div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {slug && publishedAt && (
              <Citation
                title={title}
                author={author}
                publishedAt={publishedAt}
                version={version}
                slug={slug}
              />
            )}

            <hr class="post-prose-rule" />
            <div class="post-prose-actions">
              <a href="/corpus" class="btn btn--ghost">Open corpus</a>
              <a href="/orchestra-operation" class="btn btn--secondary">Query Intelligence</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="field-coordinate" aria-hidden="true">SYS.LOC // KL-UTC+8</div>
  </article>
</BaseLayout>

<style>
  .content-body {
    margin: 0 auto;
  }
  .post-prose-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  
  .changelog-block {
    margin: var(--space-8) 0;
    padding: var(--space-6);
    background: linear-gradient(135deg, rgba(20, 18, 16, 0.3) 0%, rgba(10, 8, 7, 0.5) 100%);
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
  }

  .changelog-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-dim);
    padding-bottom: var(--space-2);
  }

  .changelog-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .changelog-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .changelog-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .changelog-version {
    font-size: var(--text-xxs);
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--text-primary);
    background: rgba(255,255,255,0.06);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .changelog-date {
    font-size: var(--text-xxs);
    font-weight: 600;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .changelog-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }
</style>
