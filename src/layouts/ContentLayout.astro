---
import BaseLayout from './BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import type { SEOProps } from '@lib/seo';
import type { RelatedItem } from '@lib/graph/types';
import type { FieldPromptSpec } from '@lib/field';
import { formatDate } from '@lib/content';
import { getTagHref } from '@lib/field';

interface Props extends SEOProps {
  title: string;
  summary?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
  domains?: string[];
  category?: string;
  author?: string;
  breadcrumbs?: { name: string; href: string }[];
  related?: RelatedItem[];
  governance?: RelatedItem[];
  lineage?: string[];
  prompt?: FieldPromptSpec;
  showByline?: boolean;
}

const {
  title,
  summary,
  publishedAt,
  updatedAt,
  tags = [],
  domains = [],
  category,
  author = 'Hillary Njuguna',
  breadcrumbs = [],
  related = [],
  governance = [],
  lineage = [],
  prompt,
  showByline = true,
  ...seoProps
} = Astro.props;

const meta = [
  category ? { label: 'Type', value: category } : null,
  showByline ? { label: 'Author', value: author } : null,
  publishedAt ? { label: 'Published', value: formatDate(publishedAt) } : null,
  updatedAt && publishedAt && updatedAt > publishedAt
    ? { label: 'Updated', value: formatDate(updatedAt) }
    : null,
].filter((item): item is { label: string; value: string } => Boolean(item));

const chips = tags.slice(0, 6).map((tag) => ({
  label: `#${tag}`,
  href: getTagHref(tag),
}));
---

<BaseLayout {...seoProps} title={title}>
  <article class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        title={title}
        summary={summary}
        breadcrumbs={breadcrumbs}
        eyebrow={category}
        meta={meta}
        chips={chips}
        width="wide"
        actions={[
          { label: 'Open corpus', href: '/corpus', tone: 'ghost' },
          { label: 'Query Intelligence', href: '/orchestra-operation', tone: 'secondary' },
        ]}
      />

      <div class="field-layout">
        <div class="field-main">
          <div class="prose content-body">
            <slot />
          </div>
        </div>

              </div>
    </div>
  </article>
</BaseLayout>

<style>
  .content-body {
    margin: 0 auto;
  }
</style>
