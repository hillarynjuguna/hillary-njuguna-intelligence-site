---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@components/ui/Breadcrumbs.astro';
import RelatedContent from '@components/relations/RelatedContent.astro';
import type { SEOProps } from '@lib/seo';
import type { RelatedItem } from '@lib/graph/types';
import { formatDate } from '@lib/content';

interface Props extends SEOProps {
  title: string;
  summary?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
  category?: string;
  author?: string;
  breadcrumbs?: { name: string; href: string }[];
  related?: RelatedItem[];
  showByline?: boolean;
}

const {
  title,
  summary,
  publishedAt,
  updatedAt,
  tags = [],
  category,
  author = 'Hillary Njuguna',
  breadcrumbs = [],
  related = [],
  showByline = true,
  ...seoProps
} = Astro.props;
---

<BaseLayout {...seoProps} title={title}>
  <article class="content-article page-enter">
    <div class="container container--narrow">
      {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}

      <header class="content-header">
        {category && (
          <p class="label content-category">{category}</p>
        )}
        <h1 class="content-title">{title}</h1>
        {summary && (
          <p class="content-summary">{summary}</p>
        )}
        {showByline && publishedAt && (
          <div class="content-meta">
            <span class="label">{author}</span>
            <span class="label content-sep">·</span>
            <time class="label" datetime={publishedAt.toISOString()}>
              {formatDate(publishedAt)}
            </time>
            {updatedAt && updatedAt > publishedAt && (
              <>
                <span class="label content-sep">·</span>
                <span class="label">
                  Updated {formatDate(updatedAt)}
                </span>
              </>
            )}
          </div>
        )}
        {tags.length > 0 && (
          <div class="content-tags">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class="tag link--hover">#{tag}</a>
            ))}
          </div>
        )}
      </header>

      <div class="prose content-body">
        <slot />
      </div>

      {related.length > 0 && (
        <RelatedContent items={related} />
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .content-article {
    padding: var(--space-24) 0 var(--space-32);
  }

  .content-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--border-dim);
  }

  .content-category {
    margin-bottom: var(--space-4);
    color: var(--ember);
  }

  .content-title {
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-5);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .content-title {
      font-size: var(--text-3xl);
    }
  }

  .content-summary {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--space-5);
    font-family: var(--font-display);
    font-style: italic;
  }

  .content-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .content-sep {
    opacity: 0.4;
  }

  .content-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ash-light);
    padding: 2px 8px;
    border: 1px solid var(--border-dim);
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  .content-body {
    margin: 0 auto;
  }
</style>
