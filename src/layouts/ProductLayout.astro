---
import BaseLayout from './BaseLayout.astro';
import FieldHeader from '@components/field/FieldHeader.astro';
import type { SEOProps } from '@lib/seo';
import type { RelatedItem } from '@lib/graph/types';
import type { FieldPromptSpec } from '@lib/field';
import { getStatusLabel, getStatusBadgeClass } from '@lib/content';

interface Props extends SEOProps {
  title: string;
  summary: string;
  status: string;
  price?: string;
  ctaLabel?: string;
  ctaUrl?: string;
  waitlistUrl?: string;
  breadcrumbs?: { name: string; href: string }[];
  faq?: { q: string; a: string }[];
  related?: RelatedItem[];
  governance?: RelatedItem[];
  lineage?: string[];
  domains?: string[];
  tags?: string[];
  prompt?: FieldPromptSpec;
}

const {
  title,
  summary,
  status,
  price,
  ctaLabel,
  ctaUrl,
  waitlistUrl,
  breadcrumbs = [],
  faq = [],
  related = [],
  governance = [],
  lineage = [],
  domains = [],
  tags = [],
  prompt,
  ...seoProps
} = Astro.props;

const badgeClass = getStatusBadgeClass(status);
const statusLabel = getStatusLabel(status);
const primaryCta = status === 'live' ? ctaUrl : waitlistUrl;
const primaryCtaLabel = status === 'live' ? (ctaLabel ?? 'Get access') : 'Join waitlist';
---

<BaseLayout {...seoProps} title={title} ogType="article">
  <div class="field-page page-enter">
    <div class="container container--wide">
      <FieldHeader
        eyebrow="Applied node"
        title={title}
        summary={summary}
        breadcrumbs={breadcrumbs}
        meta={[
          { label: 'Status', value: statusLabel },
          ...(price ? [{ label: 'Price', value: price }] : []),
        ]}
        actions={[
          ...(primaryCta ? [{ label: primaryCtaLabel, href: primaryCta, tone: 'primary', external: primaryCta.startsWith('http') }] : []),
          { label: 'Research corpus', href: '/research', tone: 'ghost' },
        ]}
        width="wide"
      />

      <div class="field-layout field-layout--wide">
        <div class="field-main">
          <div class="product-shell">
            <div class="product-status-row">
              <span class={`badge ${badgeClass}`}>{statusLabel}</span>
            </div>

            <div class="prose product-body">
              <slot />
            </div>

            {faq.length > 0 && (
              <section class="product-faq">
                <h2 class="faq-heading">Common questions</h2>
                <div class="faq-list">
                  {faq.map(({ q, a }) => (
                    <details class="faq-item">
                      <summary class="faq-q">{q}</summary>
                      <p class="faq-a">{a}</p>
                    </details>
                  ))}
                </div>
              </section>
            )}
          </div>
        </div>

        <div class="product-rail">
          <div class="field-panel">
            <div class="product-cta-card">
              <div class="cta-status">
                <span class={`badge ${badgeClass}`}>{statusLabel}</span>
              </div>
              {price && <div class="cta-price">{price}</div>}
              {primaryCta && (
                <a
                  href={primaryCta}
                  class="btn btn--primary cta-btn"
                  target={primaryCta.startsWith('http') ? '_blank' : undefined}
                  rel={primaryCta.startsWith('http') ? 'noopener noreferrer' : undefined}
                >
                  {primaryCtaLabel}
                </a>
              )}
              <div class="cta-contact">
                <p class="label">Questions</p>
                <a href="mailto:hillarynjuguna@protonmail.com" class="cta-email">
                  hillarynjuguna@protonmail.com
                </a>
              </div>
            </div>
          </div>

                  </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .product-shell {
    display: grid;
    gap: var(--space-10);
  }

  .product-status-row {
    margin-bottom: calc(var(--space-6) * -1);
  }

  .product-rail {
    display: grid;
    gap: var(--space-4);
  }

  .product-cta-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-price {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--pale-gold);
  }

  .cta-btn {
    width: 100%;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
  }

  .cta-contact {
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-dim);
  }

  .cta-email {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--ember);
  }

  .product-faq {
    padding-top: var(--space-12);
    border-top: 1px solid var(--border-dim);
  }

  .faq-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-8);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .faq-item {
    border: 1px solid var(--border-dim);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-q {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .faq-q:hover {
    background: var(--surface-3);
  }

  .faq-q::after {
    content: '+';
    font-size: var(--text-lg);
    color: var(--ember);
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .faq-item[open] .faq-q::after {
    transform: rotate(45deg);
  }

  .faq-a {
    padding: var(--space-4) var(--space-5) var(--space-5);
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    border-top: 1px solid var(--border-dim);
    background: var(--surface-1);
  }
</style>
